  "passive": {
    "name": "聚能之炎",
    "description": "卡尔玛的伤害型技能将缩短梵咒的冷却时间。",
    "image": "Karma_Passive.png"
  },
  "spells": [
    {
      "name": "心灵烈焰",
      "description": "卡尔玛向前方发射一枚灵能法球。这枚法球会在命中第一个敌人时爆炸，并造成伤害。梵咒增效：除爆炸之外，梵咒还会提升她的心灵烈焰的破坏力，同时创造出一个火环，火环会在短暂的延时后造成伤害。",
      "tooltip": "卡尔玛发射一团能量，对命中的第一个目标及其周围的敌人们造成{{ totaldamage }}魔法伤害，以及持续{{ slowduration }}秒的{{ slowamount*-100 }}%减速。",
      "cooldown": "9/8/7/6/5",
      "cost": "40/50/60/70/80",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "KarmaQ.png",
      "key": "Q"
    },
    {
      "name": "坚定不移",
      "description": "卡尔玛在她和目标敌人之间产生一条灵链，同时造成伤害，并使目标暴露。如果灵链在一段时间内没有被破坏，那么目标敌人就会被束缚在原地并再次受到伤害。梵咒增效：卡尔玛强化灵链，治疗自身并延长禁锢时长。",
      "tooltip": "卡尔玛用灵链来连接她和一名敌方英雄或野怪，造成{{ initialdamage }}魔法伤害并使其显形{{ tetherduration }}秒。如果灵链一直未断裂，那么目标会再次受到{{ initialdamage }}魔法伤害并被禁锢{{ rootduration }}秒。",
      "cooldown": "12",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "675",
      "maxrank": 5,
      "image": "KarmaSpiritBind.png",
      "key": "W"
    },
    {
      "name": "鼓舞",
      "description": "卡尔玛召唤一个防御性的护盾来吸收即将到来的伤害，并为目标友军提升移动速度。梵咒增效：能量从目标处向外辐射，强化初始护盾，并对附近的友方英雄施加鼓舞效果。",
      "tooltip": "卡尔玛为一名友方英雄提供持续{{ shieldduration }}秒的{{ totalshield }}护盾值和持续{{ movespeedduration }}秒的{{ movespeed*100 }}%移动速度。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "KarmaSolKimShield.png",
      "key": "E"
    },
    {
      "name": "梵咒",
      "description": "卡尔玛的下个技能会获得强化，造成额外特效。梵咒在1级时就可以使用，并且不需要投入技能点。",
      "tooltip": "卡尔玛增强她在8秒内使用的下一个技能。心灵烈焰：造成额外的{{ rqimpactdamage }}魔法伤害并留下一道烈焰圆环，减速敌人并造成额外的{{ rqfielddamage }}魔法伤害。坚定不移：卡尔玛将在灵链的开始和结束时回复{{ rwhealamount }}已损失生命值，并且禁锢延长{{ rwbonusroot }}秒。鼓舞：卡尔玛为她的目标提供额外的{{ rebonusshield }}护盾值，并且还会对目标附近的友军提供护盾，为他们提供{{ rebonusshieldarea }}护盾值和{{ removespeed*100 }}%移动速度。",
      "cooldown": "40/38/36/34",
      "cost": "0",
      "costType": "无消耗",
      "range": "1100",
      "maxrank": 4,
      "image": "KarmaMantra.png",
      "key": "R"
    }
  ]
}