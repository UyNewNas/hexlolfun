  "passive": {
    "name": "地狱诅咒",
    "description": "锤石可以收割那些死在他身边的敌人们的灵魂，从而为他提供护甲和法术强度。",
    "image": "Thresh_Passive.png"
  },
  "spells": [
    {
      "name": "死亡判决",
      "description": "在激活时，锤石会绑住一名敌方目标，并将该目标拉向锤石。再次激活此技能，会将锤石拉向该目标。",
      "tooltip": "锤石投出他的镰刀，晕眩命中的第一个单位并将其拉拽向锤石{{ tauntlength }}秒。镰刀造成{{ totaldamage }}魔法伤害并且还会在持续期间提供真实视野。锤石可以再次施放这个技能来将自身拉拽到敌人处。如果这个技能命中了，那么它的冷却时间缩短{{ hitbonuscooldown }}秒。",
      "cooldown": "19/16.5/14/11.5/9",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "1075",
      "maxrank": 5,
      "image": "ThreshQ.png",
      "key": "Q"
    },
    {
      "name": "魂引之灯",
      "description": "锤石扔出一个灯笼来为周围友军武装一层抵挡伤害的护盾。友军可以通过点击灯笼来冲到锤石身边。",
      "tooltip": "锤石扔出他的灯笼，允许一名友军点击它来冲刺到锤石处。灯笼也会提供持续{{ shieldduration }}秒的{{ totalshield }}护盾值给锤石和前去触摸灯笼的第一个友方英雄。",
      "cooldown": "21/20/19/18/17",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "ThreshW.png",
      "key": "W"
    },
    {
      "name": "厄运钟摆",
      "description": "锤石会提升攻击伤害，攻击的间歇期越久伤害值越高。在激活此技能时，锤石会挥舞他的锁链，将命中的所有敌人带向锁链挥舞的方向。",
      "tooltip": "被动：锤石的攻击造成额外伤害，伤害值基于与他最后一次攻击相隔的时间。造成{{ pattackdamagemin }}到{{ pattackdamagemax }}魔法伤害。主动：锤石挥舞他的锁链，沿挥舞的方向拉拽或推挤敌人。还会对命中的敌人们造成持续{{ e4 }}秒的{{ e2 }}%减速和{{ totaldamage }}魔法伤害。",
      "cooldown": "13/12.25/11.5/10.75/10",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 5,
      "image": "ThreshE.png",
      "key": "E"
    },
    {
      "name": "幽冥监牢",
      "description": "构建一座监牢，其墙壁在被敌方单位打破时对该敌方单位造成伤害和减速效果。",
      "tooltip": "锤石生成一个由灵魂墙体组成的监牢，对英雄造成持续{{ e2 }}秒的{{ e3 }}%减速和{{ totaldamage }}魔法伤害。墙体一经碰撞就会被打破，并且一旦被打破一面墙体，剩余的就不会造成伤害且减速时长减半。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 3,
      "image": "ThreshRPenta.png",
      "key": "R"
    }
  ]
}