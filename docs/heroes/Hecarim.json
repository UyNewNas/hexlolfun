  "passive": {
    "name": "征战之路",
    "description": "赫卡里姆获得相当于他一部分额外移动速度的攻击力加成。",
    "image": "Hecarim_Passive.png"
  },
  "spells": [
    {
      "name": "暴走",
      "description": "赫卡里姆猛劈周围的敌人，同时造成物理伤害。如果这个技能对至少一名敌人造成伤害，那么赫卡里姆会提升【暴走】的伤害并为随后施放的【暴走】缩短冷却时间。",
      "tooltip": "赫卡里姆顺劈周围的敌人，造成{{ damage }}物理伤害。如果这个技能命中了敌人，那么他会获得一层效果，来使这次技能的冷却时间降低{{ rampagecooldownreduction }}秒并提升此技能{{ rampagebonusdamageperc }}%伤害，持续{{ e6 }}秒。这个效果至多可达{{ e2 }}层。",
      "cooldown": "4",
      "cost": "28/26/24/22/20",
      "costType": " {{ abilityresourcename }}",
      "range": "350",
      "maxrank": 5,
      "image": "HecarimRapidSlash.png",
      "key": "Q"
    },
    {
      "name": "恐惧之灵",
      "description": "赫卡里姆获得护甲和魔抗。赫卡里姆对附近敌人造成魔法伤害，并基于敌人所受的伤害来恢复生命值。",
      "tooltip": "赫卡里姆在{{ buffduration }}秒里对附近的敌人们持续造成共{{ totaldamage }}魔法伤害。赫卡里姆获得{{ resistamount }} 护甲和魔法抗性并治疗自身，治疗数额相当于这些敌人受到的来自赫卡里姆的{{ leechamount }}%伤害和来自赫卡里姆友军的{{ allytooltipleachvalue }}%伤害。",
      "cooldown": "14",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "525",
      "maxrank": 5,
      "image": "HecarimW.png",
      "key": "W"
    },
    {
      "name": "毁灭冲锋",
      "description": "赫卡里姆获得不断提升的移动速度加成并且移动时可以无视单位的碰撞体积。他的下一次攻击将会击退目标，并且造成额外物理伤害，伤害值基于他在激活该技能后所移动的距离。",
      "tooltip": "赫卡里姆变为幽灵状态，并获得{{ minmovespeed*100 }}%移动速度，在{{ e5 }}秒里持续提升至{{ maxmovespeed*100 }}%。他的下次攻击会击退目标并造成{{ mindamage }}到{{ maxdamage }}物理伤害。击退距离和伤害随此技能期间的位移距离而增长。",
      "cooldown": "20/19/18/17/16",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "HecarimRamp.png",
      "key": "E"
    },
    {
      "name": "暗影冲击",
      "description": "赫卡里姆召唤幽魂骑兵向前冲锋，对一条直线上的敌人造成魔法伤害。赫卡里姆会在完成他的冲锋时发出一道冲击波，来使周围的敌人惊慌失措地逃命。",
      "tooltip": "赫卡里姆召唤幽魂骑兵并向前冲锋，造成{{ damagedone }}魔法伤害。赫卡里姆会在他冲锋的终点释放一道冲击波，来使敌人们恐惧{{ feardurationmin }}到{{ feardurationmax }}秒，随冲锋距离提升。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "50000",
      "maxrank": 3,
      "image": "HecarimUlt.png",
      "key": "R"
    }
  ]
}