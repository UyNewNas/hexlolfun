  "passive": {
    "name": "战争律动",
    "description": "嘉文四世对一名敌人发起的第一次普攻会造成基于目标当前生命值的额外物理伤害。这个效果在数秒内无法重复作用于同一目标。",
    "image": "JarvanIVP.png"
  },
  "spells": [
    {
      "name": "巨龙撞击",
      "description": "嘉文四世的长矛穿透敌人，对沿途的敌人造成物理伤害和护甲击碎效果。如果嘉文四世该技能指向德邦军旗，那么他将会被导向军旗，并击飞沿途所有敌人。",
      "tooltip": "嘉文延伸他的长枪，造成{{ totaldamage }}物理伤害并移除{{ basearshred*100 }}%护甲，持续{{ e3 }}秒。如果长枪与德邦军旗连接，那么嘉文会将自己拉向它，将沿途的敌人击飞0.75秒。",
      "cooldown": "10/9/8/7/6",
      "cost": "45/50/55/60/65",
      "costType": " {{ abilityresourcename }}",
      "range": "770",
      "maxrank": 5,
      "image": "JarvanIVDragonStrike.png",
      "key": "Q"
    },
    {
      "name": "黄金圣盾",
      "description": "嘉文四世召唤古德玛西亚国王保护自己，护盾吸收伤害并减速附近敌人。",
      "tooltip": "嘉文召唤一个圣盾，对附近的敌人造成持续{{ e5 }}秒的{{ baseslowamount*100 }}%减速并为他提供{{ totalshield }}护盾值，每命中一个敌方英雄会提升{{ bonusshield }}护盾值。",
      "cooldown": "9",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "625",
      "maxrank": 5,
      "image": "JarvanIVGoldenAegis.png",
      "key": "W"
    },
    {
      "name": "德邦军旗",
      "description": "嘉文四世携带着德玛西亚的骄傲，能被动地给予他额外的攻击速度。激活德邦军旗会使嘉文四世放置一面德玛西亚军旗，在军旗的着陆点造成魔法伤害，并强化军旗附近的队友们的攻击速度。",
      "tooltip": "被动：嘉文获得{{ permanentattackspeed*100 }}%攻击速度。主动：嘉文将一面军旗投掷到地上，造成{{ totaldamage }}魔法伤害并为附近的友军们提供持续{{ e4 }}秒的{{ baseauraas*100 }}%攻击速度。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "860",
      "maxrank": 5,
      "image": "JarvanIVDemacianStandard.png",
      "key": "E"
    },
    {
      "name": "天崩地裂",
      "description": "嘉文四世勇猛地跃向目标敌方英雄，对其造成物理伤害，并在敌人周围形成环形障碍，持续数秒。在嘉文四世着陆时，目标附近的敌人也会受到伤害。",
      "tooltip": "嘉文勇猛地跃向一名敌方英雄，对目标及周围的敌人造成{{ damagecalc }}物理伤害，并在目标周围生成一个由不可通过地形构成的竞技场，持续{{ wallduration }}秒。嘉文可以再次施放来使该地形倒塌。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 3,
      "image": "JarvanIVCataclysm.png",
      "key": "R"
    }
  ]
}