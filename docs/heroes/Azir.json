  "passive": {
    "name": "恕瑞玛的传承",
    "description": "阿兹尔可以从友方或敌方防御塔的废墟中召唤太阳圆盘。",
    "image": "Azir_Passive.png"
  },
  "spells": [
    {
      "name": "狂沙猛攻",
      "description": "阿兹尔把所有黄沙士兵派往一个地点。黄沙士兵会对沿途的所有敌人造成魔法伤害，并施加持续1秒的减速效果。",
      "tooltip": "阿兹尔把所有黄沙士兵派往一个区域，从而对它们途经的所有敌人造成{{ totaldamage }}魔法伤害，并施加持续1秒的{{ slowamount*-100 }}%减速。",
      "cooldown": "14/12/10/8/6",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "740",
      "maxrank": 5,
      "image": "AzirQWrapper.png",
      "key": "Q"
    },
    {
      "name": "沙兵现身",
      "description": "阿兹尔召唤一个黄沙士兵来为他攻击附近的敌方单位。如果敌方单位在士兵的攻击距离内，那么士兵会代替阿兹尔进行普攻。士兵的攻击会对一条直线上的敌人造成魔法伤害。",
      "tooltip": "阿兹尔召唤一个持续{{ e1 }}秒的黄沙士兵。当阿兹尔攻击处在一个黄沙士兵附近的敌人时，他会转而命令该士兵进行戳刺，在其方向上造成{{ totaldamage }}魔法伤害。这个技能拥有{{ maxammo }}层充能。",
      "cooldown": "1.5",
      "cost": "40/35/30/25/20",
      "costType": " {{ abilityresourcename }}",
      "range": "525",
      "maxrank": 5,
      "image": "AzirW.png",
      "key": "W"
    },
    {
      "name": "流沙移形",
      "description": "阿兹尔暂时套上一层护盾并冲向他的一个黄沙士兵，伤害敌人。如果他命中了一位敌方英雄，那么他就会准备好一个新的黄沙士兵并中断他的位移。",
      "tooltip": "阿兹尔为他自身提供{{ totalshield }}护盾值，持续{{ e6 }}秒并朝着他的一位黄沙士兵突进，对途经的敌人们造成{{ totaldamage }}魔法伤害。如果阿兹尔命中了一名敌方英雄，那么他就会停下来并获得一层黄沙士兵充能。",
      "cooldown": "22/20.5/19/17.5/16",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "AzirEWrapper.png",
      "key": "E"
    },
    {
      "name": "禁军之墙",
      "description": "阿兹尔召唤一道由禁军组成的人墙向前冲锋，对敌人造成伤害和击退效果。",
      "tooltip": "阿兹尔召唤一道由禁军组成的人墙向前冲锋，击退敌人们并造成{{ totaldamage }}魔法伤害。然后这道由禁军组成的人墙会持续{{ e4 }}秒，来阻挡敌人的前进。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "250",
