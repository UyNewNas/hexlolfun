  "passive": {
    "name": "爆头",
    "description": "每进行几次基础攻击，对中了她的陷阱或绳网的单位进行攻击时，凯特琳就会造成一次【爆头】效果，造成随暴击几率增长的额外伤害。在对中了陷阱或绳网的目标进行攻击时，凯特琳的【爆头】攻击距离翻倍。",
    "image": "Caitlyn_Headshot.png"
  },
  "spells": [
    {
      "name": "和平使者",
      "description": "凯特琳加速转动步枪，1秒后进行穿透射击，造成物理伤害（目标身后的单位受到较少伤害）。",
      "tooltip": "凯特琳加速转动她的步枪来射出一颗穿刺弹，造成{{ initialdamage }}物理伤害。在子弹命中第一个单位后，它会绽开为一个更宽的弹体，造成{{ secondarydamage }}物理伤害。被约德尔诱捕器显形的敌人总会受到全额伤害。",
      "cooldown": "10/9/8/7/6",
      "cost": "55/60/65/70/75",
      "costType": " {{ abilityresourcename }}",
      "range": "1250",
      "maxrank": 5,
      "image": "CaitlynQ.png",
      "key": "Q"
    },
    {
      "name": "约德尔诱捕器",
      "description": "凯特琳设下一个陷阱，这个陷阱在被敌方英雄踩中时，会使该英雄显形并被束缚1.5秒，并为凯特琳提供一次强化版的爆头。",
      "tooltip": "凯特琳设置一个陷阱来禁锢踩中它的第一个英雄{{ rootduration }}秒并提供该英雄的真实视野，持续3秒。陷阱持续{{ trapduration }}秒，并且同一时间至多可存在{{ maximumtraps }}个已激活的陷阱。这个技能有{{ maximumcharges }}层充能({{ ammorechargetime }}秒充能时间)。被这个技能禁锢的目标会从爆头中受到额外的{{ headshotbonusdamage }}物理伤害。",
      "cooldown": "0.5",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "CaitlynW.png",
      "key": "W"
    },
    {
      "name": "90口径绳网",
      "description": "凯特琳朝目标放出一张网，对其减速，并对凯特琳造成一定的反冲效果。",
      "tooltip": "凯特琳发射一张绳网，并将她向后推送。绳网对命中的第一个目标造成持续{{ e2 }}秒的{{ e3 }}%减速和{{ netdamage }}魔法伤害。",
      "cooldown": "16/14/12/10/8",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "CaitlynE.png",
      "key": "E"
    },
    {
      "name": "让子弹飞",
      "description": "凯特琳精心准备完美一击，拥有超远射程并对单个目标造成巨大伤害。敌方英雄能为友军拦截子弹。",
      "tooltip": "凯特琳花费一段时间来引导并精心准备完美一击，然后她会开火，造成{{ rtotaldamage }}物理伤害，但其他敌方英雄能拦截子弹。这个技能在引导期间会提供目标的真实视野。伤害受益于凯特琳的暴击几率和暴击伤害加成。",
      "cooldown": "90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "3500",
      "maxrank": 3,
      "image": "CaitlynR.png",
      "key": "R"
    }
  ]
}