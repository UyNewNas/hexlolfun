  "passive": {
    "name": "正气凌人",
    "description": "每次施放技能会强化塔里克的下2次普攻，以造成额外魔法伤害，使他的基础技能的冷却时间减少，并且可以快速地连续攻击。",
    "image": "Taric_Passive.png"
  },
  "spells": [
    {
      "name": "星光之触",
      "description": "基于已储存的充能来治疗附近的友方英雄。【正气凌人】的强化普攻会为这个技能提供一层充能。",
      "tooltip": "被动：每{{ stackcooldown }}秒和打出一次正气凌人攻击时获得一层效果(最多{{ e6 }}层)。主动：消耗所有层数来为附近的友方英雄们回复{{ healingperstack }}x层数的生命值(在{{ e6 }}层时回复{{ maxstackhealing }}生命值)。",
      "cooldown": "3",
      "cost": "60",
      "costType": "法力值，所有充能数",
      "range": "325",
      "maxrank": 5,
      "image": "TaricQ.png",
      "key": "Q"
    },
    {
      "name": "坚毅壁垒",
      "description": "被动提升塔里克和带有【坚毅壁垒】效果的友方英雄的护甲。主动施放会为一名友方英雄提供护盾和【坚毅壁垒】效果，只要该英雄呆在塔里克身边，【坚毅壁垒】效果会一直持续。塔里克的技能也会从带有【坚毅壁垒】效果的友方英雄身上施放。",
      "tooltip": "被动：塔里克获得{{ bonusarmor }}护甲并在他和被此技能绑定过的友方英雄之间形成一条灵链。只要他们在彼此附近，该友方英雄就会获得{{ bonusarmor }}护甲并且塔里克的各个技能也会从他自己和该友方英雄处施放。主动：塔里克与一名友方英雄进行绑定，提供持续{{ e3 }}秒的{{ e2 }}%最大生命值的护盾值。",
      "cooldown": "15",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "TaricW.png",
      "key": "W"
    },
    {
      "name": "炫光",
      "description": "塔里克准备施放一束星光，在短暂的延迟后，会对敌人造成魔法伤害和晕眩效果。",
      "tooltip": "塔里克投射一束星光，在{{ e3 }}秒后爆裂，以造成{{ totaldamage }}魔法伤害并使敌人们晕眩{{ e2 }}秒。",
      "cooldown": "16/15/14/13/12",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "610",
      "maxrank": 5,
      "image": "TaricE.png",
      "key": "E"
    },
    {
      "name": "宇宙之辉",
      "description": "在短暂的延迟后，放射一道宇宙能量到附近的友方英雄身上，让他们免疫伤害一段时间。",
      "tooltip": "塔里克召唤来自天堂的保护。在{{ initialdelay }}秒后，附近的所有友方英雄都会免疫伤害{{ invulnduration }}秒。",
      "cooldown": "180/150/120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 3,
      "image": "TaricR.png",
      "key": "R"
    }
  ]
