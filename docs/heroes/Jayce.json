  "passive": {
    "name": "海克斯科技电容",
    "description": "每当杰斯切换武器时，他会获得短暂持续的移动速度加成。",
    "image": "Jayce_Passive.png"
  },
  "spells": [
    {
      "name": "苍穹之跃 / 电能震荡",
      "description": "锤形态：跳向一个敌人，对敌人造成物理伤害和减速效果。 炮形态：发射一团电球，在命中一名敌人或者到达最大射程后爆炸，对命中的敌人造成物理伤害。",
      "tooltip": "墨丘利之锤：杰斯跳向一名敌人，对周围的敌人造成{{ spell.jaycetotheskies:damage }}物理伤害和持续{{ spell.jaycetotheskies:slowduration }}秒的{{ spell.jaycetotheskies:slow*-100 }}%减速。",
      "cooldown": "16/14/12/10/8/6",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 6,
      "image": "JayceToTheSkies.png",
      "key": "Q"
    },
    {
      "name": "闪电领域 / 超能电荷",
      "description": "锤形态：被动：每次攻击回复法力。主动：创造一个闪电领域，在数秒内对附近的敌人造成伤害。炮形态：杰斯的活力暴涨，将攻击速度提升至最大值，此效果在若干次攻击后消失。",
      "tooltip": "墨丘利之锤 - 被动：杰斯的战锤攻击会提供{{ spell.jaycestaticfield:managain }}法力值。墨丘利之锤 - 主动：杰斯创造一个电能光环，在{{ spell.jaycestaticfield:duration }}秒里持续造成共{{ spell.jaycestaticfield:damage }}魔法伤害。",
      "cooldown": "10",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "285",
      "maxrank": 6,
      "image": "JayceStaticField.png",
      "key": "W"
    },
    {
      "name": "雷霆一击 / 加速之门",
      "description": "锤形态：对一个敌人造成魔法伤害，并将目标击退一小段距离。炮形态：展开一个加速之门，所有穿过它的友军英雄都会得到移动速度加成。如果电能震荡穿过这个门发射，那么它的弹道速度和射程都会得到提高，并且伤害会提升。",
      "tooltip": "战锤形态：杰斯挥舞他的战锤，击退他的目标并造成{{ spell.jaycethunderingblow:flatdamage }}外加{{ spell.jaycethunderingblow:perchpdamage*100 }}%最大生命值的魔法伤害。",
      "cooldown": "20/18/16/14/12/10",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "240",
      "maxrank": 6,
      "image": "JayceThunderingBlow.png",
      "key": "E"
    },
    {
      "name": "墨丘利之炮 / 墨丘利之锤",
      "description": "锤形态：将墨丘利之锤变成墨丘利之炮，获得新的技能和远程攻击能力。切换至这个形态后的第一下攻击将会减少目标的护甲和魔法抗性。炮形态：将墨丘利之炮变成墨丘利之锤，获得新的技能和护甲与魔法抗性加成，切换至这个形态后的第一下攻击将会造成额外的魔法伤害。",
      "tooltip": "墨丘利之锤：杰斯将他的武器变形为墨丘利之炮，获得攻击距离和全新的一套技能。杰斯的下一个攻击移除{{ spell.jaycestancehtg:rangedformshred }}护甲和魔法抗性，持续{{ spell.jaycestancehtg:shredduration }}秒。",
      "cooldown": "6",
      "cost": "0",
      "costType": "无消耗",
      "range": "600",
      "maxrank": 1,
      "image": "JayceStanceHtG.png",
      "key": "R"
    }
  ]
