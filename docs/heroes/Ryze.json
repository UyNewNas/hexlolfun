  "passive": {
    "name": "奥术专精",
    "description": "瑞兹的技能会造成基于他法力值加成的额外伤害，并且他的最大法力值会基于他的法术强度来获得百分比的提升。",
    "image": "Ryze_P.png"
  },
  "spells": [
    {
      "name": "超负荷",
      "description": "被动部分：瑞兹的其它基础技能会重置【超负荷】的冷却时间并且充能一层符文。当瑞兹带着2层符文施放【超负荷】时，他会获得短暂的爆发性移动速度加成。施放时，瑞兹会沿直线扔出一团纯粹能量，来对命中的第一个敌人造成伤害。如果目标身上有【涌动】效果，那么【超负荷】会造成额外伤害并弹射至附近带有【涌动】效果的敌人身上。",
      "tooltip": "被动：符文禁锢和法术涌动会刷新这个技能的冷却时间并充能一枚符文，持续{{ runeduration }}秒(最多{{ maximumrunes }}枚符文)。主动：瑞兹释放一次魔爆，对命中的第一个敌人造成{{ qdamagecalc }}魔法伤害。如果目标带有涌动，则它会将其消耗，使这个技能造成{{ spell.ryzer:overloaddamagebonus }}%伤害提升并弹射至附近带有涌动的敌人们。如果{{ maximumrunes }}枚符文已被充能，瑞兹就会释放所有符文的能量，来为瑞兹提供持续{{ movementspeedduration }}秒的{{ movementspeedamount }}%移动速度。",
      "cooldown": "5",
      "cost": "40/38/36/34/32",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "RyzeQWrapper.png",
      "key": "Q"
    },
    {
      "name": "符文禁锢",
      "description": "瑞兹将一个目标陷入一个符文牢笼中，来对其造成伤害和减速效果。如果目标身上带有【涌动】效果，那么减速效果会替换为禁锢效果。",
      "tooltip": "瑞兹造成{{ wdamagecalc }}魔法伤害和持续{{ ccduration }}秒的{{ slowamount*100 }}%减速。如果目标带有涌动，则它会将其消耗，使这个技能造成禁锢而非减速。",
      "cooldown": "11/10.5/10/9.5/9",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "615",
      "maxrank": 5,
      "image": "RyzeW.png",
      "key": "W"
    },
    {
      "name": "法术涌动",
      "description": "瑞兹放出一颗纯净魔法能量球，对一名敌人造成伤害并对附近的敌人造成减益效果。瑞兹的技能可以对带有该减益的敌人造成额外效果。",
      "tooltip": "瑞兹发射一颗法球，造成{{ edamagecalc }}魔法伤害并施加持续{{ debuffduration }}秒的涌动给目标和附近的敌人们。已被涌动影响的敌人们将使其进一步扩散。",
      "cooldown": "3.5/3.25/3/2.75/2.5",
      "cost": "35/45/55/65/75",
      "costType": " {{ abilityresourcename }}",
      "range": "615",
      "maxrank": 5,
      "image": "RyzeE.png",
      "key": "E"
    },
    {
      "name": "曲境折跃",
      "description": "被动部分：【超负荷】对带有【涌动】效果的目标造成更多伤害。施放时，瑞兹会创造一个传送门来通向一个附近的位置。在若干秒后，站在传送门附近的友军会被传送至目标位置。",
      "tooltip": "被动： 超负荷对带有涌动的目标的伤害加成提升至{{ overloaddamagebonus }}%。主动：瑞兹开启一个前往另一个位置的传送门。在{{ chargetimetooltip }}秒后，传送门附近的所有友军都会被传送到该位置。",
      "cooldown": "180/160/140",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "3000",
      "maxrank": 3,
      "image": "RyzeR.png",
      "key": "R"
    }
  ]
