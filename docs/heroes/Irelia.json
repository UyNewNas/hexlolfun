  "passive": {
    "name": "艾欧尼亚热诚",
    "description": "当艾瑞莉娅用技能命中敌人时，她会获得可叠加的攻击速度加成。这个效果在满层时还会为艾瑞莉娅提供攻击附伤。",
    "image": "Irelia_Passive.png"
  },
  "spells": [
    {
      "name": "利刃冲击",
      "description": "艾瑞莉娅向前突进以打击她的目标，并治疗自身。如果目标被标记或死于利刃冲击，那么它的冷却时间会刷新。",
      "tooltip": "艾瑞莉娅冲向一名敌人，造成{{ championdamage }}物理伤害并回复自身 {{ healamount }}生命值。如果敌人阵亡或者重心不稳，那么会刷新冷却时间。对小兵造成{{ miniondamage }}伤害。",
      "cooldown": "10/9/8/7/6",
      "cost": "15",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "IreliaQ.png",
      "key": "Q"
    },
    {
      "name": "距破之舞",
      "description": "艾瑞莉娅开始蓄力以进行一次打击，蓄力越久则打击造成的伤害越多。在蓄力期间她所受的物理伤害降低。",
      "tooltip": "开始蓄力：艾瑞莉娅进入防御姿态，至多持续{{ maxduration }}秒，变得无法行动但使所受的物理伤害降低{{ finalphysicaldr }}%、所受的魔法伤害降低{{ finalmagicdr }}%。释放：艾瑞莉娅放出她的刀锋，造成{{ mindamagecalc }}物理伤害，基于蓄力时间至多提升至{{ maxdamagecalc }}。",
      "cooldown": "20/18/16/14/12",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 5,
      "image": "IreliaW.png",
      "key": "W"
    },
    {
      "name": "比翼双刃",
      "description": "艾瑞莉娅放出两柄相互聚拢的利刃。利刃之间被击中的敌人会受到伤害、晕眩效果并被标记。",
      "tooltip": "艾瑞莉娅扔出一把刀锋至地上，并且至多可在{{ buffduration }}秒里再次施放。再次施放：艾瑞莉娅扔出第二把刀锋，随后两把刀锋会朝着彼此飞行，对沿途的敌人造成{{ stunduration }}秒晕眩和{{ totaldamage }}魔法伤害。英雄和大型野怪会进入重心不稳状态，持续{{ markduration }}秒。",
      "cooldown": "16/14.5/13/11.5/10",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "IreliaE.png",
      "key": "E"
    },
    {
      "name": "先锋之刃",
      "description": "艾瑞莉娅发射庞大数量的利刃，它们会在命中一名敌方英雄时向外爆开。被利刃命中的敌人会受到伤害并被标记。然后利刃会形成一道刃墙，在敌人穿过时造成伤害、和减速效果。",
      "tooltip": "艾瑞莉娅发射出一阵刀锋弹幕，造成{{ missiledamage }}魔法伤害并对英雄和大型野怪施加持续{{ markduration }}秒的重心不稳。刀锋弹幕会在命中第一个英雄后绽放成一个持续{{ zoneduration }}秒的牢笼。牢笼造成{{ zonedamage }}魔法伤害和持续{{ ccduration }}秒的{{ slowamount }}%减速。",
      "cooldown": "125/105/85",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 3,
      "image": "IreliaR.png",
      "key": "R"
    }
  ]
}