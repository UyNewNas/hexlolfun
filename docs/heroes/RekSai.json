  "passive": {
    "name": "艾克塞之怒",
    "description": "雷克塞可通过攻击和命中基础技能来生成怒气。她在位于地下时可消耗怒气来回复生命值。",
    "image": "RekSai_Passive.png"
  },
  "spells": [
    {
      "name": "女王之怒 / 猎物搜寻",
      "description": "雷克塞的下3次普攻会对身边的敌人造成额外物理伤害。在地底时，雷克塞发射一道充满虚空能量的冲击波，对命中的敌人造成伤害并使其显形。",
      "tooltip": "位于地表：雷克塞在{{ buffduration }}秒内的下3次普攻会获得{{ attackspeed*100 }}%攻击速度并对附近的敌人造成额外的{{ totaldamagetooltip }}物理伤害。攻击会刷新这个技能的持续时长。",
      "cooldown": "4/3.5/3/2.5/2",
      "cost": "0",
      "costType": "无消耗",
      "range": "325",
      "maxrank": 5,
      "image": "RekSaiQ.png",
      "key": "Q"
    },
    {
      "name": "遁地 / 破土而出",
      "description": "雷克塞遁入地下，提供新的技能并提升移动速度。她的视野距离会被降低并且无法进行普攻。在地底时，雷克塞可以施放破土而出，击飞并伤害身边的敌人。",
      "tooltip": "位于地表：雷克塞遁入地下，获得全新的一套技能但不能攻击。她获得{{ burrowedmovespeed }}移动速度，视野距离被降低{{ visionradiusmod*-100 }}%，并且附近不可见的敌人在移动时会将其位置显形给雷克塞和她的友军。",
      "cooldown": "4",
      "cost": "0",
      "costType": "无消耗",
      "range": "1650",
      "maxrank": 5,
      "image": "RekSaiW.png",
      "key": "W"
    },
    {
      "name": "狂野之噬 / 挖掘隧道",
      "description": "雷克塞噬咬她的目标，造成物理伤害，或是在满怒时造成额外真实伤害。在地底时，雷克塞挖掘出一个可重复使用、长期存在的隧道。敌人踩在任一入口上即可摧毁整条隧道。",
      "tooltip": "位于地表：雷克塞撕咬一个目标，造成{{ spell.reksaie:basedamage }}物理伤害。在满额怒气时，这次撕咬会转而造成{{ spell.reksaie:empowereddamage }}真实伤害。",
      "cooldown": "6",
      "cost": "0",
      "costType": "无消耗",
      "range": "250",
      "maxrank": 5,
      "image": "RekSaiE.png",
      "key": "E"
    },
    {
      "name": "虚空猛冲",
      "description": "雷克塞对目标造成伤害即可将其标记。她可以激活这个技能，暂时变成不可被选取状态，并扑向一个被标记的目标，并基于其最大生命值造成大量伤害。",
      "tooltip": "雷克塞将一个之前{{ preymarkduration }}秒内被她造成过伤害的敌人选为目标，随后遁入地下，进入不可选取状态。片刻之后，她会不可阻挡地跃向目标，造成{{ rbasedamagecalc }}加上{{ percenthealthdamage }}%最大生命值的物理伤害并重置遁地 / 破土而出的冷却时间。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "1500",
      "maxrank": 3,
      "image": "RekSaiR.png",
      "key": "R"
    }
  ]
}