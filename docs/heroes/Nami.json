  "passive": {
    "name": "踏浪之行",
    "description": "每当娜美的技能命中友方英雄时，他们都会暂时获得移动速度加成。",
    "image": "NamiPassive.png"
  },
  "spells": [
    {
      "name": "碧波之牢",
      "description": "朝着目标区域放出一个泡泡，对命中的所有敌人造成伤害和晕眩效果。",
      "tooltip": "娜美掷出一个泡泡，晕眩敌人{{ e2 }}秒并造成{{ totaldamagett }}魔法伤害。",
      "cooldown": "12/11/10/9/8",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "875",
      "maxrank": 5,
      "image": "NamiQ.png",
      "key": "Q"
    },
    {
      "name": "冲击之潮",
      "description": "释放一股在友方英雄和敌方英雄之间交替流动的水流，治疗友军并伤害敌军。",
      "tooltip": "娜美释放一股在友方英雄和敌方英雄之间交替弹跳的水流。每个目标只会被弹到一次，并且水流至多可弹{{ maxtargets }}个目标。为友方英雄回复{{ totalheal }}生命值并弹向附近的一名敌方英雄身上。对敌方英雄造成{{ totaldamage }}魔法伤害并弹向附近的一名友方英雄身上。每次弹跳会使伤害和治疗数额修正{{ bouncescaling }}。",
      "cooldown": "10",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "725",
      "maxrank": 5,
      "image": "NamiW.png",
      "key": "W"
    },
    {
      "name": "唤潮之佑",
      "description": "短时间里强化一个友军英雄。友军的普通攻击和技能会对其目标造成额外伤害和减速效果。",
      "tooltip": "娜美强化一位友方英雄的下{{ hitcount }}次普通攻击和技能，持续{{ buffduration }}秒，使其可以对目标造成持续{{ slowduration }}秒的{{ totalslow }}减速，并造成额外的{{ totaldamage }}魔法伤害。",
      "cooldown": "11",
      "cost": "55/60/65/70/75",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "NamiE.png",
      "key": "E"
    },
    {
      "name": "怒涛之啸",
      "description": "召唤一阵巨大的怒涛，击飞、减速并伤害沿途的所有敌人。被怒涛命中的友方英雄会获得【踏浪之行】的双倍加速效果。",
      "tooltip": "娜美召唤一阵怒涛，造成0.5秒击飞，{{ e4 }}%减速并造成{{ totaldamage }}魔法伤害。减速的持续时间会基于怒涛的行进距离而提升，至多持续{{ e5 }}秒。被怒涛命中的友方英雄会获得踏浪之行的双倍效果。",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "2550",
      "maxrank": 3,
      "image": "NamiR.png",
      "key": "R"
    }
  ]
