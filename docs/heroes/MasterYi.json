  "passive": {
    "name": "双重打击",
    "description": "易大师每攻击数次，就会同时对目标进行2次打击。",
    "image": "MasterYi_Passive1.png"
  },
  "spells": [
    {
      "name": "阿尔法突袭",
      "description": "易以肉眼难以发觉的速度穿梭于战场，对多个敌人造成物理伤害，同时处于不可被选取的状态下。阿尔法突袭可以暴击，并对野怪造成额外物理伤害。普通攻击可以减少阿尔法突袭的冷却时间。",
      "tooltip": "易变得【不可被选取】并对他目标附近的敌人发起快速打击，对命中的所有敌人造成{{ totaldamage }}物理伤害，至多命中{{ alphastrikebounces }}名敌人。如果没有其他目标，那么这个技能可以重复打击相同敌人，每次后续打击造成{{ subsequenthitmultiplier*100 }}%物理伤害({{ subesquentdamage }})，对单个目标的最大伤害值为{{ singletotaldamage }}物理伤害。",
      "cooldown": "20/19.5/19/18.5/18",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "AlphaStrike.png",
      "key": "Q"
    },
    {
      "name": "冥想",
      "description": "易通过集中念力来活化他的身体，从而回复生命值，并暂时减少所受的伤害。此外，易还会为双重打击充能，并暂停无极剑道和高原血统的持续时长。",
      "tooltip": "易开始引导，并在{{ healduration }}秒里持续回复共{{ totalheal }}生命值。这个治疗效果可基于易大师的已损失生命值而提升，最多可提升至{{ maxmissinghealthpercent*100 }}%。在引导时和随后的{{ drlinger }}秒里，他还会获得{{ initialdr }}伤害减免，这个效果会在最初的{{ initialextradrduration }}秒后降低至{{ damagereduction*100 }}%。",
      "cooldown": "10",
      "cost": "40",
      "costType": "法力 (+{{ percentmanacostpersecond*100 }}%最大法力值每秒)",
      "range": "20",
      "maxrank": 5,
      "image": "Meditate.png",
      "key": "W"
    },
    {
      "name": "无极剑道",
      "description": "提供额外真实伤害至普攻",
      "tooltip": "易的攻击造成额外的{{ totaldamage }}真实伤害，持续{{ duration }}秒。",
      "cooldown": "14",
      "cost": "0",
      "costType": "无消耗",
      "range": "20",
      "maxrank": 5,
      "image": "WujuStyle.png",
      "key": "E"
    },
    {
      "name": "高原血统",
      "description": "易以超乎想象的身法进行移动，短时间内提升移动速度和攻击速度，并免疫减速效果。该技能激活期间，易在参与击杀一名敌方英雄的同时，会延长该技能的持续时间。在击杀和助攻后，也会被动地减少易其它技能的冷却时间。",
      "tooltip": "被动：在参与击杀后，易大师的普通技能的剩余冷却时间会减少{{ rcooldownrefund*100 }}%。主动：获得{{ rmsbonus }}%移动速度，{{ rasbonus }}%攻击速度，并且免疫减速效果，持续{{ rduration }}秒。每次参与击杀后都会使此技能的持续时间延长{{ rkillassistextension }}秒。",
      "cooldown": "85",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1",
      "maxrank": 3,
      "image": "Highlander.png",
      "key": "R"
    }
  ]
}