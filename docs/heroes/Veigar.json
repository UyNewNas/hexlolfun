  "passive": {
    "name": "超凡邪力",
    "description": "维迦是最强大的恶魔，甚至能对符文之地之心发起攻击——并且他只会越来越强大！用技能攻击一名敌人、击杀单位或拆毁防御塔都会为维迦永久提升法术强度加成。",
    "image": "VeigarEntropy.png"
  },
  "spells": [
    {
      "name": "黑暗祭祀",
      "description": "维迦释放一束黑暗能量，对最先被命中的两个敌人造成魔法伤害。被这个能量束所击杀的单位，会永久地为维迦提供一些法术强度。",
      "tooltip": "维迦释放一束黑暗能量，对命中的头2个敌人造成{{ totaldamage }}魔法伤害。用此技能击杀一个单位，还会为维迦提供{{ spell.veigarpassive:dqkillstacks }}层超凡邪恶效果。大型小兵和大型野怪会提供{{ spell.veigarpassive:dqkillstackslarge }}层作为替代。",
      "cooldown": "6/5.5/5/4.5/4",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "VeigarBalefulStrike.png",
      "key": "Q"
    },
    {
      "name": "黑暗物质",
      "description": "维迦召唤一大团黑暗物质轰击目标区域，落地造成魔法伤害。【超凡邪力】的层数会缩短这个技能的冷却时间。",
      "tooltip": "维迦召唤黑暗物质将从天而降，造成{{ totaldamage }}魔法伤害。每{{ spell.veigarpassive:pstacksperdarkmattercdr }}层超凡邪力会使这个技能的冷却时间减少{{ spell.veigarpassive:darkmattercdrincrement*100 }}%。",
      "cooldown": "0",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "VeigarDarkMatter.png",
      "key": "W"
    },
    {
      "name": "扭曲空间",
      "description": "维迦扭曲空间的边缘，创造一个牢笼来使途径的敌人晕眩。",
      "tooltip": "维迦扭曲空间的边缘，创造一个牢笼来使途经的敌人晕眩{{ stunduration }}秒。牢笼持续3秒。",
      "cooldown": "20/18.5/17/15.5/14",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "725",
      "maxrank": 5,
      "image": "VeigarEventHorizon.png",
      "key": "E"
    },
    {
      "name": "能量爆裂",
      "description": "引爆目标敌方英雄，造成大量魔法伤害，并基于目标已损失生命值提升伤害。",
      "tooltip": "维迦用源力魔法引爆目标一名敌方英雄，造成{{ mindamage }}到{{ maxdamage }}魔法伤害，伤害提升幅度基于目标的已损失生命值。目标生命值在33%以下即可造成最大伤害。",
      "cooldown": "120/90/60",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 3,
      "image": "VeigarR.png",
      "key": "R"
    }
  ]
}