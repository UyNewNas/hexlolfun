  "passive": {
    "name": "拯救",
    "description": "索拉卡在朝着附近低血量的友方英雄移动时会提升移动速度。",
    "image": "Soraka_Passive.png"
  },
  "spells": [
    {
      "name": "流星坠落",
      "description": "一颗流星从天而降，落在目标地点，造成魔法伤害，并对区域中心的敌人造成减速效果。如果一名敌人被此技能命中，那么索拉卡就会回复生命值。",
      "tooltip": "索拉卡召唤下一颗星星，造成{{ totaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ movespeedslow*100 }}%减速效果。命中一个敌方英雄时会为索拉卡提供活力焕发，在{{ hotduration }}秒里持续回复共{{ totalhot }}生命值并提供在此期间持续衰减的{{ movespeedhaste*100 }}%移动速度。",
      "cooldown": "8/7/6/5/4",
      "cost": "45/50/55/60/65",
      "costType": " {{ abilityresourcename }}",
      "range": "810",
      "maxrank": 5,
      "image": "SorakaQ.png",
      "key": "Q"
    },
    {
      "name": "星之灌注",
      "description": "索拉卡牺牲自己的一部分生命值来治疗一个友方英雄。",
      "tooltip": "索拉卡给一名友方英雄回复{{ totalheal }}生命值。如果索拉卡带有活力焕发，那么生命值消耗会降低{{ percenthealthcostrefund*100 }}%，并且目标也会获得活力焕发，持续{{ spell.sorakaq:hotduration }}秒。",
      "cooldown": "6/5/4/3/2",
      "cost": "40/45/50/55/60",
      "costType": "%最大生命值，{{ cost }}法力",
      "range": "550",
      "maxrank": 5,
      "image": "SorakaW.png",
      "key": "W"
    },
    {
      "name": "星体结界",
      "description": "在目标区域创造一个结界，沉默结界中的所有敌人。当结界消散时，仍在结界内的敌人会被禁锢。",
      "tooltip": "索拉卡创造一个星之领域，对英雄造成{{ totaldamage }}魔法伤害。领域会存留{{ rootdelay }}秒，沉默其中的敌人们。当领域消失后，领域中的英雄们会被禁锢{{ rootduration }}秒并受到{{ totaldamage }}魔法伤害。",
      "cooldown": "20/19/18/17/16",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "SorakaE.png",
      "key": "E"
    },
    {
      "name": "祈愿",
      "description": "索拉卡让友军充满希望，立刻使她和所有友方英雄回复生命值。",
      "tooltip": "索拉卡召唤神圣的能量，来为所有友方英雄回复{{ healingcalc }}生命值，无论相距多远。对生命值低于40%的友方英雄的回复效果提升至{{ ampedhealing }}。",
      "cooldown": "150/135/120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "SorakaR.png",
      "key": "R"
    }
  ]
}