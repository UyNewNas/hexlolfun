  "passive": {
    "name": "灵魂吸取",
    "description": "莫甘娜从她的敌人身上吸取灵魂，在对英雄、大型小兵、中型野怪和大型野怪造成技能伤害时获得治疗效果。",
    "image": "FallenAngel_Empathize.png"
  },
  "spells": [
    {
      "name": "暗之禁锢",
      "description": "莫甘娜用黑暗魔法将一名敌人禁锢在原地，迫使其感受自己造成的痛苦并对其造成魔法伤害。",
      "tooltip": "莫甘娜掷出一团星火来禁锢命中的第一个敌人{{ rootduration }}秒，并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1250",
      "maxrank": 5,
      "image": "MorganaQ.png",
      "key": "Q"
    },
    {
      "name": "折磨之影",
      "description": "莫甘娜在一个区域施放一团诅咒之影，对胆敢站在她黑色环形之中的敌人造成伤害。敌人会持续受到魔法伤害，并且生命值越低受到伤害越高。",
      "tooltip": "莫甘娜点燃一个区域{{ wduration }}秒，每秒对区域内的敌人造成{{ totalmindamage }}魔法伤害，基于目标的已损失生命值，伤害可最多提升{{ totalmaxdamage }}。每当莫甘娜被灵魂吸取治疗时，这个技能的冷却时间就会减少{{ cdrefundpercent*100 }}%。",
      "cooldown": "12",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "MorganaW.png",
      "key": "W"
    },
    {
      "name": "黑暗之盾",
      "description": "莫甘娜为一名友方英雄涂上一层保护性的星火屏障，在被打破之前吸收魔法伤害和限制效果。",
      "tooltip": "莫甘娜为一名友方英雄提供{{ totalshieldstrength }}魔法护盾，持续{{ shieldduration }}秒。护盾会阻挡限制和定身效果，直至被打破为止。",
      "cooldown": "26/23.5/21/18.5/16",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "MorganaE.png",
      "key": "E"
    },
    {
      "name": "灵魂镣铐",
      "description": "莫甘娜全力释放她的星界能量，与此同时，她的羽翼会解除束缚并且会悬浮在地面上。她将黑暗痛苦组成的锁链抽击到附近的敌方英雄身上，获得移动速度。锁链会减速并造成初段伤害，并在一段延迟后，晕眩那些未能挣脱的敌方英雄。",
      "tooltip": "莫甘娜将她自己与附近的敌方英雄用锁链铐在一起，造成{{ totaldamage }}魔法伤害和{{ slowpercent }}%减速效果。在{{ chainduration }}秒后，仍未挣断锁链的敌人会受到{{ totaldamage }}魔法伤害并被晕眩{{ stunduration }}秒。在施放这个技能时，莫甘娜会获得{{ hastepercent }}%移动速度。",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "625",
      "maxrank": 3,
      "image": "MorganaR.png",
      "key": "R"
    }
  ]
}