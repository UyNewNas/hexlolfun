  "passive": {
    "name": "赐死剑气",
    "description": "每过一段时间，亚托克斯的下次普攻会造成额外魔法伤害，并治疗亚托克斯，治疗量基于目标的最大生命值。",
    "image": "Aatrox_Passive.png"
  },
  "spells": [
    {
      "name": "暗裔利刃",
      "description": "亚托克斯向下猛砸他的巨剑，并造成物理伤害。他可以挥击三次，每次都有一个不同的范围效果。",
      "tooltip": "亚托克斯猛砸他的巨剑，造成{{ qdamage }}物理伤害。如果敌人被边缘命中，还会被暂时击飞并转而受到{{ qedgedamage }}伤害。这个技能可以再次施放两段，每段都会改变形状并比上一段多造成25%伤害。",
      "cooldown": "14/12/10/8/6",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "AatroxQ.png",
      "key": "Q"
    },
    {
      "name": "恶火束链",
      "description": "亚托克斯猛砸地面，对命中的第一个敌人造成伤害。英雄和大型野怪需要快速离开被影响的区域，否则就会被拖拽到中心并再次受到伤害。",
      "tooltip": "亚托克斯发射一道锁链，对命中的第一个敌人造成持续 {{ wslowduration }}秒的{{ wslowpercentage*-100 }}%减速和{{ wdamage }}物理伤害。英雄和大型野怪需要在{{ wslowduration }}秒内离开被影响的区域，否则就会被拖拽回中心并再次受到等额伤害。",
      "cooldown": "20/18/16/14/12",
      "cost": "0",
      "costType": "无消耗",
      "range": "825",
      "maxrank": 5,
      "image": "AatroxW.png",
      "key": "W"
    },
    {
      "name": "暗影冲决",
      "description": "被动效果：亚托克斯会在对敌方英雄造成伤害时治疗自身。主动效果：他会朝一个方向突进。",
      "tooltip": "被动：亚托克斯获得治疗效果，相当于他对英雄造成的{{ totalevamp }}伤害。主动：亚托克斯突进。他可以在其它技能的前摇阶段使用这个技能。",
      "cooldown": "9/8/7/6/5",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "AatroxE.png",
      "key": "E"
    },
    {
      "name": "大灭",
      "description": "亚托克斯现出他的恶魔形态，恐惧附近的敌方小兵，并获得攻击力、治疗效果提升、以及移动速度。如果他参与了一次击杀，这个效果就会延长。",
      "tooltip": "亚托克斯显现他真正的恶魔形态，恐惧附近的小兵{{ rminionfearduration }}秒并获得在 {{ rduration }}秒里持续衰减的{{ rmovementspeedbonus*100 }}%移动速度。在此期间，他还会获得{{ rtotaladamp*100 }}%攻击力并提升{{ rhealingamp*100 }}%自我治疗效果。参与击杀英雄后会使这个效果的持续时间延长{{ rextension }}秒并刷新移动速度效果。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 3,
      "image": "AatroxR.png",
      "key": "R"
    }
  ]
