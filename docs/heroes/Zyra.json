  "passive": {
    "name": "荆棘花园",
    "description": "种子会周期性地在婕拉身边生成，生成速度随等级提升。婕拉可通过在种子附近施放致命棘刺或缠绕之根来让种子长成为婕拉而战的植物。",
    "image": "ZyraP.png"
  },
  "spells": [
    {
      "name": "致命棘刺",
      "description": "浓密的藤蔓在地面蔓延，并爆炸成棘刺，对范围内的敌人造成魔法伤害。如果在一颗种子附近施放，那么【Q致命棘刺】就会让种子长成一株荆棘喷射者，可对远处的敌人进行攻击。",
      "tooltip": "婕拉使稠密的藤蔓们扩散并爆炸成尖刺，造成{{ initialdamage }}魔法伤害。如果这个技能在一颗种子附近施放，那么这颗种子就会长成荆棘喷射者，造成{{ spell.zyrap:plantdamage }}魔法伤害并持续{{ spell.zyrap:plantduration }}秒。荆棘喷射者拥有575攻击距离。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "ZyraQ.png",
      "key": "Q"
    },
    {
      "name": "狂野生长",
      "description": "婕拉播下一颗种子，最多持续60秒。在种子附近施放【Q致命棘刺】或【E缠绕之根】会让种子长成植物，与婕拉并肩作战。婕拉可以同时存有多个种子，并且击杀敌人会减少【W狂野生长】的充能时间。",
      "tooltip": "婕拉种下一颗持续{{ e6 }}秒的种子。这些种子在被敌方英雄踩到后会提供该英雄的真实视野，持续{{ e3 }}秒，但仍然会被摧毁。这个技能有2层充能，充能时间为{{ ammorechargetime }}秒。击杀一个敌方小兵或野怪会使充能时间缩短{{ e1 }}%。参与击杀英雄会转而使充能时间缩短{{ e2 }}%。",
      "cooldown": "0",
      "cost": "0",
      "costType": "1颗种子",
      "range": "850",
      "maxrank": 5,
      "image": "ZyraW.png",
      "key": "W"
    },
    {
      "name": "缠绕之根",
      "description": "婕拉朝前方放出贯穿地面的藤蔓来诱捕她的目标，藤蔓经过的敌人会受到伤害和束缚效果。如果在一颗种子附近施放，那么【E缠绕之根】就会让种子长成一株藤蔓鞭击者，可进行短程攻击并降低敌人的移动速度。",
      "tooltip": "婕拉向前方放出藤蔓，禁锢{{ e5 }}秒并造成{{ totaldamage }}魔法伤害。如果这个技能在一颗种子附近经过，那么这颗种子就会长成藤蔓鞭击者，造成{{ spell.zyrap:plantdamage }}魔法伤害并持续{{ spell.zyrap:plantduration }}秒。藤蔓鞭击者拥有400攻击距离，并且它们的攻击会施加持续{{ e3 }}秒的{{ e2 }}%减速。来自多个藤蔓鞭击者的减速可以至多叠加{{ maxslowstacks }}次。",
      "cooldown": "11",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "ZyraE.png",
      "key": "E"
    },
    {
      "name": "绞杀之藤",
      "description": "婕拉在目标区域召唤一个扭曲的密林，在蔓延时对区域内的所有敌人造成伤害，并在收缩时击飞区域内的所有敌人。密林内的植物会被进入激怒状态。",
      "tooltip": "婕拉召唤自然之怒，长出一个扭曲的密林，造成{{ totaldamage }}魔法伤害。在2秒后，藤蔓会向上方抽击，使敌人击飞{{ e1 }}秒。婕拉在密林中的植物们会被激怒，重置持续时间，获得{{ e2 }}%生命值并且攻击会造成{{ plantdamagebonus }}%额外伤害。",
      "cooldown": "110/100/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 3,
      "image": "ZyraR.png",
      "key": "R"
    }
  ]
}