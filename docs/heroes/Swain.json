  "passive": {
    "name": "狂食鸦群",
    "description": "斯维因的鸦群会收集魂屑来治疗斯维因并永久提升他的最大生命值。",
    "image": "Swain_P.png"
  },
  "spells": [
    {
      "name": "解脱之触",
      "description": "斯维因释放多道恶魔之力，这种力量可以穿透命中的目标。被一道以上的恶魔之力所命中的敌人，会受到基于恶魔之力数量的更多伤害。",
      "tooltip": "斯维因释放5道恶魔之力，造成{{ initialdamage }}魔法伤害，第一道之后的每道恶魔之力造成{{ extraboltdamage }}魔法伤害(最大伤害为{{ maxdamage }}魔法伤害)。",
      "cooldown": "7/6/5/4/3",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "SwainQ.png",
      "key": "Q"
    },
    {
      "name": "帝国视界",
      "description": "斯维因睁开恶魔之眼来对敌人造成伤害和减速效果。在命中敌方英雄时会使该英雄显形，并为斯维因提供一片魂屑。",
      "tooltip": "斯维因睁开一只恶魔之眼，来使一个位置显形1.5秒，然后造成{{ totaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ slow*-100 }}%减速。被命中的英雄会为斯维因提供一片魂屑并显形{{ revealduration }}秒。",
      "cooldown": "22/21/20/19/18",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "5500/6000/6500/7000/7500",
      "maxrank": 5,
      "image": "SwainW.png",
      "key": "W"
    },
    {
      "name": "永不复行",
      "description": "斯维因释放一道恶魔之手向前击出。手臂随后会返回至斯维因处，并禁锢它命中的敌人。斯维因之后可以选择将所有被禁锢的英雄们拉拽得更靠近他。这个技能在【恶魔升华】期间会有一个更短的冷却时间。",
      "tooltip": "斯维因发射一道会折返的恶魔能量波，在命中的第一个敌人身上引爆，对一个区域内的敌人造成{{ secondarydamage }}魔法伤害和{{ rootduration }}秒禁锢。用这个技能禁锢一名英雄后，可使斯维因再次施放这个技能来拉拽所有被永不复行禁锢的英雄们，并且每个被他拉拽的英雄将为他提供一个魂屑。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "SwainE.png",
      "key": "E"
    },
    {
      "name": "恶魔升华",
      "description": "斯维因变身为恶魔并从附近的敌方英雄、小兵和中立野怪身上汲取生命值。斯维因能施放【恶魔耀光】来用一道魂焰新星残害并减速附近的敌人们。这个形态可以在斯维因汲取敌方英雄时无限持续。",
      "tooltip": "斯维因使体内的恶魔解脱，每秒造成{{ damagecalc }}魔法伤害并从附近的敌人们身上汲取{{ healingcalc }}生命值。他的恶魔能量会持续消耗，但可通过汲取敌方英雄来无限期地充能并且会在参与击杀英雄后完全回复。在{{ demonflarecastdelay }}秒后以及之后的每{{ demonflarecooldowntooltip }}秒，斯维因能够在变身状态下施放恶魔耀光来对敌人们造成{{ demonflaredamagetotal }}魔法伤害和在{{ demonflareslowduration }}秒里持续衰减的{{ demonflareslowamount*100 }}%减速。",
      "cooldown": "120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 3,
      "image": "SwainR.png",
      "key": "R"
    }
  ]
