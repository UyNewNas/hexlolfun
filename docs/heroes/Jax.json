  "passive": {
    "name": "无情连打",
    "description": "贾克斯连续的普通攻击，会持续地提高他的攻击速度。",
    "image": "Armsmaster_MasterOfArms.png"
  },
  "spells": [
    {
      "name": "跳斩",
      "description": "贾克斯跳向一个单位。如果目标是敌人，贾克斯会用他的武器狠狠地抽打敌人的脸，造成额外伤害。",
      "tooltip": "贾克斯跳向一个友方或敌方单位或守卫，如果目标是敌人则会造成{{ totaldamage }}物理伤害。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "JaxQ.png",
      "key": "Q"
    },
    {
      "name": "蓄力一击",
      "description": "贾克斯为武器充能，使他的下次攻击能造成额外伤害。",
      "tooltip": "贾克斯给他的武器充能，使他的下次攻击或跳斩造成额外的{{ totaldamage }}魔法伤害。",
      "cooldown": "7/6/5/4/3",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "JaxW.png",
      "key": "W"
    },
    {
      "name": "反击风暴",
      "description": "贾克斯的武艺让他能够在短时间里躲闪掉所有即将到来的普通攻击，随后对所有周围的敌人快速发起反击，并将他们击晕。",
      "tooltip": "贾克斯进入一个最多持续{{ dodgeduration }}秒的防御姿态，能够躲闪掉一切即将到来的攻击，并且减少{{ aoedamagereduction }}%来自群体技能的伤害。在{{ dodgeduration }}秒后，或再次施放后，贾克斯会造成{{ totaldamage }} + {{ percenthealthdamage }}%最大生命值的魔法伤害并使附近的敌人晕眩{{ stunduration }}秒。贾克斯每躲掉一次攻击，这个伤害值就会提升{{ percentincreasedperdodge*100 }}%，最多可提升至最大值{{ maxdamage }} + {{ maxpercenthealthdamage }}%最大生命值。",
      "cooldown": "17/15/13/11/9",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "JaxE.png",
      "key": "E"
    },
    {
      "name": "武器大师",
      "description": "每连续攻击2次，第3次攻击就会造成额外的魔法伤害。另外，贾克斯可以激活这个技能来在他周围造成伤害并增强他的决心，从而暂时性地提升他的护甲和魔法抗性。",
      "tooltip": "被动：{{ passivefallofftime }}秒内的每第三次攻击造成额外的{{ onhitdamage }}魔法伤害。主动：贾克斯将他的灯柱砸落，对附近的敌人们造成{{ swingdamagetotal }}魔法伤害。如果他命中了一名英雄，那么他会获得{{ basearmor }}护甲和{{ basemr }}魔法抗性，并且每额外命中一个英雄就会获得额外的{{ bonusarmor }}护甲和{{ bonusmr }}魔法抗性，持续{{ duration }}秒。在此期间，他每第二次攻击（而非每第三次攻击）造成额外的魔法伤害。",
      "cooldown": "110/100/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "260",
      "maxrank": 3,
      "image": "JaxR.png",
      "key": "R"
    }
  ]
}