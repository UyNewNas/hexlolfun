  "passive": {
    "name": "登神长阶",
    "description": "凯尔的攻击会随着她提升等级和分配技能点而获得增强。她的羽翼将燃起圣焰，逐步提供攻击速度，移动速度，攻击距离，以及攻击附带焰浪。",
    "image": "Kayle_P.png"
  },
  "spells": [
    {
      "name": "耀焰冲击",
      "description": "凯尔召出一个传送门，召唤出一把星界之剑来刺穿敌人，对命中的所有敌人造成减速、伤害和防御属性击碎效果。",
      "tooltip": "凯尔发射一把星界之剑，它会停留在命中的第一个敌人身上，造成{{ totaldamage }}魔法伤害，持续{{ slowduration }}秒的{{ slowpercent }}%减速，并移除目标及其后方敌人们的{{ shredpercent }}%护甲和魔法抗性，持续{{ shredduration }}秒。",
      "cooldown": "12/11/10/9/8",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "KayleQ.png",
      "key": "Q"
    },
    {
      "name": "星界恩典",
      "description": "通过神圣的赐福，凯尔为自己和距她最近的友方英雄提供治疗和移动速度。",
      "tooltip": "凯尔为她自身和一名友方英雄灌注圣光，回复{{ totalheal }}生命值并提供持续{{ hasteduration }}秒的{{ totalhaste }}移动速度。",
      "cooldown": "15",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "KayleW.png",
      "key": "W"
    },
    {
      "name": "星火符刃",
      "description": "被动：凯尔的星界之剑，“美德”，会对她在攻击的敌人造成额外伤害。主动：凯尔的下次攻击将用星火重击她的目标，基于敌人的已损失生命值造成额外伤害。",
      "tooltip": "被动：攻击造成额外的{{ epassivetotaldamage }}魔法伤害。主动：凯尔的下次攻击变为远程并造成额外的{{ activetotalexecutedamage }}已损失生命值的魔法伤害。这个攻击会在凯尔到达{{ spell.kaylepassive:levelforpassiverank2 }}级时升级，使它可以在命中目标时爆炸，对附近敌人造成伤害。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "0",
      "costType": "无消耗",
      "range": "550",
      "maxrank": 5,
      "image": "KayleE.png",
      "key": "E"
    },
    {
      "name": "圣裁之刻",
      "description": "凯尔让一名友方英雄免疫伤害，并号召曾经的正义星灵们用一阵神圣剑雨来纯化她目标附近的区域。",
      "tooltip": "凯尔令一名友方英雄免疫伤害{{ invulnduration }}秒，随后会净化该英雄身边的区域并造成{{ totaldamage }}魔法伤害给附近的敌人们。",
      "cooldown": "160/120/80",
      "cost": "100/50/0",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 3,
      "image": "KayleR.png",
      "key": "R"
    }
  ]
