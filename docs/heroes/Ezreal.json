  "passive": {
    "name": "咒能高涨",
    "description": "伊泽瑞尔的任何技能在击中目标后，都会提升他的攻击速度（最多可叠加5次）。",
    "image": "Ezreal_RisingSpellForce.png"
  },
  "spells": [
    {
      "name": "秘术射击",
      "description": "伊泽瑞尔发射一枚能量弹，如果它击中一个敌方单位，那么它将略微减少伊泽瑞尔所有技能的冷却时间。",
      "tooltip": "伊泽瑞尔发射一支能量箭，对命中的第一个敌人造成{{ damage }}物理伤害并使他各个技能的冷却时间缩短{{ cdrefund }}秒。",
      "cooldown": "5.5/5.25/5/4.75/4.5",
      "cost": "28/31/34/37/40",
      "costType": " {{ abilityresourcename }}",
      "range": "1150",
      "maxrank": 5,
      "image": "EzrealQ.png",
      "key": "Q"
    },
    {
      "name": "精华跃动",
      "description": "伊泽瑞尔发射一个法球，法球会附着在命中的第一个敌方英雄或战略点上。如果伊泽瑞尔用技能或攻击命中一个法球时，会将它引爆来造成伤害。",
      "tooltip": "伊泽瑞尔发射一团魔法球体，魔法球体会附着在命中的第一个敌方英雄、建筑物或史诗级野怪上，持续{{ detonationtimeout }}秒。如果伊泽瑞尔用技能或攻击命中该目标，就会将球体引爆，造成{{ damage }}魔法伤害。用技能引爆时会返还该技能的法力消耗外加{{ manareturn }}法力。",
      "cooldown": "8",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "1150",
      "maxrank": 5,
      "image": "EzrealW.png",
      "key": "W"
    },
    {
      "name": "奥术跃迁",
      "description": "伊泽瑞尔传送到附近的目标区域，并向最近的敌人发射一束自动寻敌的魔法箭。优先选择被【精华跃动】击中的敌人。",
      "tooltip": "伊泽瑞尔传送然后向最近的敌人发射一支魔法箭，造成{{ damage }}魔法伤害。魔法箭会优先选择受精华跃动影响的目标。",
      "cooldown": "26/23/20/17/14",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "475",
      "maxrank": 5,
      "image": "EzrealE.png",
      "key": "E"
    },
    {
      "name": "精准弹幕",
      "description": "伊泽瑞尔蓄力然后向目标区域释放长程能量波，对穿过的敌人造成高额伤害（对小兵和非史诗级野怪的伤害会减少）。",
      "tooltip": "伊泽瑞尔发射一道大型能量圆弧，造成{{ damage }}魔法伤害。对小兵和非史诗级野怪降低至{{ damageminionmonster }}魔法伤害。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "EzrealR.png",
      "key": "R"
    }
  ]
