  "passive": {
    "name": "法力屏障",
    "description": "布里茨在血量过低时会获得一层基于它法力值的护盾。",
    "image": "Blitzcrank_ManaBarrier.png"
  },
  "spells": [
    {
      "name": "机械飞爪",
      "description": "布里茨发射它的右手，来抓取碰到的第一个敌人，在对敌人造成伤害的同时，还会将这名敌人拉到它的面前。",
      "tooltip": "布里茨射出它的右拳，将命中的第一个敌人拉拽向它并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "20/19/18/17/16",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1079",
      "maxrank": 5,
      "image": "RocketGrab.png",
      "key": "Q"
    },
    {
      "name": "过载运转",
      "description": "布里茨对自己进行了超级充电，它的攻击速度和移动速度得到了显著提升。它会在效果结束后暂时减速。",
      "tooltip": "布里茨进行超级充能，获得持续衰减的{{ movespeedmod*100 }}%移动速度和{{ attackspeedmod*100 }}%攻击速度，持续{{ duration }}秒。持续期间过后，布里茨会减速{{ movespeedmodreduction*100 }}%，持续{{ slowduration }}秒。",
      "cooldown": "15",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "1",
      "maxrank": 5,
      "image": "Overdrive.png",
      "key": "W"
    },
    {
      "name": "能量铁拳",
      "description": "布里茨为机械手臂充能，下次攻击造成双倍伤害并击飞目标。",
      "tooltip": "布里茨给它的拳头充能，使它的下次攻击可以击飞{{ ccduration }}秒并造成{{ totaldamage }}物理伤害。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "25",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "PowerFist.png",
      "key": "E"
    },
    {
      "name": "静电力场",
      "description": "被布里茨攻击过的敌人会被标记并在1秒后受到闪电伤害。此外，布里茨可以主动激活这个技能来移除附近敌人们的护盾、对他们造成伤害并暂时沉默他们。",
      "tooltip": "被动：在这个技能可以使用时，闪电会充盈着布里茨的双拳，标记它攻击的敌人。在1秒后，被标记的敌人会被震击，受到{{ passivedamage }}魔法伤害。主动：布里茨进行过度充能，对附近的敌人造成{{ activedamage }}魔法伤害和{{ silenceduration }}秒沉默效果。敌人的护盾也会被摧毁。",
      "cooldown": "60/40/20",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "StaticField.png",
      "key": "R"
    }
  ]
