  "passive": {
    "name": "暗夜猎手",
    "description": "薇恩毫不留情的猎杀世间邪恶，向附近敌方英雄移动时会获得移动速度。",
    "image": "Vayne_NightHunter.png"
  },
  "spells": [
    {
      "name": "闪避突袭",
      "description": "薇恩进行翻滚，并小心地填充她的下一发射击。她的下次攻击造成额外伤害。",
      "tooltip": "薇恩翻滚一小段距离，并且她的下次普通攻击造成额外的{{ adratiobonus }}物理伤害。这个技能会在造成伤害时触发技能特效。",
      "cooldown": "6/5/4/3/2",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "VayneTumble.png",
      "key": "Q"
    },
    {
      "name": "圣银弩箭",
      "description": "薇恩用稀有金属制作弩箭，让邪恶敌人中毒。对同一目标的第3次攻击或技能施放会对其造成额外真实伤害，数值相当于目标最大生命值的一定百分比。",
      "tooltip": "被动：对一名敌人的每第三次连续的攻击或技能造成额外的{{ totaldamage }}最大生命值的真实伤害。",
      "cooldown": "0",
      "cost": "0",
      "costType": "被动",
      "range": "750",
      "maxrank": 5,
      "image": "VayneSilveredBolts.png",
      "key": "W"
    },
    {
      "name": "恶魔审判",
      "description": "薇恩从背部展开一张重弩，并且朝她的目标发射一根巨型弩箭，将目标击退并造成伤害。如果目标与地形产生碰撞，那么目标会被贯穿，对其造成额外伤害和晕眩效果。",
      "tooltip": "薇恩发射一根弩箭来击退一个目标并造成{{ totaldamage }}物理伤害。如果目标与地形产生碰撞，那么会受到{{ empowereddamagett }}额外物理伤害，并且会被晕眩{{ stunduration }}秒。",
      "cooldown": "20/18/16/14/12",
      "cost": "90",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "VayneCondemn.png",
      "key": "E"
    },
    {
      "name": "终极时刻",
      "description": "薇恩准备进行史诗般的对决，她的攻击力得到提高，能在闪避突袭期间进入隐形状态，闪避突袭的冷却时间缩短，并且暗夜猎手（被动）提供更多移动速度。",
      "tooltip": "薇恩获得{{ bonusattackdamage }}攻击力，持续{{ baseduration }}秒，并且如果一个被薇恩所伤害的敌方英雄在{{ damagedmarkerduration }}秒内死亡，那么持续时间会延长{{ durationtoadd }}秒。此外，在这段持续时间里：暗夜猎手会转而提供{{ movementspeed }}移动速度。闪避突袭的冷却时间缩短{{ tumblecdreduction }}%，并提供持续{{ tumblestealthduration }}秒的隐形。",
      "cooldown": "100/85/70",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "1",
      "maxrank": 3,
      "image": "VayneInquisition.png",
      "key": "R"
    }
  ]
}