  "passive": {
    "name": "浪客之道",
    "description": "亚索的暴击几率提升。此外，亚索在移动时会为一层护盾攒能。护盾会在他受到来自英雄或野怪的伤害时触发。",
    "image": "Yasuo_Passive.png"
  },
  "spells": [
    {
      "name": "斩钢闪",
      "description": "向前出剑，呈直线造成伤害。在命中时，斩钢闪会获得一层旋风烈斩效果，持续数秒。在积攒2层旋风烈斩效果后，斩钢闪会形成一阵能够击飞敌人的旋风。斩钢闪被视为普通攻击，并且可以从所有作用于普攻的东西上获得收益。",
      "tooltip": "亚索进行戳刺，造成{{ totaldamage }}物理伤害。如果他命中了，那么他会获得一层持续{{ gatheringstormduration }}秒的层数。当他拥有2层时，这个技能的下次施放将会发射出一道远程龙卷风，造成等值伤害和{{ knockupdurationtooltiponly }}秒击飞。如果在冲刺期间施放，那么这个技能会呈环状进行打击而非直接戳刺。",
      "cooldown": "4",
      "cost": "0",
      "costType": "无消耗",
      "range": "475",
      "maxrank": 5,
      "image": "YasuoQ1Wrapper.png",
      "key": "Q"
    },
    {
      "name": "风之障壁",
      "description": "形成一个持续4秒的气流之墙，来阻挡敌方的飞行道具。",
      "tooltip": "亚索形成一个持续4秒的气流浮墙，来阻挡敌方的飞行道具。",
      "cooldown": "25/23/21/19/17",
      "cost": "0",
      "costType": "无消耗",
      "range": "400",
      "maxrank": 5,
      "image": "YasuoW.png",
      "key": "W"
    },
    {
      "name": "踏前斩",
      "description": "向目标敌人突进，造成魔法伤害。每次施法都会提升你的后续突进的伤害，直到抵达上限。在若干秒内无法对相同敌人重复施放。如果在突进的过程中施放斩钢闪，那么斩钢闪就会呈环状出剑。",
      "tooltip": "亚索冲刺并穿过一个目标，造成{{ totaldamage }}魔法伤害。这个技能每次施放后都会为{{ stackduration }}秒内的后续施放提供{{ bonusdamageperstack }}额外伤害，至多可叠加{{ maxstacks }}次。这个技能对每个目标有{{ e2 }}秒冷却时间。",
      "cooldown": "0.5/0.4/0.3/0.2/0.1",
      "cost": "0",
      "costType": "无消耗",
      "range": "475",
      "maxrank": 5,
      "image": "YasuoE.png",
      "key": "E"
    },
    {
      "name": "狂风绝息斩",
      "description": "闪烁到一个浮空的敌方英雄身边，造成物理伤害，并使范围内的所有浮空的敌人滞留在空中。获得满额的剑意值，但会重置旋风烈斩的层数。在接下来的若干秒里，亚索的暴击会获得显著的额外护甲穿透加成值。",
      "tooltip": "亚索传送到一名浮空的敌方英雄身边，造成{{ damage }}物理伤害并使所有附近浮空的敌人们维持此状态至多{{ rknockupduration }}秒。亚索还会获得满额剑意，但会失去所有所有斩钢闪层数。之后，亚索的暴击会无视{{ rpercentarmorpen }}%额外护甲，持续{{ rbuffduration }}秒。",
      "cooldown": "70/50/30",
      "cost": "0",
      "costType": "无消耗",
      "range": "1400",
      "maxrank": 3,
      "image": "YasuoR.png",
      "key": "R"
    }
  ]
}