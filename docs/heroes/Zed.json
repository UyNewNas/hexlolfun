  "passive": {
    "name": "影忍法！灭魂劫",
    "description": "劫的普通攻击会对低生命值的目标造成额外魔法伤害。这个特效在数秒内只能对相同的敌方英雄生效一次。",
    "image": "ZedP.png"
  },
  "spells": [
    {
      "name": "影奥义！诸刃",
      "description": "劫和他的影分身一起将他们的手里剑向前方掷出。每支手里剑都会对命中的每个敌人造成伤害。",
      "tooltip": "劫和他的影分身一起将他们的手里剑向前方掷出，每一枚手里剑都会对命中的第一个敌人造成{{ totaldamage }}物理伤害，并对之后的每个敌人造成{{ passthroughdamage }}物理伤害。",
      "cooldown": "6",
      "cost": "75/70/65/60/55",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "ZedQ.png",
      "key": "Q"
    },
    {
      "name": "影奥义！分身",
      "description": "被动：当劫和他的影分身用相同技能击中一名敌方英雄时，劫会回复能量。每次施放技能只会回复一次能量。主动：劫的影分身向前突进，并在一个地方维持若干秒。再次激活此技能会让劫与这个影分身互换位置。",
      "tooltip": "被动：当劫和他的影分身用相同技能击中一名敌方英雄时，劫会回复{{ e3 }}能量。主动：劫的影分身向前突进，并在一个地方维持{{ e5 }}秒。再次施放这个技能会让劫与这个影分身互换位置。",
      "cooldown": "20/19/18/17/16",
      "cost": "40/35/30/25/20",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "ZedW.png",
      "key": "W"
    },
    {
      "name": "影奥义！鬼斩",
      "description": "劫和他的影分身进行斩击，对附近的敌人造成伤害。被一个影分身的斩击命中的敌人们会被减速。",
      "tooltip": "劫和他的影分身进行斩击，对附近的敌人造成{{ totaldamage }}物理伤害。每个被劫的斩击所命中的敌方英雄都会使影奥义！分身的冷却时间减少{{ shadowhitcdr }}秒。被影分身的斩击所击中的敌人，将会被减速{{ movespeedmod*-100 }}%，持续{{ slowduration }}秒。被多个斩击同时击中的敌人，将会被减速{{ movespeedmodbonus*-100 }}%，但不会受到额外伤害。",
      "cooldown": "5/4.5/4/3.5/3",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "290",
      "maxrank": 5,
      "image": "ZedE.png",
      "key": "E"
    },
    {
      "name": "禁奥义！瞬狱影杀阵",
      "description": "劫变为不可被选取状态并突进至一名敌方英雄，同时为目标施加死亡印记。在3秒后，印记将会爆炸，同时造成额外伤害，劫在印记激活期间造成的伤害越多，则此额外伤害越高。如果该英雄死于此技能期间，那么劫可以获得该英雄的一部分攻击力。",
      "tooltip": "劫变得不可被选取，突进向一位敌方英雄，并将其标记。{{ rdeathmarkduration }}秒后，标记会触发，对目标造成{{ rcalculateddamage }}物理伤害，加上印记激活期间劫所造成的伤害总和的{{ rdamageamp*100 }}%。突进会留下一个影分身在身后，持续{{ rshadowdurationdisplayed }}秒。再次施放此技能会使劫与这个影分身互换位置。",
      "cooldown": "120/110/100",
      "cost": "0",
      "costType": "无消耗",
      "range": "625",
      "maxrank": 3,
      "image": "ZedR.png",
      "key": "R"
    }
  ]
