  "passive": {
    "name": "排山倒海",
    "description": "诺提勒斯对一名目标发起的第一次攻击会造成提升过的物理伤害并将其暂时禁锢。",
    "image": "Nautilus_StaggeringBlow.png"
  },
  "spells": [
    {
      "name": "疏通航道",
      "description": "诺提勒斯向前抛出他的船锚。在与敌人碰撞后，船锚会将目标与诺提勒斯拉到一起，并造成魔法伤害。与地形碰撞时会将诺提勒斯拉向它。",
      "tooltip": "诺提勒斯向前猛掷他的船锚。如果它命中了一个敌方单位，诺提勒斯就会将他自己和目标吸到一起，同时造成{{ qdamagecalc }}魔法伤害，并将目标暂时晕眩。如果它命中了地形，诺提勒斯则会把自己拉到船锚处。",
      "cooldown": "14/13/12/11/10",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1150",
      "maxrank": 5,
      "image": "NautilusAnchorDrag.png",
      "key": "Q"
    },
    {
      "name": "泰坦之怒",
      "description": "诺提勒斯获得一个临时护盾。当护盾存在时，他的攻击会对目标及目标周围的敌人造成持续伤害。",
      "tooltip": "诺提勒斯获得一层持续{{ shieldduration }}秒的{{ shieldcalc }}护盾。当护盾存在时，诺提勒斯的攻击会在2秒里对目标及目标周围的敌人持续造成共{{ dotdamagecalc }}额外魔法伤害。",
      "cooldown": "12",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "350",
      "maxrank": 5,
      "image": "NautilusPiercingGaze.png",
      "key": "W"
    },
    {
      "name": "暗流涌动",
      "description": "诺提勒斯在他身边生成3道爆炸波纹。每道爆炸波纹都会伤害并减速敌人。",
      "tooltip": "诺提勒斯在他身边生成3道爆炸波纹，每道爆炸波纹都会对范围内的敌人们造成{{ damagecalc }}魔法伤害并使他们减速{{ slowpercent*100 }}%，在{{ slowduration }}秒里持续衰减。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "NautilusSplashZone.png",
      "key": "E"
    },
    {
      "name": "深海冲击",
      "description": "诺提勒斯将一束冲击波打进土里，来追击敌方目标。这束冲击波会撕裂它上面的地表，将敌人震到半空中。当它命中目标时，冲击波会喷发，将他的目标震到半空中，并使目标晕眩。",
      "tooltip": "诺提勒斯发射一道冲击波来追击一名敌方英雄，造成{{ primarytargetdamage }}魔法伤害，击飞目标并将其晕眩{{ stunduration }}秒。冲击波还会击飞和晕眩沿途经过的其它敌人，并造成{{ secondarytargetdamage }}魔法伤害。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 3,
      "image": "NautilusGrandLine.png",
      "key": "R"
    }
  ]
