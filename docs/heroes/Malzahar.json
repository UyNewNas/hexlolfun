  "passive": {
    "name": "虚空穿越",
    "description": "玛尔扎哈如果近期没有受到伤害或控制效果，就会获得巨幅伤害减免和免疫控制的效果，并且这个效果在受到伤害后还会残留一小段时间。",
    "image": "Malzahar_Passive.png"
  },
  "spells": [
    {
      "name": "虚空召唤",
      "description": "玛尔扎哈开启两扇通向虚空的传送门。在短暂的延迟后，两扇门之间会有虚空能量对流而过，造成魔法伤害并沉默敌方英雄。",
      "tooltip": "玛尔扎哈开启两扇通往虚空的传送门，在短暂的延迟后，能量就会从虚空之中喷发，并且在两道传送门之间对流，对击中的敌人造成{{ totaldamagetooltip }}魔法伤害并使其沉默{{ silenceduration }}秒。",
      "cooldown": "6",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "MalzaharQ.png",
      "key": "Q"
    },
    {
      "name": "虚空虫群",
      "description": "玛尔扎哈召唤虚灵去攻击附近的敌人。",
      "tooltip": "被动：玛尔扎哈的其它技能在施放时会为他提供一层效果(最多可叠到{{ stackcap }}层)。主动：玛尔扎哈召唤一个虚灵，并且每层效果会额外召唤一个虚灵。虚灵持续{{ voidlingduration }}秒并且每次命中造成{{ voidlingbonusdamagetooltip }}魔法伤害。",
      "cooldown": "8",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "150",
      "maxrank": 5,
      "image": "MalzaharW.png",
      "key": "W"
    },
    {
      "name": "煞星幻象",
      "description": "玛尔扎哈将目标的惨死幻象侵入目标的意识中，造成持续伤害。玛尔扎哈对目标使用其它技能时会刷新幻象的持续时间。如果目标在感染幻象期间死亡，那么幻象会传到附近的一个敌人身上，并且玛尔扎哈会回复法力值。玛尔扎哈的虚灵会优先攻击感染了幻象的单位。",
      "tooltip": "玛尔扎哈给目标造成可怕的幻象，在{{ duration }}秒里对一名敌人持续造成共{{ totaldamage }}魔法伤害。在此期间，对目标使用虚空召唤或冥府之握会刷新幻象的持续时间。如果目标被击杀，玛尔扎哈会获得{{ manarestore }}法力并且幻象会传播给相距最近的敌人。煞星幻象会处决低于{{ minionexecutethreshold }}生命值的小兵。",
      "cooldown": "11/10/9/8/7",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "MalzaharE.png",
      "key": "E"
    },
    {
      "name": "冥府之握",
      "description": "玛尔扎哈引导虚空的精萃来把一名敌方英雄压制在一个充满伤害的负能量地带上。",
      "tooltip": "玛尔扎哈压制一名敌方英雄并在{{ ccduration }}秒里持续造成共{{ totaldamagetooltip }}魔法伤害。一个负能量地带会在他目标周围生成，在{{ poolduration }}秒里持续造成共{{ zonedamagetooltip }}最大生命值的魔法伤害。",
      "cooldown": "140/110/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 3,
      "image": "MalzaharR.png",
      "key": "R"
    }
  ]
}