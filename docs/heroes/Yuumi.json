  "passive": {
    "name": "猫的博爱",
    "description": "周期性地，当悠米用一个攻击或技能击中一个英雄时，她会为自身和她要附身的下一个友方英雄回复生命值。在附身于友方英雄时，悠米会与她的友方英雄们生成一个特殊羁绊。在附身于拥有最强羁绊的那名友方英雄时，悠米的各个技能会获得强化。",
    "image": "YuumiP2.png"
  },
  "spells": [
    {
      "name": "摸鱼飞弹",
      "description": "悠米发射一道飞弹，对命中的首个单位造成伤害和减速效果。如果它在到达目标之前至少飞行了1.35秒，那么还会造成额外伤害和强化减速效果。在附身于她的挚友身上时，将总造成强化减速效果并且为她的挚友提供额外附加伤害。在附身状态时，飞弹可以通过你的指针来控制。",
      "tooltip": "悠米召唤一个飘忽不定的飞弹，可对命中的首个敌人造成{{ totalmissiledamage }}魔法伤害和{{ slowamount }}%减速。如果在附身状态时施放，那么悠米可以通过使用她的鼠标来控制飞弹一小段时间，直到它提速进入一条直线轨迹为止。已提速的飞弹会转而对目标造成{{ totalmissiledamageempowered }}魔法伤害和持续{{ empoweredslowduration }}秒的{{ empoweredslowamount }}%减速。挚友加成：摸鱼飞弹将总是造成强化减速效果并在命中一名敌方英雄时还会为挚友提供持续{{ buffduration }}秒的附加%i:OnHit%{{ onhitdamagecalc }}魔法伤害。额外附加伤害可提升{{ allycritchancemaxamp*100 }}%，基于她正附身的友军的暴击几率。",
      "cooldown": "6.5",
      "cost": "50/55/60/65/70/75",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 6,
      "image": "YuumiQ.png",
      "key": "Q"
    },
    {
      "name": "悠米出动！",
      "description": "悠米突进到一名目标友方英雄处，变得不可被选取（防御塔除外）。在附身于她的挚友身上时，她会获得治疗与护盾强度并为她的这名友军提供附加治疗效果。",
      "tooltip": "被动：在附身于她的挚友身上时，悠米获得额外的{{ healandshieldpower*100 }}%治疗与护盾强度并且她的这名友军也会获得附加%i:OnHit%{{ healthonhit }}治疗效果。主动：悠米突进到一名目标友方英雄处，并附身到该友军身上。当悠米处于附身状态时，她会跟随她搭档的移动并且不可被选取（防御塔除外）。对悠米施加定身效果会使这个技能进入为期{{ ccattachlockout }}秒的冷却时间。",
      "cooldown": "0",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "YuumiW.png",
      "key": "W"
    },
    {
      "name": "旺盛精力",
      "description": "为悠米提供护盾值和一个爆发性的移动速度和攻击速度加成。如果她处于附身状态，那么她会将这个效果传给她附身的友方英雄。",
      "tooltip": "悠米为自身提供{{ totalshielding }}护盾值并获得持续{{ msduration }}秒的{{ totalattackspeed }}%攻击速度。在护盾存留时，目标还会获得{{ msamount }}%移动速度。如果悠米处于附身状态，这个技能会转而影响她附身的友方英雄并且还会为该英雄回复{{ manarestore }}法力值，基于目标的已损失法力值至多提升{{ maxmanapercincrease*100 }}%。",
      "cooldown": "10",
      "cost": "80/90/100/110/120",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 5,
      "image": "YuumiE.png",
      "key": "E"
    },
    {
      "name": "魔典终章",
      "description": "悠米引导5道波纹来伤害敌人并治疗友军。在引导时，悠米可以移动、附身并施放【旺盛精力】。在附身于她的挚友身上时，这个技能还会跟随她的鼠标。",
      "tooltip": "悠米引导{{ ultduration }}秒，发射{{ numberofwaves }}道影响双方的魔法波纹。如果在施放时处在附身状态，那么悠米可以操控这些波纹来跟随她的鼠标。波纹对命中的敌人们造成{{ totalmissiledamage }}魔法伤害和持续{{ ccduration }}秒的{{ baseslow*-100 }}%减速，每道命中的波纹都会使这个减速效果提升{{ bonusslowperwave*-100 }}%。每道波纹对命中的友方英雄们造成{{ totalhealperwave }}治疗效果。溢出的治疗效果会转化为护盾值。挚友加成：对她的挚友来说，治疗效果会提升至{{ enhancedhealperwave }}生命值。施放悠米出动！将把波纹锁定在当前方向。悠米可以在引导时移动和施放旺盛精力。",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 3,
      "image": "YuumiR.png",
      "key": "R"
    }
  ]
}