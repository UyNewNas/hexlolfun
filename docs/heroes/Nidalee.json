  "passive": {
    "name": "寻觅",
    "description": "在穿越草丛进行移动时，奈德丽的移动速度会提升10%，持续2秒，并在朝着1400码内的出现在己方视野内的敌方英雄进行移动时，移动速度加成会提升至30%。在【Q标枪投掷】或【W丛林伏击】对敌方英雄或野怪造成伤害后，奈德丽会开始捕猎目标英雄，提供其真实视野，持续4秒。在此期间，奈德丽获得10%移动速度加成（在她朝着被捕猎的目标移动时，这个加成会提升至30%）并且她的【Q推倒】和【W猛扑】会对这些目标造成强化伤害。",
    "image": "Nidalee_Passive.png"
  },
  "spells": [
    {
      "name": "标枪投掷 / 推倒",
      "description": "人类形态下，奈德丽向她的目标投掷标枪，飞行中击中目标造成伤害。美洲狮形态下，她的下一次攻击会试图对目标造成致命伤害，目标的生命值越低，造成的伤害越大。",
      "tooltip": "人类形态：奈德丽投掷她的标枪，造成{{ humanminimumdamage }}魔法伤害，基于标枪飞行距离至多提升至{{ humanmaximumdamage }}魔法伤害。",
      "cooldown": "6",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1500",
      "maxrank": 5,
      "image": "JavelinToss.png",
      "key": "Q"
    },
    {
      "name": "丛林伏击 / 猛扑",
      "description": "人类形态下， 奈德丽会对指定位置放置一个陷阱，踩中陷阱的单位的视野将会被暴露给奈德丽，并持续受到伤害。美洲狮形态下，她会猛扑向目标，落地时造成伤害。",
      "tooltip": "人类形态：奈德丽放置一个持续2分钟的隐形陷阱。当有一个敌人走到它上面时，该敌人会每秒受到{{ damagepersecond }}魔法伤害，持续{{ e3 }}秒。最多可以有{{ maxtraps }}个陷阱同时存在。",
      "cooldown": "13/12/11/10/9",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "Bushwhack.png",
      "key": "W"
    },
    {
      "name": "野性奔腾 / 挥击",
      "description": "人类形态下，奈德丽引导美洲狮的灵魂以治疗友方单位，并且短暂提升他们的攻击速度。美洲狮形态下，她迅速的挥爪攻击她面前的敌人。",
      "tooltip": "人类形态：奈德丽为目标回复{{ totalhealing }}生命值，这个数额基于已损失生命值至多提升至{{ maxhealing }}，并为目标提供持续{{ asduration }}秒的{{ bonusas*100 }}%攻击速度。",
      "cooldown": "12",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "PrimalSurge.png",
      "key": "E"
    },
    {
      "name": "美洲狮形态",
      "description": "奈德丽转变成美洲狮形态，获得全新技能。",
      "tooltip": "被动：在人类形态下，施加捕猎效果会刷新这个技能的冷却时间。人类形态：奈德丽变形为美洲狮形态，获得近战攻击并替换她的主动技能。美洲狮形态：奈德丽变形为人类形态，获得远程攻击并替换她的主动技能。",
      "cooldown": "3",
      "cost": "0",
      "costType": "无消耗",
      "range": "20",
      "maxrank": 4,
      "image": "AspectOfTheCougar.png",
      "key": "R"
    }
  ]
