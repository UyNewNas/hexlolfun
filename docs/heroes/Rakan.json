  "passive": {
    "name": "异色羽裳",
    "description": "洛会周期性地获得一层护盾。",
    "image": "Rakan_P.png"
  },
  "spells": [
    {
      "name": "微光飞翎",
      "description": "掷出一片神奇羽毛以造成魔法伤害。用在一名敌方英雄或史诗级野怪上时，会使洛有能力治疗他的友军。",
      "tooltip": "洛掷出一支魔羽，对命中的第一个敌人造成{{ totaldamage }}魔法伤害。如果魔羽命中了一个英雄或史诗级野怪，洛会在{{ healdelay }}秒后或触碰到一名友方英雄后，为自己和附近的友方回复{{ totalheal }}生命值。",
      "cooldown": "11/10/9/8/7",
      "cost": "45",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "RakanQ.png",
      "key": "Q"
    },
    {
      "name": "盛大登场",
      "description": "冲到一个位置，在到达时击飞附近的敌人。",
      "tooltip": "洛进行冲刺，然后旋至空中，击飞{{ knockupduration }}秒并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "RakanW.png",
      "key": "W"
    },
    {
      "name": "轻舞成双",
      "description": "飞向一名友方英雄，并提供给该英雄一层护盾。能在短时间内再次免费施放。",
      "tooltip": "洛冲向一名友方英雄，为其提供持续{{ duration }}秒的{{ totalshield }}护盾值。洛可以在{{ recastwindow }}秒内再次施放一次这个技能。",
      "cooldown": "0",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "RakanE.png",
      "key": "E"
    },
    {
      "name": "惊鸿过隙",
      "description": "获得移动速度，对触碰到的敌人造成魅惑和魔法伤害。",
      "tooltip": "洛获得持续{{ duration }}秒的{{ initialcastspeed }}%移动速度。洛触碰到敌人时会造成{{ totaldamagetooltip }}魔法伤害，并对被首次命中的敌人造成持续{{ charmduration }}秒的魅惑效果。被触碰的首个敌方英雄，会为洛提供持续衰减的{{ touchspeed }}%移动速度。",
      "cooldown": "130/110/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "150",
