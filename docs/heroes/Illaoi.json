  "passive": {
    "name": "古神先知",
    "description": "俄洛伊和她创造的躯壳会在附近的不可穿越的地形上生成触手。触手会挥向灵魂，躯壳，以及俄洛伊的【严酷训诫】的受害者们。触手会在命中敌人时造成物理伤害，如果命中目标是英雄还会治疗俄洛伊。",
    "image": "Illaoi_P.png"
  },
  "spells": [
    {
      "name": "触手猛击",
      "description": "提升触手造成的伤害。在激活时，俄洛伊会挥出一条触手来造成物理伤害。",
      "tooltip": "被动：猛击伤害提升{{ spell.illaoiq:tentacledamageamp*100 }}%(当前{{ spell.illaoiq:tentacledamagetotal }}物理伤害)。主动：俄洛伊挥舞她的神像，使一条触手向前猛击。",
      "cooldown": "10/9/8/7/6",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "IllaoiQ.png",
      "key": "Q"
    },
    {
      "name": "严酷训诫",
      "description": "俄洛伊跃向她的目标，造成物理伤害并使附近的触手也挥向目标。",
      "tooltip": "俄洛伊的下次攻击会使她跃向目标，造成额外的{{ healthpercenttotal }}最大生命值的物理伤害。当她进行打击时，附近的触手会对目标进行猛击。",
      "cooldown": "4",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "IllaoiW.png",
      "key": "W"
    },
    {
      "name": "灵魂试炼",
      "description": "俄洛伊把灵魂从一名敌人的肉身中扯出，强迫它站在她面前。 灵魂会将其所受的一部分伤害传递到本体上。如果灵魂被击杀，或者本体离灵魂过远，那么本体就会成为一个躯壳并且开始生成触手。",
      "tooltip": "俄洛伊从一名敌方英雄身上扯出灵魂，持续{{ spiritduration }}秒。灵魂能像英雄一样被攻击，并且所受的 {{ echopercent }}伤害会传递给本体。如果灵魂死亡或者离本体过远，那么目标会被标记{{ vesselduration }}秒，并被减速{{ slowamount*100 }}%，持续{{ slowduration }}秒。被标记的敌人会尽可能地生成触手。触手会每{{ timebetweenvesseltentacleslams }}秒自动猛击一次灵魂和被标记的敌人。",
      "cooldown": "16/15/14/13/12",
      "cost": "35/40/45/50/55",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "IllaoiE.png",
      "key": "E"
    },
    {
      "name": "过界信仰",
      "description": "俄洛伊将她的神像砸在地上，对附近的敌人造成物理伤害。每命中一个敌人就会生成一条触手。",
      "tooltip": "俄洛伊将她的神像砸入地面，对附近的敌人造成{{ damagecalc }}物理伤害并且每命中一个敌方英雄就会生成一条触手。在接下来的{{ duration }}秒里，触手无法被选取， 猛击变快50%，并且严酷训诫有一个{{ spell.illaoiw:cooldownduringr }}秒的冷却时间。",
      "cooldown": "120/95/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 3,
      "image": "IllaoiR.png",
      "key": "R"
    }
  ]
}