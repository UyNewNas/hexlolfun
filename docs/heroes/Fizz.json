  "passive": {
    "name": "伶俐斗士",
    "description": "菲兹在移动时可以穿过单位并且从所有来源处受到的伤害都会减少一个固定的数额。",
    "image": "Fizz_P.png"
  },
  "spells": [
    {
      "name": "淘气打击",
      "description": "菲兹穿过他的目标，造成魔法伤害，并施加攻击特效。",
      "tooltip": "菲兹冲刺并穿过一名敌人，同时造成{{ totaldamage }}物理伤害加上{{ qdamage }}魔法伤害。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "FizzQ.png",
      "key": "Q"
    },
    {
      "name": "海石三叉戟",
      "description": "菲兹的攻击会让他的敌人们流血，同时造成持续数秒的魔法伤害。菲兹可以强化他的下次普攻来造成额外伤害，并在短时间内强化他的后续普攻。",
      "tooltip": "被动：菲兹的攻击会使他的敌人们流血，在{{ bleedduration }}秒里持续造成共{{ dotdamage }}魔法伤害。主动：菲兹的下次攻击造成额外的{{ activedamage }}魔法伤害。如果这次攻击将目标击杀，那么菲兹会返还{{ onkillmanarefund }}法力并使这个技能的冷却时间缩短至{{ onkillnewcooldown }}秒。如果这次攻击未能造成击杀，那么菲兹的攻击会造成额外的{{ onhitbuffdamage }}魔法伤害，持续{{ onhitbuffduration }}秒。",
      "cooldown": "7/6/5/4/3",
      "cost": "30/40/50/60/70",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "FizzW.png",
      "key": "W"
    },
    {
      "name": "古灵/精怪",
      "description": "菲兹跳到空中，同时优雅地落在他的长矛上，变得不可被选取。在这个姿态下，菲兹可以选择立原地着陆，也可以选择在着陆之前再跳一段距离。",
      "tooltip": "菲兹跳到他的三叉戟上，变为【不可被选取】状态0.75秒，随后对附近敌人造成{{ edamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。菲兹可以在【不可被选取】状态中再次施放这个技能，以再次位移，并提前结束该状态，在一个较小的区域内造成伤害，并且不会造成减速。",
      "cooldown": "16/14/12/10/8",
      "cost": "75/80/85/90/95",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "FizzE.png",
      "key": "E"
    },
    {
      "name": "巨鲨强袭",
      "description": "菲兹朝一个方向放出一条小鱼，小鱼会附身在第一个与它接触的敌方英雄身上，同时减速目标。在短暂的延迟之后，一条巨鲨就会破土而出，击飞目标并将目标附近的敌人震开。被命中的所有敌人都会受到魔法伤害和减速效果。",
      "tooltip": "菲兹掷出一只小鱼来吸附到命中的第一个敌方英雄身上。这个英雄会被施加真实视野和减速，减速幅度为40%到80%，基于小鱼在吸附前的位移距离。在{{ detonationtime }}秒后，一头巨鲨会从目标脚下出现，击飞带着小鱼的目标1秒，击退其它单位，并基于小鱼在吸附前的位移距离造成{{ smallsharkdamage }}到{{ bigsharkdamage }}魔法伤害。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1300",
      "maxrank": 3,
      "image": "FizzR.png",
      "key": "R"
    }
  ]
