  "passive": {
    "name": "天生幻魅",
    "description": "妮蔻可以假扮成一名友方英雄或地图上的其它单位。承受定身类限制效果、施放伤害型的技能、以非英雄单位的状态对敌方防御塔造成伤害、或者你的假扮受到了相当于其生命条的伤害时，都会打破这个假扮状态。",
    "image": "Neeko_P.png"
  },
  "spells": [
    {
      "name": "盛开花种",
      "description": "妮蔻扔出一颗种子以造成伤害。种子在再次命中英雄或击杀单位时会盛开。",
      "tooltip": "妮蔻扔出一颗种子以造成{{ explosiondamage }}魔法伤害。如果种子击杀了一个单位或命中了一个英雄或大型野怪，那么它会再次盛开，造成{{ seconddamage }}魔法伤害。最多可额外盛开2次。",
      "cooldown": "9/8.5/8/7.5/7",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "NeekoQ.png",
      "key": "Q"
    },
    {
      "name": "两生花影",
      "description": "被动效果：妮蔻每第三次攻击造成额外魔法伤害，并短暂提升她的移动速度。主动效果：妮蔻能够朝一个方向投射出一个幻像并通过再次施放来改变幻象的方向。",
      "tooltip": "被动：每第三次攻击造成{{ passivebonusdamagecalc }}额外魔法伤害并使妮蔻获得持续{{ passivehasteduration }}秒的{{ passivehaste }}%移动速度提升。主动：妮蔻隐形{{ stealthduration }}秒并投射出一个持续{{ cloneduration }}秒的复制体。妮蔻和复制体会获得持续{{ hasteduration }}秒的{{ haste }}%移动速度 。可通过使用“移动宠物点击”热键或通过再次施放这个技能来控制复制体。复制体会镜像模仿她的技能施放、表情和回城。",
      "cooldown": "16/15/14/13/12",
      "cost": "0",
      "costType": "无消耗",
      "range": "900",
      "maxrank": 5,
      "image": "NeekoW.png",
      "key": "W"
    },
    {
      "name": "缠结倒刺",
      "description": "妮蔻投出一团倒刺，对它沿途的所有东西造成伤害和禁锢效果。如果倒刺击杀了一个敌人或穿过了一名英雄，就会变得更大、更快并且禁锢时间更长。",
      "tooltip": "妮蔻掷出一团倒刺，造成{{ basedamage }}魔法伤害和{{ minrootduration }}秒的禁锢效果。倒刺会在命中一名敌方英雄后强化，长得更大、动得更快、并且禁锢时长变为{{ maxrootduration }}秒。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "NeekoE.png",
      "key": "E"
    },
    {
      "name": "怒放",
      "description": "在短暂的准备阶段后，妮蔻会跃入空中，击飞所有附近的英雄。在着陆时，附近的敌人会受到伤害并被晕眩。如果妮蔻处于假扮状态时，那么准备阶段不会被敌人看见。",
      "tooltip": "在短暂延迟后，妮蔻会跃入空中，对所有附近的敌人造成{{ delayuntilexplosion }}秒击飞。然后她会猛然着陆，对附近的所有敌人造成{{ totaldamage }}魔法伤害和{{ stunduration }}秒晕眩效果。如果妮蔻处于假扮状态时，那么这个技能的准备阶段不会被敌人看见。妮蔻会在施放这个技能的{{ delaybeforepassiveremoval }}秒后打破她的假扮状态。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "NeekoR.png",
      "key": "R"
    }
  ]
}