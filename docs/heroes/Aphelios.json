  "passive": {
    "name": "传知者与真知者",
    "description": "厄斐琉斯拥有5件由他妹妹拉露恩所制的皎月武器。他同一时间可以使用2件：1件主手武器和1件副手武器。每件武器都有1种独特的普攻方式和1个独特的技能。攻击和技能都会消耗该武器的弹药。在弹药耗尽后，厄斐琉斯会弃掉该武器，并且拉露恩会召唤下一件武器给厄斐琉斯。",
    "image": "ApheliosP.png"
  },
  "spells": [
    {
      "name": "武器技能",
      "description": "厄斐琉斯拥有5个不同的主动技能，基于他的主手武器：通碧(步枪)：长距离射击，能够标记目标来跟进一次长距离攻击。断魄(短镰枪)：在快速奔跑的同时用两把武器攻击附近的敌人。坠明(加农炮)：禁锢被这把武器减速的所有敌人。荧焰(喷火器)：引爆锥形范围内的敌人并用你的副手武器攻击他们。折镜(飞轮刃)：部署一个装备着你副手武器的驻灵。",
      "tooltip": "",
      "cooldown": "9",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1450",
      "maxrank": 6,
      "image": "ApheliosQ_ClientTooltipWrapper.png",
      "key": "Q"
    },
    {
      "name": "月相轮转",
      "description": "厄斐琉斯将主手武器和副手武器互换，同时替换他的普攻方式和主动技能。",
      "tooltip": "切换主手武器与副手武器，装备坠明。",
      "cooldown": "0.8",
      "cost": "0",
      "costType": "无消耗",
      "range": "250",
      "maxrank": 6,
      "image": "ApheliosW.png",
      "key": "W"
    },
    {
      "name": "武器队列系统",
      "description": "厄斐琉斯没有E技能。这个技能栏位会显示拉露恩将为他提供的下一件武器。武器序列在开始时是固定的，但可以随着游戏时间来变更——在一件武器弹药耗尽后，就会进入序列的末端。",
      "tooltip": "",
      "cooldown": "0",
      "cost": "0",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 6,
      "image": "ApheliosE_ClientTooltipWrapper.png",
      "key": "E"
    },
    {
      "name": "清辉夜凝",
      "description": "发射一道凝结的月光来引爆敌方英雄。还会施加厄斐琉斯主手武器的独特效果。",
      "tooltip": "厄斐琉斯发射一道浓缩爆裂的月光，在命中一位敌方英雄时爆炸，以对周围的敌人们造成{{ maxdamage }}物理伤害。随后，厄斐琉斯会用他的主手武器攻击所有英雄。{{ Spell_ApheliosR_WeaponMod_{{ f1 }} }}",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1300",
      "maxrank": 3,
      "image": "ApheliosR.png",
      "key": "R"
    }
  ]
