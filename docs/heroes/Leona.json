  "passive": {
    "name": "日光",
    "description": "技能会在敌人身上施加【日光】效果，持续1.5秒。在此期间，蕾欧娜友军对这些目标造成伤害时，会触发【日光】，使目标受到额外的魔法伤害。",
    "image": "LeonaSunlight.png"
  },
  "spells": [
    {
      "name": "破晓之盾",
      "description": "蕾欧娜用盾进行下次普通攻击，造成额外魔法伤害并晕眩目标。",
      "tooltip": "蕾欧娜的下次攻击会晕眩目标{{ e1 }}秒，并造成额外的{{ totaldamagetooltip }}魔法伤害。",
      "cooldown": "5",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "100",
      "maxrank": 5,
      "image": "LeonaShieldOfDaybreak.png",
      "key": "Q"
    },
    {
      "name": "日蚀",
      "description": "蕾欧娜举起盾牌，提供伤害减免、护甲和魔法抗性。当持续时间首次结束时，如果附近有敌人，那么她会对其造成魔法伤害并延长效果的持续时间。",
      "tooltip": "蕾欧娜举起她的盾牌，使即将到来的伤害降低{{ flatdamagereduction }}并获得{{ bonusarmortooltip }}护甲和{{ bonusmrtooltip }}魔法抗性，持续{{ e3 }}秒。之后，她的盾牌会爆炸，对附近的敌人造成{{ totaldamagetooltip }}魔法伤害。如果她命中了至少一名敌人，那么她会将护甲和魔法抗性加成延续额外的{{ e3 }}秒。",
      "cooldown": "14/13/12/11/10",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 5,
      "image": "LeonaSolarBarrier.png",
      "key": "W"
    },
    {
      "name": "天顶之刃",
      "description": "蕾欧娜投掷一束日光，对直线上的所有敌人造成魔法伤害。当效果消失时，蕾欧娜会冲向最后一个被击中的敌人并使其无法移动。",
      "tooltip": "蕾欧娜用光明之剑进行猛刺，造成{{ totaldamagetooltip }}魔法伤害。最后一个被命中的敌方英雄将会被禁锢{{ e2 }}秒，并且蕾欧娜将会冲向该英雄。",
      "cooldown": "12/10.5/9/7.5/6",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "875",
      "maxrank": 5,
      "image": "LeonaZenithBlade.png",
      "key": "E"
    },
    {
      "name": "日炎耀斑",
      "description": "蕾欧娜召唤一道太阳光束，对区域内的敌人造成伤害。区域中心的敌人会被晕眩，并且外围的敌人会被减速。",
      "tooltip": "蕾欧娜召唤一道太阳光束，造成{{ explosioncalculateddamage }}魔法伤害并使敌人减速{{ slowpercent }}%，持续{{ ccduration }}秒。处于区域正中的敌人会受到晕眩效果而非减速效果。",
      "cooldown": "90/75/60",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 3,
      "image": "LeonaSolarFlare.png",
      "key": "R"
    }
  ]
