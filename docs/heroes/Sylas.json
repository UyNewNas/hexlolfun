  "passive": {
    "name": "破敌禁法",
    "description": "在施放一次技能后，塞拉斯会储存一层【破敌禁法】效果。塞拉斯的普攻将消耗一层效果并环绕自身挥舞他的盈能锁链来对命中的敌人造成额外魔法伤害。当塞拉斯拥有一层【破敌禁法】效果时，他会获得攻击速度。",
    "image": "SylasP.png"
  },
  "spells": [
    {
      "name": "锁链鞭击",
      "description": "塞拉斯甩出他的锁链，锁链会在目标区域交叉，并对敌人造成伤害和减速效果。在一段延迟后，魔法能量将从交叉点迸发，造成伤害。",
      "tooltip": "塞拉斯甩出他的锁链，造成{{ damage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamountcalc }}减速。锁链交叉的位置会被引爆，进一步造成{{ explosiondamage }}魔法伤害。",
      "cooldown": "10/9/8/7/6",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "775",
      "maxrank": 5,
      "image": "SylasQ.png",
      "key": "Q"
    },
    {
      "name": "弑君突刺",
      "description": "塞拉斯带着魔法之力跃向一名敌人，造成伤害，并且在对抗敌方英雄时治疗自身。",
      "tooltip": "塞拉斯带着魔法之力跃向一名敌人，造成{{ mindamage }}魔法伤害。如果对敌方英雄造成伤害，那么会基于塞拉斯的已损失生命值来治疗塞拉斯{{ minhealing }}到{{ maxhealing }}生命值(在{{ maxexecutethreshold*100 }}%生命值或以下时达到最大值)。",
      "cooldown": "12/10.5/9/7.5/6",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "SylasW.png",
      "key": "W"
    },
    {
      "name": "潜掠/强掳",
      "description": "塞拉斯突进至一个位置。塞拉斯可以再次施放来将他的锁链向一个方向挥出，将他自身拉向命中的第一个敌人。",
      "tooltip": "塞拉斯快速突进至一个位置，并准备好一次再次施放，持续3.5秒。再次施放：塞拉斯挥出他的锁链，将他自身拉向命中的第一个敌人并造成{{ damage }}魔法伤害和{{ knockupduration }}秒击飞。",
      "cooldown": "13/12/11/10/9",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "SylasE.png",
      "key": "E"
    },
    {
      "name": "其人之道",
      "description": "塞拉斯窃取一名敌人的终极技能，然后可以免费施放该技能。",
      "tooltip": "塞拉斯劫掠一位敌方英雄，以使他自身可以施放该敌人的终极技能，基于他自身的终极技能等级并使用他自身的属性。从一名敌人处劫掠技能后，会进入一段相当于{{ pertargetcooldown }}%目标终极技能冷却时间的、只针对该名敌人的冷却阶段(基于塞拉斯的技能急速)，最小值为{{ minimumenemycooldown }}秒，期间无法再次劫掠该名敌人的终极技能。",
      "cooldown": "80/55/30",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 3,
      "image": "SylasR.png",
      "key": "R"
    }
  ]
}