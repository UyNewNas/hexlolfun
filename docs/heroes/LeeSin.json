  "passive": {
    "name": "疾风骤雨",
    "description": "在李青使用一次技能后，他的下两次攻击会获得攻速加成，且回复能量。",
    "image": "LeeSinPassive.png"
  },
  "spells": [
    {
      "name": "天音波/回音击",
      "description": "天音波：李青发出刺耳的声波定位敌人，对首个敌人造成物理伤害。如果天音波击中敌人，李青在接下来3秒可施放回音击。回音击：李青冲向被天音波击中的敌人，造成基于该目标已损失生命值的物理伤害。",
      "tooltip": "李青发出刺耳的声波定位敌人，对命中的首个敌人造成{{ initialdamage }}物理伤害，提供目标的真实视野，并使李青可以在接下来的{{ reactivatetime }}秒内再次施放。再次施放：李青突进向被声波击中的敌人，造成{{ recastdamage }}到{{ empowereddamage }}物理伤害（基于目标已损失的生命值）。",
      "cooldown": "10/9/8/7/6",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "LeeSinQOne.png",
      "key": "Q"
    },
    {
      "name": "金钟罩/铁布衫",
      "description": "金钟罩：李青冲向目标友军，为他自身提供护盾值。如果该友军是一名英雄，则也会获得护盾值。在使用【金钟罩】后，李青可以施放【铁布衫】。铁布衫：李青艰苦卓绝的训练让他能在战斗中激发潜能。李青获得全能吸血。",
      "tooltip": "李青冲刺至一名友军或守卫处。如果目标友军是一名英雄，李青会为自己和目标友军提供持续{{ shieldduration }}秒的{{ shieldamount }}护盾值。李青可以在接下来的{{ w1reactivatetime }}秒内再次施放此技能。再次施放：李青获得持续{{ lifestealandspellvamptime }}秒的{{ lifestealandspellvamp }}%全能吸血。",
      "cooldown": "7",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "LeeSinWOne.png",
      "key": "W"
    },
    {
      "name": "天雷破/摧筋断骨",
      "description": "天雷破：李青猛击地面，施放冲击波，造成魔法伤害并使命中的敌方单位显形。如果天雷破命中了一名敌人，那么李青可以施放【摧筋断骨】。摧筋断骨：李青致残被天雷破给伤害到的敌人，减少其移动速度。持续期间受影响单位的移动速度会逐渐恢复正常。",
      "tooltip": "李青猛击地面，施放冲击波，造成{{ initialdamage }}魔法伤害并使命中的敌方单位显形{{ slowduration }}秒。如果这个技能命中了一名敌人，那么李青可以在接下来的{{ reactivatetime }}秒内再次施放此技能。再次施放：李青使被冲击波击中的敌人造成在{{ slowduration }}秒里持续衰减的{{ slowamount }}%减速。",
      "cooldown": "8",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 5,
      "image": "LeeSinEOne.png",
      "key": "E"
    },
    {
      "name": "猛龙摆尾",
      "description": "李青用强力的回旋踢击退敌方英雄，对目标以及被目标撞到的任何敌人造成物理伤害。 被目标撞到的敌人会被短暂击飞。这项技艺是春哥教他的，不过李青不能将玩家的英雄踢到地图外面去。",
      "tooltip": "李青用一记强力的回旋踢击退一名敌方英雄，并造成{{ damage }}物理伤害。被目标撞到的敌方英雄会被短暂击飞并受到物理伤害，伤害值相当于{{ damage }}加上初始目标{{ percenthpcarrythrough }}%的额外生命值。",
      "cooldown": "110/85/60",
      "cost": "0",
      "costType": "无消耗",
      "range": "375",
      "maxrank": 3,
      "image": "LeeSinR.png",
      "key": "R"
    }
  ]
