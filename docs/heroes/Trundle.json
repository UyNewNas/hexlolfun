  "passive": {
    "name": "国王的贡品",
    "description": "每当附近有一个敌方单位死亡，特朗德尔都会获得相当于其一部分最大生命值的治疗效果。",
    "image": "Trundle_Passive.png"
  },
  "spells": [
    {
      "name": "利齿撕咬",
      "description": "特朗德尔撕咬敌方，造成伤害，并暂时减少敌人的移动速度，削弱敌人的攻击力。",
      "tooltip": "特朗德尔的下次攻击造成{{ totaldamage }}物理伤害和短暂的{{ slowamount*100 }}%减速，然后特朗德尔获得持续{{ sapdebuffduration }}秒的{{ bonusad }}攻击力并且敌人们在这期间失去{{ sappedad*-1 }}攻击力。",
      "cooldown": "3.5",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "TrundleTrollSmash.png",
      "key": "Q"
    },
    {
      "name": "冰封领域",
      "description": "特朗德尔将目标区域变成他的领土，增加自己在该区域的攻击速度、移动速度，并且会从所有治疗手段中获得额外治疗效果。",
      "tooltip": "特朗德尔冻结一个区域{{ duration }}秒。在其中时，他会获得{{ msbonus*100 }}%移动速度，{{ asbonus*100 }}%攻击速度，和{{ healingbonus*100 }}%治疗效果提升。",
      "cooldown": "18/17/16/15/14",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "trundledesecrate.png",
      "key": "W"
    },
    {
      "name": "寒冰之柱",
      "description": "特朗德尔在目标地点召唤寒冰之柱，令敌人无法通过，并减缓附近敌方单位的移动速度。",
      "tooltip": "特朗德尔生成一个持续{{ pillarduration }}秒的冰柱，短暂击退它上方的敌人们并使附近的敌人们减速{{ slowamount }}%。",
      "cooldown": "21/19.5/18/16.5/15",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "TrundleCircle.png",
      "key": "E"
    },
    {
      "name": "强权至上",
      "description": "特朗德尔直接偷取目标的一部分生命值、大量的护甲和魔抗。在接下来的4秒里，特朗德尔将继续偷取双倍的等量的生命值、护甲值和魔抗。",
      "tooltip": "特朗德尔吸取一名敌方英雄的生命力，在{{ actualdurationofdrainbuff }}秒里持续造成共计{{ totalpercenthpdamage }}最大生命值的魔法伤害并偷取{{ armormrshred*100 }}%护甲和魔法抗性。",
