  "passive": {
    "name": "虚空之石",
    "description": "卡萨丁所受的魔法伤害减少，并无视单位的碰撞体积。",
    "image": "Kassadin_Passive.png"
  },
  "spells": [
    {
      "name": "虚无法球",
      "description": "卡萨丁向目标发射虚空能量法球，造成伤害并打断目标的技能引导。满溢的能量会在他身边环绕，提供一个可吸收魔法伤害的临时护盾。",
      "tooltip": "卡萨丁发射一颗虚无能量法球，造成{{ totaldamage }}魔法伤害并打断引导技能。卡萨丁还会获得{{ totalshield }}魔法护盾，持续1.5秒。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "NullLance.png",
      "key": "Q"
    },
    {
      "name": "虚空之刃",
      "description": "被动：卡萨丁的普通攻击会造成额外魔法伤害。主动：卡萨丁的下次普通攻击会造成显著的额外魔法伤害并回复法力值。",
      "tooltip": "被动：卡萨丁的攻击造成额外的{{ onhitdamage }}魔法伤害。主动：卡萨丁给他的剑刃充能，使他的下次攻击造成{{ activedamage }}魔法伤害并回复{{ missingmanaratio }}%已损失法力值，对抗英雄时提升至{{ championmissingmanaratio }}%。",
      "cooldown": "7",
      "cost": "1",
      "costType": " {{ abilityresourcename }}",
      "range": "1",
      "maxrank": 5,
      "image": "NetherBlade.png",
      "key": "W"
    },
    {
      "name": "能量脉冲",
      "description": "附近有单位施放法术技能时，卡萨丁将吸收能量，当充能完毕后，吸收的能量可转化为脉冲，对面前锥形区域内敌人造成伤害并减速。",
      "tooltip": "被动：卡萨丁附近每有任一个技能施放，能量脉冲的冷却时间就会缩短{{ reductionperspellcast }}秒。主动：卡萨丁释放一道虚空脉冲，造成{{ totaldamage }}魔法伤害和持续{{ e3 }}秒的{{ e2 }}%减速。",
      "cooldown": "21/20/19/18/17",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "ForcePulse.png",
      "key": "E"
    },
    {
      "name": "虚空行走",
      "description": "卡萨丁传送到附近区域，对区域内的敌方单位造成伤害。 在一段时间内连续施放虚空行走技能会消耗更多的法力值，但也会造成额外伤害。",
      "tooltip": "卡萨丁传送到附近的目标区域，着陆时对身边的所有敌方单位造成{{ basedamage }}魔法伤害。每在{{ rstackduration }}秒内连续施放一次虚空行走，法力消耗就会翻倍，并造成额外的{{ bonusdamage }}魔法伤害。消耗和伤害提升最多可叠加{{ maxstacks }}次。",
      "cooldown": "5/3.5/2",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 3,
      "image": "RiftWalk.png",
      "key": "R"
    }
  ]
