  "passive": {
    "name": "光芒四射",
    "description": "拉克丝的伤害类技能会对敌人施加【启明】效果，持续若干秒。拉克丝的下一次攻击将会消耗【启明】效果，来对目标造成额外魔法伤害（基于拉克丝等级）。",
    "image": "LuxIlluminatingFraulein.png"
  },
  "spells": [
    {
      "name": "光之束缚",
      "description": "拉克丝释放一个光球，束缚并伤害最多两个敌方单位。",
      "tooltip": "拉克丝朝目标地点发射一团光球，束缚前2名敌人{{ rootduration }}秒并对每个敌人造{{ totaldamagett }}魔法伤害。",
      "cooldown": "10",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "1175",
      "maxrank": 5,
      "image": "LuxLightBinding.png",
      "key": "Q"
    },
    {
      "name": "曲光屏障",
      "description": "拉克丝掷出她的魔杖，魔杖所触及的友方单位会有光环环绕，保护他们免受敌方伤害。",
      "tooltip": "拉克丝扔出她的魔杖，为它途经的友军提供持续{{ shieldduration }}秒的{{ totalshieldtt }}护盾。随后它会折返，为它途经的友军提供等额的护盾。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "1150",
      "maxrank": 5,
      "image": "LuxPrismaticWave.png",
      "key": "W"
    },
    {
      "name": "透光奇点",
      "description": "朝一个区域发射一个不规则的扭曲之光，减速附近敌人。拉克丝可以引爆它，对敌人造成区域性伤害。",
      "tooltip": "拉克丝创造一个光明地带，显形该区域并使区域中的敌人减速{{ slowpercent }}%。在{{ slowzoneduration }}秒后或再次施放这个技能后，它会爆炸，造成{{ totaldamagett }}魔法伤害并减速额外的{{ slowlingerduration }}秒。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "LuxLightStrikeKugel.png",
      "key": "E"
    },
    {
      "name": "终极闪光",
      "description": "在积蓄能量之后，拉克丝发射一束光波，对该区域所有目标造成伤害。此外，该技能触发拉克丝的被动技能并刷新光芒四射减益的持续时间。",
      "tooltip": "拉克丝发射一束耀目的光能射线，对一条直线上的所有敌人造成{{ totaldamage }}魔法伤害。",
      "cooldown": "60/50/40",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "3340",
      "maxrank": 3,
      "image": "LuxR.png",
      "key": "R"
    }
  ]
