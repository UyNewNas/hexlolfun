  "passive": {
    "name": "花岗岩护盾",
    "description": "墨菲特被岩石护盾保护，最多吸收10%最大生命值的伤害，若数秒内墨菲特未受到攻击，护盾将重置。",
    "image": "Malphite_GraniteShield.png"
  },
  "spells": [
    {
      "name": "地震碎片",
      "description": "墨菲特发出一块大地碎片穿过他敌人处的地面，在碰撞时造成伤害并且偷取移动速度3秒。",
      "tooltip": "墨菲特朝一名敌人发出一块大地碎片，造成{{ qdamagecalc }}魔法伤害，并对目标造成持续{{ slowduration }}秒的{{ e2 }}%减速。墨菲特还会窃取目标的这一部分速度，来获得持续{{ slowduration }}秒的与这个减速效果等额的移动速度。",
      "cooldown": "8",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "625",
      "maxrank": 5,
      "image": "SeismicShard.png",
      "key": "Q"
    },
    {
      "name": "雷霆拍击",
      "description": "墨菲特的攻击蕴含着如此惊人的力道以至于它引发了一次音爆。在接下来的数秒里，他的攻击会在他面前引发余波。",
      "tooltip": "被动：墨菲特获得{{ bonusarmorpassive*100 }}%护甲(%i:scaleArmor%{{ f1 }})。这个效果会在花岗岩护盾激活时提升至{{ bonusarmorpassive*300 }}% (%i:scaleArmor%{{ f2 }})。主动：墨菲特的下次攻击造成额外的{{ totalbonusdamage }}物理伤害 %i:OnHit% 攻击特效，并会引发一阵余震，以在其方向造成{{ thunderclapsplash }}物理伤害 %i:OnHit% 攻击特效。在接下来的{{ thunderclapbuffduration }}秒内，他的攻击会继续引发余震 %i:OnHit% 攻击特效。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "Obduracy.png",
      "key": "W"
    },
    {
      "name": "大地震颤",
      "description": "墨菲特锤击地面，放射出冲击波对目标造成基于他护甲值的魔法伤害，同时暂时降低目标攻击速度。",
      "tooltip": "墨菲特锤击地面，对周围敌人造成{{ edamagecalc }}魔法伤害并减少他们{{ asreduction }}%攻击速度，持续{{ duration }}秒。",
      "cooldown": "7",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "Landslide.png",
      "key": "E"
    },
    {
      "name": "势不可挡",
      "description": "墨菲特自身高速冲向一个区域，对区域内的敌人们造成伤害和击飞效果。",
      "tooltip": "墨菲特携着山崩之力冲锋，进行不可阻挡的突进。在突进结束时，墨菲特会击飞{{ knockupduration }}秒并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "130/115/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 3,
      "image": "UFSlash.png",
      "key": "R"
    }
  ]
