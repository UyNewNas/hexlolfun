  "passive": {
    "name": "战斗狂怒",
    "description": "泰达米尔每次攻击、暴击或击杀都能获得怒气。怒气被动地增加他的暴击几率，且可以通过释放嗜血杀戮来消耗。",
    "image": "Tryndamere_Passive.png"
  },
  "spells": [
    {
      "name": "嗜血杀戮",
      "description": "泰达米尔对战斗极度饥渴，他受伤程度越高，攻击力越强。他能通过释放【Q嗜血杀戮】消耗怒气并治疗自己。",
      "tooltip": "被动：泰达米尔嗜血成性，获得至多{{ maximumbonusad }}攻击力，基于他的已损失生命值。主动：泰达米尔消耗他的怒气，回复{{ baseheal }}外加{{ healperfury }}x怒气的生命值(最大值：{{ maximumheal }})。",
      "cooldown": "12",
      "cost": "0",
      "costType": "无消耗",
      "range": "400",
      "maxrank": 5,
      "image": "TryndamereQ.png",
      "key": "Q"
    },
    {
      "name": "蔑视",
      "description": "泰达米尔嘲笑敌人，减少身边敌方英雄的攻击力。背对泰达米尔的敌人还会被减速。",
      "tooltip": "泰达米尔抛出羞辱之语，使英雄们降低{{ adreduction*-1 }}攻击力，持续{{ reductionduration }}秒，并且对逃离泰达米尔的敌人造成{{ slowpotency*-100 }}%减速，持续{{ slowduration }}秒。",
      "cooldown": "14",
      "cost": "0",
      "costType": "无消耗",
      "range": "850",
      "maxrank": 5,
      "image": "TryndamereW.png",
      "key": "W"
    },
    {
      "name": "旋风斩",
      "description": "泰达米尔挥舞大剑冲向目标，对冲锋路线上所有敌人造成伤害。",
      "tooltip": "泰达米尔旋转并穿过他的敌人，造成{{ totaldamage }}物理伤害并且每命中一个敌人就会生成{{ nonchampfurygain }}怒气，在命中敌方英雄时提升至{{ champfurygain }}怒气。这个技能的冷却时间会在泰达米尔暴击时缩短{{ nonchampcdrefund }}秒，并在对英雄暴击时缩短{{ champcdrefund }}秒。",
      "cooldown": "12/11/10/9/8",
      "cost": "0",
      "costType": "无消耗",
      "range": "650",
      "maxrank": 5,
      "image": "TryndamereE.png",
      "key": "E"
    },
    {
      "name": "无尽怒火",
      "description": "泰达米尔是如此渴望战斗，以至于承受再多的伤害也不会死亡。",
      "tooltip": "泰达米尔变得对死亡完全免疫，持续{{ tryndrduration }}秒，拒绝将生命值降至{{ tryndrminhealth }}以下，并瞬间获得{{ tryndrfurygain }}怒气。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "400",
      "maxrank": 3,
      "image": "UndyingRage.png",
      "key": "R"
    }
  ]
