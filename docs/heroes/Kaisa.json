  "passive": {
    "name": "体表活肤",
    "description": "卡莎的普通攻击会叠加电浆，造成不断提升的额外魔法伤害。友军的定身效果也可以帮忙叠加电浆。此外，卡莎可通过购买装备来升级她的基础技能，让它们拥有更多强大的属性。",
    "image": "Kaisa_Passive.png"
  },
  "spells": [
    {
      "name": "艾卡西亚暴雨",
      "description": "卡莎发射一大堆弹体来搜寻附近的目标。活体武器：这个技能得到升级，可发射更多弹体。",
      "tooltip": "卡莎发射{{ e2 }}发弹体并在附近的敌人中间四散，每一发造成{{ totalindividualmissiledamage }}物理伤害，至多至最大值{{ maxdamagedisplay }}伤害。对英雄或野怪的每发额外弹体造成{{ extrahitreduction*100 }}%伤害。进化版：卡莎转而发射{{ e7 }}发弹体。当前：{{ f11.1 }}/{{ e6 }}额外攻击力",
      "cooldown": "10/9/8/7/6",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "KaisaQ.png",
      "key": "Q"
    },
    {
      "name": "虚空索敌",
      "description": "卡莎发射一束长程弹体，并用她的被动来标记敌人。活体武器：这个技能得到升级，可施加更多被动标记并在命中英雄时减少冷却时间。",
      "tooltip": "卡莎发射一道虚空震波来对命中的第一个敌人造成{{ totaldamage }}魔法伤害、施加{{ e4 }}层电浆效果并提供其真实视野，持续{{ spell.kaisapassive:pduration }}秒。进化版：卡莎转而施加{{ e5 }}层电浆效果并在命中一名英雄时使冷却时间缩短{{ e3 }}%。当前：{{ f2.1 }}/{{ e2 }}法术强度",
      "cooldown": "22/20/18/16/14",
      "cost": "55/60/65/70/75",
      "costType": " {{ abilityresourcename }}",
      "range": "3000",
      "maxrank": 5,
      "image": "KaisaW.png",
      "key": "W"
    },
    {
      "name": "极限超载",
      "description": "卡莎暂时提升移动速度，随后提升攻击速度。活体武器：这个技能得到升级，可短暂提供隐形效果。",
      "tooltip": "卡莎极限超载她的虚空能量，获得{{ totalmovespeed }}移动速度并且在超载时变为幽灵状态，随后获得持续{{ e2 }}秒的{{ e5 }}%攻击速度。每次攻击还会使此技能的冷却时间缩短{{ e4 }}秒。进化版：卡莎还会隐形{{ e7 }}秒。当前：{{ f10.1 }}%/{{ e6 }}%额外攻击速度",
      "cooldown": "16/14.5/13/11.5/10",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "1",
      "maxrank": 5,
      "image": "KaisaE.png",
      "key": "E"
    },
    {
      "name": "猎手本能",
      "description": "卡莎突进到一个敌方英雄身边。",
      "tooltip": "卡莎跃迁到一个位置上，该位置处于一名身上带有电浆效果的敌方英雄的附近，并获得持续{{ rshieldduration }}秒的{{ rcalculatedshieldvalue }}护盾值。",
      "cooldown": "130/100/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "2000/2500/3000",
      "maxrank": 3,
      "image": "KaisaR.png",
      "key": "R"
    }
  ]
