  "passive": {
    "name": "悍勇本色",
    "description": "莎弥拉可通过用不同的技能或攻击命中敌人来构建一次连招。莎弥拉在近战距离的攻击会造成额外的魔法伤害。莎弥拉在对被定身的敌人进行攻击时，将冲刺到她的最大攻击距离处。如果该敌人已被击飞，她还会使其短暂保持击飞状态。",
    "image": "SamiraP.png"
  },
  "spells": [
    {
      "name": "交火",
      "description": "莎弥拉进行一次射击或斩击，造成伤害。如果在【狂飙】期间施放，那么会在完成时打击沿途的所有敌人。",
      "tooltip": "莎弥拉进行一次射击，对命中的第一个敌人造成{{ damagecalc }}物理伤害。如果朝着近战距离内的一名敌人施放这个技能，那么莎弥拉会转而用她的剑进行斩击，造成{{ damagecalc }}物理伤害。",
      "cooldown": "6/5/4/3/2",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "SamiraQ.png",
      "key": "Q"
    },
    {
      "name": "锋旋",
      "description": "莎弥拉斩击她的周围，对敌人造成伤害并摧毁敌人的飞行道具。",
      "tooltip": "莎弥拉斩击她的周围{{ slashduration }}秒，对敌人造成2段伤害，每段为{{ damagecalc }}物理伤害并摧毁任何进入该区域的敌方飞行道具。",
      "cooldown": "30/28/26/24/22",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "325",
      "maxrank": 5,
      "image": "SamiraW.png",
      "key": "W"
    },
    {
      "name": "狂飙",
      "description": "莎弥拉冲刺并越过一名敌人（包含建筑物），斩击沿途的敌人并获得攻击速度。击杀一名敌方英雄会刷新这个技能的冷却时间。",
      "tooltip": "莎弥拉冲刺经过一名敌人（包括建筑物），斩击沿途的敌人来造成{{ dashdamage }}魔法伤害并获得持续{{ attackspeedduration }}秒的{{ bonusattackspeed*100 }}%攻击速度。如果敌方英雄在被莎弥拉造成伤害后的3秒内被击杀，那么这个技能的冷却时间将重置。",
      "cooldown": "20/18/16/14/12",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "SamiraE.png",
      "key": "E"
    },
    {
      "name": "炼狱扳机",
      "description": "莎弥拉的武器倾泻出大量的子弹，狂野地射击她周围的所有敌人。",
      "tooltip": "莎弥拉只能在她当前的评价等级为S时使用这个技能。使用这个技能会消耗掉所有评价等级。莎弥拉的武器倾泻出大量的子弹，狂野地在2秒里持续对她周围的所有敌人进行10次射击，每次射击造成{{ damagecalc }}物理伤害并施加{{ lifestealmod*100 }}%效能的生命偷取。这些射击也可以产生暴击。",
      "cooldown": "5",
      "cost": "0",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "SamiraR.png",
      "key": "R"
    }
  ]
