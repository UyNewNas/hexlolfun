  "passive": {
    "name": "有机体解构",
    "description": "维克兹的技能会对命中的敌人施加有机体解构效果。如果累积到3层效果，敌人就会受到爆发性的真实伤害。",
    "image": "VelKoz_Passive.png"
  },
  "spells": [
    {
      "name": "等离子裂变",
      "description": "维克兹发射一束等离子，再次施放此技能或在命中一名敌人后，等离子束会一分为二。等离子束在命中时会造成伤害和减速效果。",
      "tooltip": "维克兹发射一束等离子，造成{{ totaldamage }}魔法伤害和在{{ slowduration }}秒里持续衰减的{{ slowamount*100 }}%减速。在到达它的距离终点，或是命中一个目标，或是再次施放此技能时，等离子束会分裂成新的两束并呈90度角发射出去。用这个技能击杀一个单位，就会回复{{ tooltipmanarefund }}法力。",
      "cooldown": "7",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "1050",
      "maxrank": 5,
      "image": "VelkozQ.png",
      "key": "Q"
    },
    {
      "name": "虚空裂隙",
      "description": "维克兹开启一道虚空裂隙，造成初始爆发伤害，并在短暂的延迟后爆炸，造成第二段爆发伤害。",
      "tooltip": "维克兹打开一道虚空裂隙，造成{{ initialdamage }}魔法伤害。然后裂隙会喷发，造成{{ secondarydamage }}魔法伤害。这个技能有2层充能({{ ammorechargetime }}秒刷新时间)。",
      "cooldown": "1.5",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1050",
      "maxrank": 5,
      "image": "VelkozW.png",
      "key": "W"
    },
    {
      "name": "构造分解",
      "description": "维克兹让一个区域爆炸，击飞敌人，并将近处的敌人略微击退。",
      "tooltip": "维克兹瓦解一个附近的区域，导致它爆炸，造成{{ stunduration }}秒击飞和{{ totaldamage }}魔法伤害。靠近维克兹的敌人们将被击退，而不是击飞。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "810",
      "maxrank": 5,
      "image": "VelkozE.png",
      "key": "E"
    },
    {
      "name": "生命形态瓦解射线",
      "description": "维克兹释放一束被引导的光线跟随鼠标指针，可造成魔法伤害，持续2.5秒。【有机体解构】效果会研究敌方英雄，从而使他们受到真实伤害。",
      "tooltip": "维克兹引导一道能量射线来跟随鼠标指针，在2.5秒里持续造成共{{ totaldamage }}魔法伤害和{{ e3 }}%减速。对近期被有机体解构伤害过的敌人们造成真实伤害作为替代。射线内的敌人会周期性地获得解构层数。",
