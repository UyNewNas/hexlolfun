  "passive": {
    "name": "旅者的召唤",
    "description": "木灵：巴德吸引小型灵体来强化他的普攻以造成额外魔法伤害。当巴德收集到足够的调和之音时，这些木灵还会造成范围伤害并使命中的敌人减速。调和之音：远古的调和之音会随机出现，用来让巴德收集。这些调和之音会提供经验值，回复法力值，并提供脱战状态下的移动速度加成。",
    "image": "Bard_Passive.png"
  },
  "spells": [
    {
      "name": "星界束缚",
      "description": "巴德发射一束能量弹，减速命中的第一个敌人，并继续向前。如果能量弹命中墙体，它还会使首个目标晕眩；如果它命中了另一个敌人，那么它会让这两个敌人都晕眩。",
      "tooltip": "巴德发射一束能量弹，对命中的头两个敌人造成{{ totaldamage }}魔法伤害。第一个被命中的敌人会被施加持续{{ slowduration }}秒的{{ slowamountpercentage }}%减速。如果该能量弹命中了第二个敌人或一个墙体，那么被命中的敌人都会被晕眩{{ stunduration }}秒。",
      "cooldown": "11/10/9/8/7",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 5,
      "image": "BardQ.png",
      "key": "Q"
    },
    {
      "name": "游神圣坛",
      "description": "升起一座生命圣坛，圣坛会在短时间内持续充能，并在治疗和加速第一个接触它的友军后消失。",
      "tooltip": "巴德升起一座生命圣坛，圣坛会为第一个进入的友方英雄提供在{{ movespeed_duration }}秒里持续衰减的{{ calc_movespeed }}移动速度并为其回复至少{{ initialheal }}生命值。圣坛会不断成长，在存在{{ chargeuptime }}秒后即可满额回复{{ maxheal }}生命值。巴德最多可同时拥有{{ maxpacks }}座圣坛。如果有一名敌方英雄进入圣坛，那么该圣坛就会被摧毁。这个技能有{{ ammo_limit }}层充能。当前已激活的圣坛数：{{ f1 }} / {{ f2 }}",
      "cooldown": "0",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "BardW.png",
      "key": "W"
    },
    {
      "name": "神奇旅程",
      "description": "巴德在附近的地形上开启一道单向传送门。友军和敌军都可以使用传送门来穿过该地形。",
      "tooltip": "巴德在附近的地形上开启一道单向传送门，持续{{ e1 }}秒。传送门附近的任何英雄都可以通过移动到它上面来进入传送门。",
      "cooldown": "22/20.5/19/17.5/16",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "BardE.png",
      "key": "E"
    },
    {
      "name": "调和命运",
      "description": "巴德朝目标区域发射能量弧光，使区域内的所有单位、小兵、野怪和防御塔都暂时进入凝滞状态。",
      "tooltip": "巴德朝一个区域投出神奇的防护能量，使命中的所有单位和建筑物都进入凝滞状态{{ rstasisduration }}秒。",
      "cooldown": "110/95/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "3400",
      "maxrank": 3,
      "image": "BardR.png",
      "key": "R"
    }
  ]
