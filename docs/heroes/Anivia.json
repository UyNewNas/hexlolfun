  "passive": {
    "name": "寒霜涅槃",
    "description": "在受到致命伤害后，艾尼维亚将化身为凤凰蛋，然后满血复活。",
    "image": "Anivia_P.png"
  },
  "spells": [
    {
      "name": "寒冰闪耀",
      "description": "艾尼维亚挥动翅膀聚集空气，制造一枚冰晶向目标区域施放，冰冻并伤害路径上的所有敌人。当冰晶爆裂时，它会晕眩并伤害一定范围内的所有敌人。",
      "tooltip": "艾尼维亚发射出一个巨型冰块，造成{{ totalpassthroughdamage }}魔法伤害并冰冻敌人{{ slowduration }}秒，使其减速{{ spell.glacialstorm:slowamount }}%。在到达距离终点时，冰块会爆炸，晕眩敌人{{ stunduration }}秒并造成{{ totalexplosiondamage }}魔法伤害。艾尼维亚可以在冰块飞行途中再次施放这个技能来将其提前引爆。",
      "cooldown": "11/10/9/8/7",
      "cost": "80/85/90/95/100",
      "costType": " {{ abilityresourcename }}",
      "range": "1075",
      "maxrank": 5,
      "image": "FlashFrost.png",
      "key": "Q"
    },
    {
      "name": "寒冰屏障",
      "description": "艾尼维亚利用空气中的湿气，召唤出一道不可穿越的冰之墙来阻挡所有移动。该墙持续很短一段时间后就会融化。",
      "tooltip": "艾尼维亚召唤出一道宽{{ e2 }}码的无法通过的冰墙。冰墙会在融化前持续{{ e1 }}秒。",
      "cooldown": "17",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "Crystallize.png",
      "key": "W"
    },
    {
      "name": "霜寒刺骨",
      "description": "艾尼维亚扇动双翅，朝她的目标喷射出一股刺骨的强风，造成伤害。如果目标近期已被【Q寒冰闪耀】所命中或被一个完全形成的【R冰川风暴】所伤害，那么将会受到该技能双倍的伤害。",
      "tooltip": "艾尼维亚用一阵刺骨的寒风冲击一名敌人，造成{{ totaldamage }}魔法伤害。如果目标身上带有冰冻效果，则艾尼维亚会转而造成{{ empowereddamage }}魔法伤害。",
      "cooldown": "4",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "Frostbite.png",
      "key": "E"
    },
    {
      "name": "冰川风暴",
      "description": "艾尼维亚召唤出一朵夹杂着冰块和冰雹的雨云，对敌人造成伤害，并使其减速。",
      "tooltip": "激活：艾尼维亚在目标区域召唤出一阵夹杂着冰与雹的强雨，来使敌人减速{{ slowamount }}%并每秒造成{{ totaldamagepersecond }}魔法伤害。风暴会在{{ growthtime }}秒里持续提升规模。当风暴完全形成后，它会施加冰冻效果，使敌人减速{{ slowpercentempoweredtt }}%，并且每秒造成{{ empowereddamagepersecondtooltiponly }}魔法伤害。",
      "cooldown": "4/3/2",
      "cost": "60",
      "costType": "+{{ manacostpersecond }}法力/秒",
      "range": "750",
      "maxrank": 3,
      "image": "GlacialStorm.png",
      "key": "R"
    }
  ]
}