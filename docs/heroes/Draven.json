  "passive": {
    "name": "德莱文联盟",
    "description": "在接住一把旋转飞斧或者击杀了一个小兵、野怪或防御塔后，德莱文会从他的粉丝那里获得崇拜效果。击杀一名敌方英雄会为德莱文提供额外赏金，赏金的多少取决于他拥有多少层崇拜效果。",
    "image": "Draven_passive.png"
  },
  "spells": [
    {
      "name": "旋转飞斧",
      "description": "德莱文的下次攻击会造成额外物理伤害。这个斧头将会从目标身上弹到高空。如果德莱文接住了它，那么会立刻准备好下一发旋转飞斧。德莱文可以同时拥有2发旋转飞斧。",
      "tooltip": "德莱文准备好一把旋转飞斧，使他的下一次攻击造成额外的{{ totaldamage }}物理伤害然后弹到空中。如果德莱文接住了它，那么他会准备好另一把旋转飞斧。德莱文可以同时持有2把旋转飞斧。",
      "cooldown": "12/11/10/9/8",
      "cost": "45",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "DravenSpinning.png",
      "key": "Q"
    },
    {
      "name": "血性冲刺",
      "description": "德莱文获得移动速度和攻击速度加成。移动速度加成在持续时间过后会急剧下降。在接到一把旋转飞斧后，血性冲刺会立刻冷却完毕。",
      "tooltip": "德莱文进入幽灵状态，获得在{{ e3 }}秒里持续衰减的{{ e2 }}%移动速度和持续{{ e5 }}秒的{{ e4 }}%攻击速度。当德莱文接住一把旋转飞斧时，这个技能的冷却时间就会刷新。",
      "cooldown": "12",
      "cost": "40/35/30/25/20",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "DravenFury.png",
      "key": "W"
    },
    {
      "name": "开道利斧",
      "description": "德莱文扔出他的斧头，对命中的目标造成物理伤害，并将他们击退至一边。被命中的目标会受到减速效果。",
      "tooltip": "德莱文抛掷一柄开山斧，造成{{ totaldamage }}物理伤害，击退，以及持续{{ e3 }}秒的{{ e2 }}%减速。",
      "cooldown": "18/17/16/15/14",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "1050",
      "maxrank": 5,
      "image": "DravenDoubleShot.png",
      "key": "E"
    },
    {
      "name": "冷血追命",
      "description": "德莱文掷出两柄大斧，对命中的每个单位造成物理伤害。在命中一名敌方英雄后，大斧会缓慢地调转方向，并回到德莱文身边。在斧头正在向外飞的时候，德莱文可以激活该技能来让斧头早点飞回来。每命中一个单位，伤害值就会减少。在斧头调转方向时，伤害值会重置。会处决那些生命值低于德莱文崇拜层数的敌人们。",
      "tooltip": "德莱文猛掷出两把巨斧来造成{{ rcalculateddamage }}物理伤害。在命中一名英雄或再次施放之后，巨斧会掉转方向并返回德莱文处。巨斧每命中一个敌人就会降低{{ rdamagereductionperhit*100 }}%伤害，最低降至{{ rmindamagepercent }}%。如果冷血追命使一名敌方英雄的生命值低于德莱文目前的{{ rpassivestackscoefficient*100 }}%德莱文联盟层数({{ rpassivetruedamage }})，那么德莱文会将该英雄处决。",
      "cooldown": "100/90/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "20000",
      "maxrank": 3,
      "image": "DravenRCast.png",
      "key": "R"
    }
  ]
}