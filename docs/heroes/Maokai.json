  "passive": {
    "name": "吸元秘术",
    "description": "茂凯的普通攻击也会治疗自身并造成额外伤害，此效果拥有一个中等的冷却时间。每当茂凯施放一次技能或被一个敌方技能击中时，这个冷却时间都会缩短。",
    "image": "Maokai_Passive.png"
  },
  "spells": [
    {
      "name": "荆棘重击",
      "description": "茂凯用一记冲击波击退附近的敌人，造成魔法伤害和减速效果。",
      "tooltip": "茂凯将他的拳头砸入大地中，造成{{ totaldamage }}外加{{ basepercenthealth*100 }}%最大生命值的魔法伤害和短暂的减速。附近的敌人们还会被击退。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "MaokaiQ.png",
      "key": "Q"
    },
    {
      "name": "扭曲突刺",
      "description": "茂凯扭曲为一团移动根须，不可被选取并且向目标突进。在抵达后，他会禁锢住目标。",
      "tooltip": "茂凯扭曲为一团移动根须，无法被选取并且向目标突进。在抵达后，他会禁锢该敌人{{ rootduration }}秒并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "525",
      "maxrank": 5,
      "image": "MaokaiW.png",
      "key": "W"
    },
    {
      "name": "树苗投掷",
      "description": "茂凯投出一颗树苗去目标地区戒备。在草丛中更加有效。",
      "tooltip": "茂凯扔出一棵树苗，戒备{{ saplingduration }}秒。树苗会追击附近的敌人，并在抵达后爆炸，对周围的敌人们造成{{ totaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。如果树苗命中了一名敌方英雄或史诗级野怪，吸元秘术的冷却时间就会缩短额外的4秒。投掷在草丛里的树苗会持续{{ empoweredsaplingduration }}秒，并引发一次范围更大的爆炸，在{{ empowereddotduration }}秒的持续时间里共造成{{ totalempowereddamage }}魔法伤害并且减速幅度变为{{ empoweredslowamount }}。",
      "cooldown": "18/17/16/15/14",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "MaokaiE.png",
      "key": "E"
    },
    {
      "name": "自然之握",
      "description": "茂凯召唤一道荆棘和尖刺灌木组成的巨墙缓慢向前行进，对沿途的敌人造成伤害和禁锢效果。",
      "tooltip": "茂凯召唤出一道由荆棘和带刺灌木组成的巨墙缓慢向前行进，禁锢敌人{{ minrootduration }}到{{ maxrootduration }}秒，时长随着行进距离提升，并造成{{ totaldamage }}魔法伤害。命中一名英雄时会为茂凯提供在{{ hasteduration }}秒里持续衰减的{{ movehaste*100 }}%移动速度。",
      "cooldown": "130/110/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "3000",
      "maxrank": 3,
      "image": "MaokaiR.png",
      "key": "R"
    }
  ]
