  "passive": {
    "name": "金刚不坏",
    "description": "孙悟空在与英雄或野怪战斗时，会获得可叠加的护甲和最大生命值回复。",
    "image": "MonkeyKingStoneSkin.png"
  },
  "spells": [
    {
      "name": "粉碎打击",
      "description": "孙悟空的下次攻击获得额外距离，造成额外伤害，并暂时减少敌人的护甲。",
      "tooltip": "孙悟空和他的分身的下次攻击提升{{ attackrangebonus }}距离，造成{{ bonusdamagett }}额外物理伤害，并移除目标{{ armorshredpercent*100 }}%护甲，持续{{ shredduration }}秒。每当孙悟空或他的分身用一次攻击或技能命中一名敌人时，这个技能的冷却时间就会缩短{{ cooldowndecrease }}秒。这个技能会在造成伤害时触发技能特效。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "250/275/300/325/350",
      "maxrank": 5,
      "image": "MonkeyKingDoubleAttack.png",
      "key": "Q"
    },
    {
      "name": "真假猴王",
      "description": "孙悟空变为隐形状态并朝着一个方向突进，同时留下一个会攻击附近敌人的分身。",
      "tooltip": "孙悟空突进并变为隐形状态，持续{{ stealthduration }}秒，同时留下一个持续{{ cloneduration }}秒的不能移动的分身。分身会攻击附近的近期被孙悟空造成过伤害的敌人并会模拟他的终极技能，造成{{ clonedamagemod*100 }}%的常规伤害。",
      "cooldown": "22/21/20/19/18",
      "cost": "60/55/50/45/40",
      "costType": " {{ abilityresourcename }}",
      "range": "275",
      "maxrank": 5,
      "image": "MonkeyKingDecoy.png",
      "key": "W"
    },
    {
      "name": "腾云突击",
      "description": "孙悟空突进至一名目标敌人处，并放出幻象来攻击他目标附近的敌人，同时对每个被击中的敌人造成伤害。",
      "tooltip": "孙悟空突进至目标敌人处，并放出多个分身来对附近的至多{{ extratargets }}个额外敌人进行模拟突进。每个被击中的敌人会受到{{ totaldamage }}魔法伤害。他和他的分身获得持续{{ attackspeedduration }}秒的{{ attackspeed*100 }}%攻击速度。",
      "cooldown": "10/9.25/8.5/7.75/7",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "MonkeyKingNimbus.png",
      "key": "E"
    },
    {
      "name": "大闹天宫",
      "description": "孙悟空伸展金箍棒不断旋转，并获得移动速度。击中敌人时会造成伤害和击飞效果。",
      "tooltip": "孙悟空获得{{ movespeed*100 }}%移动速度并旋转他的金箍棒，击飞 附近的敌人{{ knockupduration }}秒并在{{ spinduration }}秒里持续造成共{{ totaldamagett }}加上 {{ percenthpdamagett }}最大生命值的物理伤害。这个技能可以在{{ recastwindow }}秒里再施放一次，随后会进入冷却阶段。",
      "cooldown": "130/110/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "315",
      "maxrank": 3,
      "image": "MonkeyKingSpinToWin.png",
      "key": "R"
    }
  ]
