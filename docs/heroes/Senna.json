  "passive": {
    "name": "赦除",
    "description": "当赛娜附近有单位死亡时，这些单位的灵魂会周期性地被黑雾所捕获。赛娜可以攻击这些灵魂来解脱他们，并吸收使他们困在死界的黑雾。黑雾会为她的圣枪提供燃料，提升她的攻击力、攻击距离和暴击几率。赛娜的圣物火炮需要更长的射击时间，造成额外伤害，并暂时为她提供她目标的一部分移动速度。",
    "image": "Senna_Passive.png"
  },
  "spells": [
    {
      "name": "黑暗洞灭",
      "description": "赛娜从她的圣物火炮的双生炮管中射出一道光影相生之芒来洞穿一个目标，治疗友军并伤害敌人。",
      "tooltip": "赛娜发射一束洞灭之影来洞穿一名友军或一名敌人，对敌人造成{{ totaldamage }}物理伤害和持续{{ slowduration }}秒的{{ totalslow }}减速。给友方英雄回复{{ totalheal }}生命值。攻击会使这个技能的冷却时间缩短{{ cdreductiononhit }}秒。",
      "cooldown": "15",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "SennaQ.png",
      "key": "Q"
    },
    {
      "name": "无尽厮守",
      "description": "赛娜向前发射一道黑雾。如果它命中了一名敌人，它就会饥渴地纠缠住该敌人，在短暂的延迟后对该敌人及其附近的单位造成禁锢效果。",
      "tooltip": "赛娜向前发射一道黑雾，对命中的第一个敌人造成 {{ damage }}物理伤害。在{{ delaytime }}秒的延迟后，对目标及目标附近的其它敌人造成{{ rootduration }}秒禁锢效果。",
      "cooldown": "11",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1250",
      "maxrank": 5,
      "image": "SennaW.png",
      "key": "W"
    },
    {
      "name": "黑雾咒附",
      "description": "赛娜将她存在武器内的黑雾抽出，在她四周形成一团风暴，然后投身于黑暗并变成幽魂。进入黑雾区域的友军会变成伪装状态，并且在被黑雾笼罩时也会呈现出幽灵的外观。幽魂会获得移动速度提升，无法被选中，并且隐藏自身的身份。",
      "tooltip": "赛娜融入一团黑雾，持续{{ buffduration }}秒，并变成幽魂。进入黑雾的友方英雄会变成伪装状态，并在离开时变成幽魂。幽魂获得{{ totalms }}移动速度，无法被选中，并且在附近没有敌方英雄时会隐藏自己的身份。",
      "cooldown": "26/24.5/23/21.5/20",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "SennaE.png",
      "key": "E"
    },
    {
      "name": "暗影燎原",
      "description": "赛娜召唤陨落哨兵们的圣石，将她的圣物火炮拆分成一座光与影的神圣阵列。她随后会发射一道不限距离的光束，来为命中的友军提供护盾，并对中心区域内的敌人造成伤害。",
      "tooltip": "赛娜发射一道光束，对命中的所有敌方英雄造成{{ totaldamage }}物理伤害。在更广范围内被命中的友方英雄会获得{{ totalshield }}护盾值，持续{{ shieldduration }}秒。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "SennaR.png",
      "key": "R"
    }
  ]
}