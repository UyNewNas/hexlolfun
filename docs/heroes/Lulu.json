  "passive": {
    "name": "皮克斯，仙灵伙伴",
    "description": "每当皮克斯正在跟随的英雄进行攻击时，皮克斯就会发射魔法飞弹。这些飞弹会自动寻敌，但也会被其它单位所拦截。",
    "image": "Lulu_PixFaerieCompanion.png"
  },
  "spells": [
    {
      "name": "闪耀长枪",
      "description": "璐璐和皮克斯各自发射一个穿刺飞弹，对命中的所有敌人造成伤害和重度减速效果。",
      "tooltip": "璐璐和皮克斯各发射一束贯穿魔弹，造成{{ totaldamage }}魔法伤害和在{{ slowduration }}秒里持续衰减的{{ slowamount*-100 }}%减速。如果两束魔弹都命中了相同的一名敌人，那么会对其造成额外的{{ bonusmissiledamage }}魔法伤害。",
      "cooldown": "7",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "LuluQ.png",
      "key": "Q"
    },
    {
      "name": "奇思妙想",
      "description": "如果对友军施放，会暂时增加目标友军的攻击速度和移动速度。如果对敌人施放，会将一名敌方英雄变成可爱的动物，使其无法攻击或施法。",
      "tooltip": "当用在一名友方身上时，璐璐提供{{ totalms }}移动速度和{{ e7 }}%攻击速度，持续{{ e5 }}秒。当用在一名敌人身上时，璐璐会将其变形{{ e3 }}秒。",
      "cooldown": "18",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "LuluW.png",
      "key": "W"
    },
    {
      "name": "帮忙，皮克斯！",
      "description": "如果对友军施放，会命令皮克斯跳到一名友军身上进行保护，之后会跟随并协助目标（而不是璐璐）进行攻击。如果对敌人施放，皮克斯会跳到敌人身上造成伤害，之后会跟随并提供目标的视野。",
      "tooltip": "在对一名友方施放时，皮克斯会跳到该友方处并提供皮克斯，仙灵伙伴，持续{{ e1 }}秒。如果该友方是一名英雄，那么皮克斯还会提供{{ totalshield }}护盾值，持续{{ e7 }}秒。在对一名敌方英雄使用时，皮克斯会妨碍该英雄，造成{{ totaldamage }}魔法伤害并提供其真实视野，持续{{ e6 }}秒。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "LuluE.png",
      "key": "E"
    },
    {
      "name": "狂野生长",
      "description": "璐璐让她的友军变大，击飞目标附近的敌人，同时为她的友军提供大量生命值加成。接下来的数秒内，该友军会获得一个减少附近敌人速度的光环。",
      "tooltip": "璐璐使一名友方英雄巨大化，并击飞周围的敌人{{ knockbackduration }}秒。巨大化的友方英雄会获得{{ totalbonushealth }}最大生命值并使周围的敌人们减速{{ slowpercent }}%，持续{{ buffduration }}秒。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 3,
      "image": "LuluR.png",
      "key": "R"
    }
  ]
}