  "passive": {
    "name": "忍法！气合盾",
    "description": "在施放一次技能后，慎会获得一层护盾。如果慎的技能对英雄产生作用，那么这个技能的冷却时间就会降低。",
    "image": "Shen_Passive.png"
  },
  "spells": [
    {
      "name": "奥义！暮临",
      "description": "慎召回他的魂刃并用它进行攻击，造成基于目标最大生命值的额外伤害。如果魂刃在召回途中与一个敌方英雄产生了碰撞，那么慎的魂刃攻击会获得极大强化，并且所有被碰撞的敌人在逃离慎的时候都会被减速。",
      "tooltip": "慎召回他的魂刃。被其命中的敌人们在接下来的{{ e5 }}秒里，在远离慎的时候会被减速{{ e4 }}%。此外，慎的下{{ e3 }}次攻击造成额外的{{ baseflatdamage }}外加{{ basepercenthealth }}最大生命值的魔法伤害。如果慎用魂刃命中了一名英雄，那么伤害提升至{{ baseflatdamage }}外加{{ emppercenthealth }}最大生命值的魔法伤害并且他的那几次攻击获得{{ e9 }}%攻击速度。",
      "cooldown": "8/7.25/6.5/5.75/5",
      "cost": "140/130/120/110/100",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "ShenQ.png",
      "key": "Q"
    },
    {
      "name": "奥义！魂佑",
      "description": "当慎或友方英雄在魂刃附近时，魂刃会对原本要命中他们的攻击进行格挡。",
      "tooltip": "慎在他的魂刃位置生成一个防御结界，持续{{ e1 }}秒。对结界内的友方英雄进行的攻击都会被格挡。 如果结界在开启时并没有英雄在其中，那么它会等待至多{{ e2 }}秒。",
      "cooldown": "16/14.5/13/11.5/10",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "ShenW.png",
      "key": "W"
    },
    {
      "name": "奥义！影缚",
      "description": "慎朝着一个方向冲刺，嘲讽沿途的敌人。",
      "tooltip": "被动：用奥义！暮临或这个技能造成伤害时，会回复{{ energyrefund }}能量。主动：慎进行冲刺，嘲讽英雄和野怪{{ ccduration }}秒并造成{{ tauntdamage }}物理伤害。",
      "cooldown": "18/16/14/12/10",
      "cost": "150",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "ShenE.png",
      "key": "E"
    },
    {
      "name": "秘奥义！慈悲度魂落",
      "description": "慎为目标友方英雄提供一层吸收伤害的护盾，然后很快传送到目标身旁。",
      "tooltip": "慎为地图任一位置的一名友方英雄提供持续{{ shieldduration }}秒的{{ shield }}到{{ maxshield }}护盾值，基于目标的已损失生命值(在60%已损失生命值时达到最大值)。在引导{{ channelduration }}秒后，慎会带着魂刃传送到该友方英雄所在的位置。",
      "cooldown": "200/180/160",
      "cost": "0",
      "costType": "无消耗",
      "range": "35000",
      "maxrank": 3,
      "image": "ShenR.png",
      "key": "R"
    }
  ]
