  "passive": {
    "name": "卓尔不凡",
    "description": "辛德拉可通过提升等级和伤害敌人来收集【怒法碎晶】，用来使她的各技能获得强化。暗黑法球：辛德拉可以持有额外一层充能。驱使念力：额外真实伤害。弱者退散：提升宽度并减速所有目标。能量倾泻：处决低生命值的目标。",
    "image": "SyndraPassive.png"
  },
  "spells": [
    {
      "name": "暗黑法球",
      "description": "辛德拉幻化出一个造成魔法伤害的暗黑法球。法球会存留，并且被她的其它能力所操纵。",
      "tooltip": "辛德拉幻化出一颗暗黑法球，造成{{ totaldamage }}魔法伤害。这个暗黑法球可以存留{{ sphereduration }}秒，并且能被辛德拉的其它技能所操纵。{{ spell.syndrapassive:q1upgradethreshold }}块怒法碎晶：辛德拉可以储存{{ upgrade1maxammo }}个暗黑法球充能。",
      "cooldown": "7",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "SyndraQ.png",
      "key": "Q"
    },
    {
      "name": "驱使念力",
      "description": "辛德拉抓取并投掷一名敌方小兵或者暗黑法球，来对敌人造成魔法伤害，并减少他们的移动速度。",
      "tooltip": "辛德拉抓取一颗暗黑法球、一个敌方小兵或一只非史诗级野怪。她在抓取后的至多5秒内可以再次施放这个技能。再次施放：辛德拉将物体猛掷出去，造成{{ throwdamage }}魔法伤害和持续{{ f2 }}秒的{{ totalslowamount }}%减速效果。{{ spell.syndrapassive:wupgradethreshold }}块怒法碎晶：这个技能造成额外的{{ tooltiponlypassivebonuspercent }}真实伤害。",
      "cooldown": "12/11/10/9/8",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "SyndraW.png",
      "key": "W"
    },
    {
      "name": "弱者退散",
      "description": "辛德拉将敌人和暗黑法球击退，并造成魔法伤害。被暗黑法球命中的敌人会被晕眩。",
      "tooltip": "辛德拉投出一道原力波，击退敌人们和暗黑法球并造成{{ totaldamage }}魔法伤害。被推挤的暗黑法球会晕眩敌人{{ stunduration }}秒并造成{{ totaldamage }}魔法伤害。{{ spell.syndrapassive:eupgradethreshold }}块怒法碎晶：这个技能的宽度得到提升并且还会对敌人们造成持续{{ upgradedslowduration }}秒的{{ upgradedslowamount*100 }}%减速。",
      "cooldown": "15",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "SyndraE.png",
      "key": "E"
    },
    {
      "name": "能量倾泻",
      "description": "辛德拉用她的所有暗黑法球来轰击一名敌方英雄。",
      "tooltip": "被动：每级能量倾泻都会为暗黑法球提供额外的{{ qhasteperrank }}技能急速。辛德拉动用她洪流般的能量，将环绕于她的3颗暗黑法球外加至多4颗附近的暗黑法球轰在一名敌方英雄身上。每颗暗黑法球造成{{ damagecalc }}魔法伤害(最大{{ maxdamagecalc }}魔法伤害)。{{ spell.syndrapassive:rupgradethreshold }}块怒法碎晶：这个技能处决生命值低于{{ upgradeexecutethreshold*100 }}%的敌人。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "675",
      "maxrank": 3,
      "image": "SyndraR.png",
      "key": "R"
    }
  ]
}