  "passive": {
    "name": "瓶中时光",
    "description": "基兰将时光储存为经验值并能将其提供给他的友军。当他拥有足够的经验值来使一名友方英雄升级时，他就能通过右键点击来传授经验值。基兰自身也会获得等值的经验值。",
    "image": "Zilean_Passive.png"
  },
  "spells": [
    {
      "name": "定时炸弹",
      "description": "将一颗炸弹扔向目标区域，炸弹会附着在靠近它的单位身上（英雄优先）。炸弹会在3秒后爆炸，造成范围魔法伤害。如果炸弹被另一颗定时炸弹给提前引爆，那么还会使敌人晕眩。",
      "tooltip": "基兰在目标地点上投掷一个定时炸弹。炸弹会附着在第一个靠近它周围小范围内的单位身上。{{ fuseduration }}秒后炸弹会爆炸，造成{{ totaldamage }} 魔法伤害。对已被附着了一颗炸弹的单位放置第二颗炸弹时，就会立刻引爆第一个炸弹，并使爆炸范围内的所有敌人晕眩{{ stunduration }}秒。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "ZileanQ.png",
      "key": "Q"
    },
    {
      "name": "穿梭未来",
      "description": "基兰为未来的对抗做准备，减少他所有其它基础技能的冷却时间。",
      "tooltip": "基兰倒转时间，使他其它基础技能的冷却时间缩短{{ cooldownreduction }}秒。",
      "cooldown": "14/12/10/8/6",
      "cost": "35",
      "costType": "法力",
      "range": "600",
      "maxrank": 5,
      "image": "ZileanW.png",
      "key": "W"
    },
    {
      "name": "时光发条",
      "description": "基兰扭曲任意单位的时光，短时间内提升友方单位移动速度或减少敌方单位移动速度。",
      "tooltip": "基兰使一名敌方英雄减速{{ speedamount }}%或为一名友方英雄提供{{ speedamount }}%移动速度，持续{{ duration }}秒。",
      "cooldown": "15",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "TimeWarp.png",
      "key": "E"
    },
    {
      "name": "时光倒流",
      "description": "基兰对友方英雄施放时光结界，若目标死亡，则时光倒流，救活目标。",
      "tooltip": "基兰提供一个保护性的时间符文给一名友方英雄，持续{{ rduration }}秒。如果该目标将要阵亡，那么符文会回溯其时间线，使其凝滞{{ revivestateduration }}秒，然后将其复活并回复{{ rtotalheal }}生命值。",
      "cooldown": "120/90/60",
      "cost": "125/150/175",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 3,
      "image": "ChronoShift.png",
      "key": "R"
    }
