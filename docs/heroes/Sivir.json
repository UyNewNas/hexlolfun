  "passive": {
    "name": "敏锐疾行",
    "description": "希维尔在攻击一名敌方英雄时，会短暂地获得移动速度提升。",
    "image": "Sivir_Passive.png"
  },
  "spells": [
    {
      "name": "回旋之刃",
      "description": "希维尔像挥舞回力标一样挥出她的十字刃，并在往返时造成伤害。",
      "tooltip": "希维尔像挥舞回力标一样挥出她的十字刃，对命中的所有敌人造成{{ totaldamage }}。命中非英雄单位时，会使对每个后续目标的伤害减少，减到{{ falloffminimum*100 }}%为止。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "55/60/65/70/75",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 5,
      "image": "SivirQ.png",
      "key": "Q"
    },
    {
      "name": "弹射",
      "description": "希维尔的下几次普通攻击将获得额外攻击速度并弹射到周围的目标上，在弹射时造成削减过的伤害。",
      "tooltip": "在接下来的{{ buffduration }}秒里，希维尔获得{{ ricochetattackspeed*100 }}%攻击速度并且她的普攻会获得强化，弹射到附近的其它敌人上，每次弹射造成{{ bouncedamage }}物理伤害，至多弹射{{ maxbounces }}次。如果生成弹射的那次攻击造成了暴击，那么该次普攻的所有弹射都会暴击。",
      "cooldown": "12",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "SivirW.png",
      "key": "W"
    },
    {
      "name": "法术护盾",
      "description": "制造一层法术屏障，来格挡一次对着希维尔施放的敌方单体技能。如果希维尔成功格挡了一次技能，那么就会回复生命值并获得爆发性的移动速度加成。",
      "tooltip": "希维尔制造一层持续{{ spellshieldduration }}秒的法术屏障，来格挡一次即将到来的敌方技能。如果希维尔成功格挡了一次技能，那么就会回复{{ totalheal }}生命值并触发【敏锐疾行】。",
      "cooldown": "24/22.5/21/19.5/18",
      "cost": "0",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "SivirE.png",
      "key": "E"
    },
    {
      "name": "狩猎",
      "description": "希维尔在战斗中引领她的友军，为他们提供持续一段时间的爆发性移动速度加成。此外，希维尔的攻击会缩短她的技能的冷却时间。",
      "tooltip": "希维尔在战斗中引领附近的友军，为他们提供持续{{ ultduration }}秒的{{ maxms*100 }}%移动速度。在【狩猎】激活期间，希维尔对英雄进行的攻击会使她的基础技能的冷却时间缩短{{ attackcooldownrefund }}秒。参与击杀近期造成过伤害的敌人会刷新【狩猎】的持续时长。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 3,
      "image": "SivirR.png",
      "key": "R"
    }
  ]
}