  "passive": {
    "name": "梦满枝",
    "description": "用一个技能命中一位英雄或野怪，将持续造成额外的最大生命值伤害。",
    "image": "Lillia_Icon_Passive.png"
  },
  "spells": [
    {
      "name": "飞花挞",
      "description": "被动部分：莉莉娅在用技能命中敌人时，会获得移动速度。主动部分：莉莉娅对附近的敌人造成魔法伤害，并对边缘的敌人造成额外真实伤害。",
      "tooltip": "被动：莉莉娅的技能在命中时会提供{{ prancespeed }}移动速度，持续{{ pranceduration }}秒，可叠加{{ prancemaxstacks }}层。主动：莉莉娅猛掷她的香炉，造成{{ totaldamage }}魔法伤害，并在外侧边缘造成额外的{{ bonustruedamage }}真实伤害 。",
      "cooldown": "6/5.5/5/4.5/4",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 5,
      "image": "LilliaQ.png",
      "key": "Q"
    },
    {
      "name": "惊惶木",
      "description": "莉莉娅在附近的一个区域内造成伤害，并在该区域的中心造成大量伤害。",
      "tooltip": "莉莉娅进行一次巨大打击，在一个区域内造成{{ flatdamage }}魔法伤害。区域中心的敌人会受到{{ flatdamagesweetspot }}伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 5,
      "image": "LilliaW.png",
      "key": "W"
    },
    {
      "name": "流涡种",
      "description": "莉莉娅猛掷出一枚种子，种子在着陆时会造成伤害和减速效果。如果种子未能命中任何东西，那么它将继续滚动，直到命中墙体或一名敌人为止。",
      "tooltip": "莉莉娅投出一枚种子，种子在着陆时会显形并造成{{ impactdamagetotal }}魔法伤害和{{ slowamount*100 }}%减速效果，持续{{ slowduration }}秒，期间还会使目标显形。如果种子未能命中任何东西，那么它将继续滚动，直到命中墙体或一名敌人为止。",
      "cooldown": "12",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "LilliaE.png",
      "key": "E"
    },
    {
      "name": "夜阑谣",
      "description": "莉莉娅使所有带着【梦尘】的敌人陷入困倦状态，然后陷入昏睡状态。这些敌人在被强制唤醒时会受到额外伤害。",
      "tooltip": "莉莉娅使所有带着梦尘的敌人陷入困倦状态{{ drowsyduration }}秒。此后，他们会陷入昏睡状态{{ sleepduration }}秒。在被伤害惊醒时，他们会受到额外的{{ totaldamage }}魔法伤害。",
      "cooldown": "150/130/110",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "1600",
      "maxrank": 3,
      "image": "LilliaR.png",
