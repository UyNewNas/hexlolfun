  "passive": {
    "name": "溺水之幸",
    "description": "当派克消失在敌人视野外时，他可从所受的来自敌方英雄的伤害中回复显著的生命值。派克无法从任何来源（装备、符文等）中获得额外最大生命值加成，而是会获得攻击力作为替代。",
    "image": "PykePassive.png"
  },
  "spells": [
    {
      "name": "透骨尖钉",
      "description": "派克要么戳刺他前方的一名敌人，要么将一名敌人拽向他。",
      "tooltip": "秒放：派克进行戳刺，对命中的第一个敌人造成{{ totaldamage }}物理伤害，优先选择英雄。该目标随后会受到持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。蓄力：派克扔出他的鱼叉，对命中的第一个敌人造成{{ totaldamage }}物理伤害并将其拉拽向他。该目标随后会受到持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。如果派克成功命中一名敌方英雄，或是引导并未成功完成，则会返还{{ manarefund*100 }}%法力消耗。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "PykeQ.png",
      "key": "Q"
    },
    {
      "name": "幽潭潜行",
      "description": "派克进入伪装状态并获得显著的移动速度加成，此移速加成会逐渐衰减。",
      "tooltip": "派克获得伪装和在{{ camoduration }}秒里持续衰减的{{ movespeed }}%移动速度。",
      "cooldown": "14/13/12/11/10",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "PykeW.png",
      "key": "W"
    },
    {
      "name": "魅影浪洄",
      "description": "派克突进并在身后留下一个幻影。幻影将会返回派克身边，并晕眩沿途的敌人。",
      "tooltip": "派克进行冲刺，并在他的身后留下一个很快回到他身边的溺毙魅影。魅影造成{{ stunduration }}秒晕眩并对英雄造成{{ totaldamage }}物理伤害。",
      "cooldown": "15/14/13/12/11",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "PykeE.png",
      "key": "E"
    },
    {
      "name": "涌泉之恨",
      "description": "派克进行闪烁以处决低血量的敌人，并且如果处决成功还能再次施放此技能并为一名助攻的友军提供额外的金币。",
      "tooltip": "派克对X型范围内的所有敌方英雄发起一次打击，闪烁并处决低于{{ rdamage }}生命值的目标们。生命值在处决阈值之上的英雄和非英雄单位会转而受到相当于{{ reduceddamage*100 }}%该数额({{ reduceddamagefinal }})的物理伤害。当有敌方英雄死在X范围内时，派克可以在{{ rrecastduration }}秒内免费地再次施放这个技能。如果派克处决了该英雄，则最后一个提供协助的友方英雄也将获得击杀金币。如果他没有处决该英雄，他将仍然获得击杀金币，就如同他已完成击杀一样。",
      "cooldown": "100/85/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 3,
      "image": "PykeR.png",
      "key": "R"
    }
  ]
}