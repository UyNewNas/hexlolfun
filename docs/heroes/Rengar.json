  "passive": {
    "name": "无形掠食者",
    "description": "在草丛时，雷恩加尔的普通攻击会让他跳跃至目标敌人身边。雷恩加尔在每次施放技能时会生成残暴值。在满残暴值时，他的下一个技能会得到强化。击杀敌方英雄会在雷恩加尔的骨齿项链上新增战利品奖励，从而提供额外攻击力。",
    "image": "Rengar_P.png"
  },
  "spells": [
    {
      "name": "残忍无情",
      "description": "雷恩加尔的下次攻击会蛮横地戳刺他的目标来造成额外伤害。残暴效果：造成更多伤害，并且他会获得攻击速度加成。",
      "tooltip": "雷恩加尔的下两次攻击获得{{ asbonus }}%攻击速度。第一次攻击造成{{ qtotaldamage }}物理伤害。满层残暴值：第一次攻击造成{{ empoweredqtotaldamage }}物理伤害并为雷恩加尔提供持续{{ asduration }}秒的{{ empoweredqas }}攻击速度。",
      "cooldown": "0.25",
      "cost": "0",
      "costType": "产生1点残暴值",
      "range": "450",
      "maxrank": 5,
      "image": "RengarQ.png",
      "key": "Q"
    },
    {
      "name": "战争咆哮",
      "description": "雷恩加尔发出一声战争咆哮，对敌人造成伤害并基于近期受到的伤害回复生命值。残暴效果：额外移除控制效果。",
      "tooltip": "雷恩加尔进行咆哮，对附近的敌人们造成{{ totaldamage }}魔法伤害并回复生命值，相当于他在前{{ healingwindow }}秒受到的{{ damagepercentagehealed }}%伤害。满层残暴值：造成{{ totaldamageempowered }}魔法伤害并且还会净化雷恩加尔身上的控制效果。",
      "cooldown": "0.25",
      "cost": "0",
      "costType": "产生1点残暴值",
      "range": "450",
      "maxrank": 5,
      "image": "RengarW.png",
      "key": "W"
    },
    {
      "name": "套索打击",
      "description": "雷恩加尔扔出一个套索，套索在命中第一个敌人后，会暂时降低这名敌人的移动速度。残暴效果：对目标造成禁锢效果。",
      "tooltip": "雷恩加尔扔出一个套索，对命中的第一个敌人造成{{ totaldamage }}物理伤害，以及持续{{ ccduration }}秒的显形和{{ slowamount }}%减速。满层残暴值：造成{{ totalempowereddamage }}物理伤害和{{ ccduration }}秒禁锢。",
      "cooldown": "0.25",
      "cost": "0",
      "costType": "产生1点残暴值",
      "range": "1000",
      "maxrank": 5,
      "image": "RengarE.png",
      "key": "E"
    },
    {
      "name": "狩猎律动",
      "description": "雷恩加尔激活他的掠食者本能，伪装自身并感知附近极大范围内的距他最近的敌方英雄。在狩猎律动期间，他会获得移动速度加成，他的下次攻击将使他即使不在草丛内也可以进行跳跃，并且会减少目标的护甲。",
      "tooltip": "被动：雷恩加尔在伪装状态下也能进行跃击。主动：雷恩加尔获得{{ stealthms }}%移动速度和相距最近的敌方英雄周围一个小区域内的真实视野，持续{{ stealthduration }}秒。在{{ fadetime }}秒后，雷恩加尔变为伪装状态并且不需要在草丛中就能进行跃击。跃击该相距最近的敌方英雄时会造成{{ bonusdamage }}物理伤害，击碎{{ armorshred }}护甲达{{ armorshredduration }}秒，并结束这个技能。",
      "cooldown": "100/90/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "2500/3000/3500",
      "maxrank": 3,
      "image": "RengarR.png",
      "key": "R"
    }
  ]
}