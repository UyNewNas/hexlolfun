  "passive": {
    "name": "锐切",
    "description": "在使用一次技能后，霞的下几次普攻将命中沿途的所有敌人，并各落下一根羽毛。",
    "image": "XayahPassive.png"
  },
  "spells": [
    {
      "name": "双刃",
      "description": "霞扔出两把具有伤害的匕首，并掉落可供她召回的羽毛。",
      "tooltip": "霞扔出两把匕首，每把造成{{ totaldamage }}物理伤害，然后留下两支羽毛。每把匕首对首个目标之后的后续目标造成{{ multihitdamage }}伤害。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "35",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "XayahQ.png",
      "key": "Q"
    },
    {
      "name": "致死羽衣",
      "description": "霞创造一道刀刃风暴，来提升她的攻击速度和伤害，并且如果她的攻击命中了敌人，还会提升她的移动速度。",
      "tooltip": "霞创造一道持续{{ wattackspeedduration }}秒的羽刃风暴，来为她提供{{ wattackspeedamount }}%攻击速度并使她的攻击发射一支造成{{ bonusdamagepercent }}%伤害的次级羽刃。如果次级羽刃命中了一名敌方英雄，那么她自身会获得{{ wmovespeedamount }}%移动速度，持续{{ wmovespeedduration }}秒。如果洛在附近，那么他也会获得这个技能的效果，但他只会在霞命中了一个目标时获得移动速度。",
      "cooldown": "18/17/16/15/14",
      "cost": "60/55/50/45/40",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "XayahW.png",
      "key": "W"
    },
    {
      "name": "倒钩",
      "description": "霞唤回她之前掉落的所有羽毛，对敌人造成伤害和禁锢效果。",
      "tooltip": "霞将所有羽毛召回至她的位置，每支造成{{ featherdamage }}物理伤害提升。如果有{{ featherthreshold }}支或以上的羽毛命中了一名敌人，那么该敌人就会被禁锢{{ rootduration }}秒。",
      "cooldown": "12/11/10/9/8",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "2000",
      "maxrank": 5,
      "image": "XayahE.png",
      "key": "E"
    },
    {
      "name": "暴风羽刃",
      "description": "霞跳向空中，变为不可被选取状态，然后扔出一排匕首，同时掉落可供她召回的羽毛。",
      "tooltip": "霞跃向空中，变为不可被选取状态，持续1.5秒。然后她会从天降下匕首雨，造成{{ damage }}物理伤害并留下一连串的羽毛。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 3,
      "image": "XayahR.png",
      "key": "R"
    }
  ]
