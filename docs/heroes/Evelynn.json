  "passive": {
    "name": "恶魔魅影",
    "description": "在非战斗状态下，伊芙琳进入【恶魔魅影】。【恶魔魅影】会在伊芙琳生命值较低时治疗她，并在6级后为她提供【伪装】。",
    "image": "Evelynn_Passive.png"
  },
  "spells": [
    {
      "name": "憎恨之刺",
      "description": "伊芙琳用鞭子进行抽击，对命中的第一个敌方单位造成伤害。随后，伊芙琳可以朝附近的敌人发出一列尖刺，可发射若干次。",
      "tooltip": "伊芙琳用她的鞭子进行打击，对命中的第一个敌人造成{{ missiledamage }}魔法伤害并使伊芙琳对该敌人发起的下3次攻击或技能造成额外的{{ totalbonusdamage }}魔法伤害。伊芙琳可以再次施放这个技能至多{{ qstackcount }}次。再次施放：伊芙琳发射尖刺穿过相距最近的敌人，并对命中的所有敌人造成{{ missiledamage }}魔法伤害。",
      "cooldown": "4",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "EvelynnQ.png",
      "key": "Q"
    },
    {
      "name": "引诱",
      "description": "伊芙琳诅咒她的目标，并使她在一段延时后的下次攻击或技能对目标施加魅惑和魔抗击碎效果。",
      "tooltip": "伊芙琳标记一名英雄或野怪5秒。如果伊芙琳用一次攻击或技能命中了该目标，那么她将抹除该印记，返还它的法力消耗，并使目标减速{{ slowamount*100 }}%，持续{{ slowduration }}秒。如果标记持续了至少2.5秒，那么将它抹除还会有额外效果：对抗英雄时：将其魅惑{{ charmduration }}秒并削减{{ mrshred*100 }}%魔法抗性，持续{{ shredduration }}秒。对抗野怪时：将其魅惑{{ monstercharm }}秒并造成{{ monsterdamagetotaltooltip }}魔法伤害。",
      "cooldown": "15/14/13/12/11",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "1200/1300/1400/1500/1600",
      "maxrank": 5,
      "image": "EvelynnW.png",
      "key": "W"
    },
    {
      "name": "鞭笞",
      "description": "伊芙琳鞭笞她的目标，并造成伤害。她随后会获得短暂持续的移动速度加成。",
      "tooltip": "伊芙琳鞭打一名敌人，造成{{ basedamage }}加上{{ percenthealthbasetooltip }}最大生命值的魔法伤害。伊芙琳获得{{ speedamount*100 }}%移动速度，持续{{ speedduration }}秒。进入恶魔魅影会刷新这个技能的冷却时间并使其获得强化。当这个技能获得强化后，伊芙琳会冲刺向目标并对她的目标和沿途的所有敌人造成{{ empowereddamage }}加上{{ percenthealthempoweredtooltip }}最大生命值的魔法伤害。",
      "cooldown": "8",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "210",
      "maxrank": 5,
      "image": "EvelynnE.png",
      "key": "E"
    },
    {
      "name": "最终抚慰",
      "description": "伊芙琳短暂进入不可被选取状态并大肆残杀她面前区域内的敌人，然后向后位移一大段距离。",
      "tooltip": "伊芙琳释放她的恶魔能量，造成大量伤害、变为不可被选取状态并向后传送。她造成{{ damage }}魔法伤害，如果敌人低于30%生命值，则此伤害提升至{{ critdamage }}。在施放的同时，给【恶魔魅影】设置一个为期1.25秒的冷却时间。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "EvelynnR.png",
      "key": "R"
    }
  ]
