  "passive": {
    "name": "锥刺甲壳",
    "description": "拉莫斯获得额外攻击力，受益于他的护甲和魔法抗性。",
    "image": "Armordillo_ScavengeArmor.png"
  },
  "spells": [
    {
      "name": "动力冲刺",
      "description": "拉莫斯缩成球状冲击目标，造成魔法伤害并减速目标。",
      "tooltip": "拉莫斯蜷缩为球状，获得{{ minimummovespeed }}移动速度，并在{{ rollduration }}秒里持续加速至{{ maximummovespeed }}移动速度。拉莫斯会在与一名敌人碰撞后停下，对附近的敌人们造成{{ powerballdamage }}魔法伤害、击退、和持续{{ slowduration }}秒的{{ slowpercent }}%减速。再次施放：拉莫斯提前结束这个技能。",
      "cooldown": "12/10.5/9/7.5/6",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "PowerBall.png",
      "key": "Q"
    },
    {
      "name": "尖刺防御",
      "description": "拉莫斯进入防御状态，极大提高护甲值和魔法抗性，并回敬伤害给那些攻击他的敌人。",
      "tooltip": "拉莫斯进入持续{{ buffduration }}秒的防御姿态，获得{{ bonusarmortooltip }}护甲和{{ bonusmrtooltip }}魔法抗性并对攻击他的敌人们造成{{ returndamagecalc }}魔法伤害。再次施放：拉莫斯提前结束这个技能。",
      "cooldown": "7",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "300",
      "maxrank": 5,
      "image": "DefensiveBallCurl.png",
      "key": "W"
    },
    {
      "name": "狂乱嘲讽",
      "description": "拉莫斯嘲讽一个敌方英雄或野怪，强制目标鲁莽地攻击自己。",
      "tooltip": "拉莫斯嘲讽一个敌方英雄或野怪，强制目标鲁莽地攻击自己{{ duration }}秒。会对野怪造成{{ monsterdamagecalc }}魔法伤害。",
      "cooldown": "12",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "325",
      "maxrank": 5,
      "image": "PuncturingTaunt.png",
      "key": "E"
    },
    {
      "name": "冲天猛撞",
      "description": "拉莫斯跃到空中然后朝着目标位置猛撞，对敌人造成魔法伤害和减速效果。如果拉莫斯在【动力冲刺】状态下施放，那么拉莫斯还会击飞区域中心的敌人们。",
      "tooltip": "拉莫斯跃到空中然后猛撞进一个区域，造成{{ initialdamagecalc }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。如果在动力冲刺状态下施放，那么还会对区域中心的敌人们造成额外的{{ spell.powerball:powerballdamage }}魔法伤害和{{ knockupduration }}秒击飞。拉莫斯随后在{{ buffduration }}秒里持续在区域内引发共{{ numberofpulses }}道余震，重复减速效果。这个技能的距离会从拉莫斯的移动速度中获得提升。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "Tremors2.png",
      "key": "R"
    }
  ]
