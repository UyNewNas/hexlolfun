  "passive": {
    "name": "震荡猛击",
    "description": "布隆的普通攻击会对目标施加震荡猛击效果。一旦施加了第一层震荡猛击，友军的普通攻击也会对目标叠加震荡猛击。在效果到达4层后，目标会被击晕并受到魔法伤害。在接下来的数秒里，布隆和友军无法再次对目标叠加震荡猛击的层数，但布隆的攻击会对目标造成额外魔法伤害。",
    "image": "Braum_Passive.png"
  },
  "spells": [
    {
      "name": "寒冬之咬",
      "description": "布隆驱动盾牌中的冷冻冰块，对敌人造成魔法伤害和减速效果。对目标施加一层震荡猛击。",
      "tooltip": "布隆驱动盾牌里的冷冻冰块，对命中的第一个敌人造成{{ totaldamage }}魔法伤害和在{{ slowduration }}秒里持续衰减的{{ initialslow }}%减速。施加一层震荡猛击。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "45/50/55/60/65",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "BraumQ.png",
      "key": "Q"
    },
    {
      "name": "挺身而出",
      "description": "布隆跃向目标友军英雄或小兵。在抵达时，布隆和友军会暂时获得护甲和魔法抗性加成。",
      "tooltip": "布隆跃向一名友方英雄或小兵。在抵达时，布隆为目标提供持续{{ duration }}秒的{{ grantedallyarmor }}护甲和{{ grantedallymr }}魔法抗性。布隆为他自己提供相同持续时间的{{ grantedbraumarmor }}护甲和{{ grantedbraummr }}魔法抗性。",
      "cooldown": "12/11/10/9/8",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "BraumW.png",
      "key": "W"
    },
    {
      "name": "坚不可摧",
      "description": "布隆朝一个方向举起盾牌，持续数秒，可以拦截所有敌方飞行道具，并将它们摧毁，但自身要承受这些飞行道具的伤害。在举盾后，布隆将使承受的第一次攻击变得完全无效，并降低来自这个方向的所有后续攻击的伤害。",
      "tooltip": "布隆将他的盾牌举起{{ shieldholdduration }}秒，拦截来自选定方向的所有敌方弹体，使其命中布隆然后被摧毁。布隆格挡的首个弹体不会造成伤害，并且后续弹体造成的伤害降低{{ shieldfacingdramount }}%。布隆在举盾时获得{{ movespeedpercent }}%移动速度。",
      "cooldown": "16/14/12/10/8",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 5,
      "image": "BraumE.png",
      "key": "E"
    },
    {
      "name": "冰川裂隙",
      "description": "布隆敲击地面，击飞他身边和前方一条直线上的所有敌人。此外，还会在前方的直线上留下一条能让敌方减速的裂隙。",
      "tooltip": "布隆猛砸地面并向前发出一道裂隙，来击飞沿途和布隆身边的敌人，并造成{{ totaldamage }}魔法伤害。被命中的第一个目标会被击飞{{ minknockup }}到{{ maxknockup }}秒，取决于其与布隆之间的距离。被命中的其他目标也会被击飞{{ minknockup }}秒。裂隙还会留下一个持续{{ slowzoneduration }}秒的地带，可使敌人减速{{ movespeedmod }}%。",
      "cooldown": "130/115/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1250",
      "maxrank": 3,
      "image": "BraumRWrapper.png",
      "key": "R"
    }
  ]
}