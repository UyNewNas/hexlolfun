  "passive": {
    "name": "符文之刃",
    "description": "锐雯的技能会为她的剑刃充能，并且她的普通攻击会消耗充能来造成额外伤害。",
    "image": "RivenRunicBlades.png"
  },
  "spells": [
    {
      "name": "折翼之舞",
      "description": "锐雯斩出一套猛烈的剑式。在短时间内，这个技能最多可以重新激活3次，并且第三次会将周围的所有敌人击飞。",
      "tooltip": "锐雯向前冲刺，造成{{ firstslashdamage }}物理伤害。她可以再次施放这个技能两次。第一次再次施放和初始效果相同，但第二次会有不同的效果：再次施放: 锐雯向前跃起并猛劈，对附近的敌人们造成{{ firstslashdamage }}物理伤害和0.75秒击飞。",
      "cooldown": "13",
      "cost": "0",
      "costType": "无消耗",
      "range": "275",
      "maxrank": 5,
      "image": "RivenTriCleave.png",
      "key": "Q"
    },
    {
      "name": "震魂怒吼",
      "description": "锐雯爆发斗气，对附近敌人造成伤害和晕眩效果。",
      "tooltip": "锐雯的剑爆发出一股符文能量，造成{{ totaldamage }}物理伤害和{{ stunduration }}秒晕眩。",
      "cooldown": "11/10/9/8/7",
      "cost": "0",
      "costType": "无消耗",
      "range": "260",
      "maxrank": 5,
      "image": "RivenMartyr.png",
      "key": "W"
    },
    {
      "name": "勇往直前",
      "description": "锐雯向前冲锋一小段距离，并格挡即将到来的伤害。",
      "tooltip": "锐雯快速冲刺并获得持续1.5秒的{{ totalshield }}护盾值。",
      "cooldown": "10/9/8/7/6",
      "cost": "0",
      "costType": "无消耗",
      "range": "250",
      "maxrank": 5,
      "image": "RivenFeint.png",
      "key": "E"
    },
    {
      "name": "放逐之锋",
      "description": "锐雯将能量灌入她那残破不堪的武器中，使攻击力和攻击范围都得到提高。在这段时间里，她还能使用一次疾风斩（一次强大的远程打击）。",
      "tooltip": "锐雯的武器激荡着灵体能量，为她提供{{ bonusad }}攻击力，并且伤害型技能和攻击获得距离提升，持续{{ duration }}秒。在此期间，她可以进行再次施放。再次施放：锐雯发射一道疾风斩来造成{{ mindamage }}到{{ maxdamage }}物理伤害，基于目标们的已损失生命值。",
      "cooldown": "120/90/60",
      "cost": "0",
      "costType": "无消耗",
      "range": "200",
      "maxrank": 3,
      "image": "RivenFengShuiEngine.png",
      "key": "R"
    }
  ]
}