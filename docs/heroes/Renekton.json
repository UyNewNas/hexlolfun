  "passive": {
    "name": "怒之领域",
    "description": "雷克顿的攻击会产生【怒气】，在它的生命值较低时产生更多【怒气】。【怒气】可以强化他的基础技能，使它们具有额外效果。",
    "image": "Renekton_Passive.png"
  },
  "spells": [
    {
      "name": "巨鳄狂袭",
      "description": "雷克顿挥动他的武器，对周围所有目标造成中等水平物理伤害，并根据造成的伤害来治疗自己。如果他有50点以上怒气，那么此技能的伤害和治疗效果会得到提升。",
      "tooltip": "雷克顿挥舞他的战刃，造成{{ basicdamage }}物理伤害，此外，每命中一个非英雄单位就会回复{{ nonchamphealing }}生命值，每命中一位英雄就会回复{{ champhealing }}。他每命中一个非英雄单位还会生成{{ minionfurygain }}怒气，且每命中一位英雄生成{{ championfurygain }}怒气。怒气加成：伤害提升至{{ empdamage }}物理伤害并且对非英雄单位的治疗效果提升至{{ empnonchamphealing }}生命值，对英雄的治疗效果提升至{{ empchamphealing }}生命值。不会生成任何怒气。",
      "cooldown": "7",
      "cost": "0",
      "costType": "无消耗",
      "range": "325",
      "maxrank": 5,
      "image": "RenektonCleave.png",
      "key": "Q"
    },
    {
      "name": "冷酷捕猎",
      "description": "雷克顿两次挥击目标，对其造成中等水平物理伤害并晕眩其0.75秒。如果雷克顿有50点以上怒气，他会三次挥击目标，摧毁目标身上的伤害护盾，对其造成高额物理伤害，并晕眩其1.5秒。",
      "tooltip": "雷克顿的下次攻击会进行两次打击，造成{{ stunduration }}秒晕眩和共计{{ basictotaldamage }}物理伤害。命中一名英雄会生成额外的{{ bonusfuryvschamps }}怒气。怒气加成：雷克顿转而进行三次打击，摧毁护盾然后造成{{ emptotaldamage }}物理伤害和{{ enragedstunduration }}秒晕眩。不会生成任何怒气。",
      "cooldown": "16/14/12/10/8",
      "cost": "0",
      "costType": "无消耗",
      "range": "300",
      "maxrank": 5,
      "image": "RenektonPreExecute.png",
      "key": "W"
    },
    {
      "name": "横冲直撞",
      "description": "雷克顿冲向前方，对沿途的敌人造成伤害。如果雷克顿有50点以上怒气，就会造成额外伤害，并减少沿途敌人的护甲值。",
      "tooltip": "雷克顿进行冲刺，造成{{ basicdamage }}物理伤害。他每命中一名非英雄单位就会生成{{ minionragegeneration }}怒气，每命中一位英雄就会生成{{ championragegeneration }}怒气。如果至少命中一名敌人，那么雷克顿就能在{{ dicetimer }}秒内再次施放这个技能一次。怒气加成：再次施放的冲刺转而造成{{ empdamage }}物理伤害并造成持续{{ shredtimer }}秒的{{ enragedarmorshred }}%护甲削减。不会生成怒气。",
      "cooldown": "16/14.5/13/11.5/10",
      "cost": "0",
      "costType": "无消耗",
      "range": "450",
      "maxrank": 5,
      "image": "RenektonSliceAndDice.png",
      "key": "E"
    },
    {
      "name": "终极统治",
      "description": "雷克顿转换为暴君形态，获得额外生命值，并对周围敌人造成伤害。此形态的雷克顿定时获得怒气。",
      "tooltip": "雷克顿用黑暗能量笼罩自身，持续{{ buffduration }}秒，获得{{ healthgain }}最大生命值和{{ furyoncast }}怒气。在激活时，他每秒造成{{ totaldamagepersecond }}魔法伤害并获得{{ furypersecond }}怒气。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "20",
      "maxrank": 3,
      "image": "RenektonReignOfTheTyrant.png",
      "key": "R"
    }
  ]
}