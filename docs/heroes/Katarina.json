  "passive": {
    "name": "贪婪",
    "description": "每当一名在过去3秒被卡特琳娜所伤害的敌方英雄阵亡时，卡特琳娜的技能的冷却时间就会显著减少。如果卡特琳娜拾起一把匕首，她会用它来斩击附近的所有敌人以造成魔法伤害。",
    "image": "Katarina_Passive.png"
  },
  "spells": [
    {
      "name": "弹射之刃",
      "description": "卡特琳娜朝敌人扔出一把匕首，匕首会弹射到附近敌人身上，然后落到地面上。",
      "tooltip": "卡特琳娜投掷一把匕首，造成{{ totaldamage }}魔法伤害给目标及附近的{{ maxbounces }}个敌人。匕首随后会弹落到主要目标身后的地面上。",
      "cooldown": "11/10/9/8/7",
      "cost": "0",
      "costType": "无消耗",
      "range": "625",
      "maxrank": 5,
      "image": "KatarinaQ.png",
      "key": "Q"
    },
    {
      "name": "伺机待发",
      "description": "卡特琳娜获得爆发性的移动速度加成，同时投掷一把匕首到她正上方的空中。",
      "tooltip": "卡特琳娜扔出一把匕首至空中并获得在{{ e2 }}秒里持续衰减的{{ e4 }}%移动速度。",
      "cooldown": "15/14/13/12/11",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "KatarinaW.png",
      "key": "W"
    },
    {
      "name": "瞬步",
      "description": "卡特琳娜立刻闪烁到目标处，如果目标是敌人，则她会对目标造成伤害，否则会对距她最近的敌人造成伤害。",
      "tooltip": "卡特琳娜在眨眼间闪烁到目标友军、敌人、或匕首处。如果目标是敌人，那么卡特琳娜会造成{{ totaldamage }}魔法伤害——如果是其它情况，那么她会对范围内距她最近的敌人造成伤害。拾取一把匕首将使这个技能的冷却时间缩短{{ daggercooldownreduction }}秒({{ tooltipdaggerreduction }})。卡特琳娜可以闪烁到目标附近的任一位置。",
      "cooldown": "12/11/10/9/8",
      "cost": "0",
      "costType": "无消耗",
      "range": "725",
      "maxrank": 5,
      "image": "KatarinaEWrapper.png",
      "key": "E"
    },
    {
      "name": "死亡莲华",
      "description": "卡特琳娜化身为一道剑刃飓风，以无与伦比的速度对周围最多三个敌方英雄造成巨量魔法伤害。",
      "tooltip": "卡特琳娜化身为一道剑刃飓风，快速用一连串匕首攻击相距最近的3名敌方英雄。每把匕首造成{{ damagecalc }}魔法伤害和{{ addamagecalc }}物理伤害，并施加持续{{ grievousduration }}秒的{{ grievousamount*100 }}%重伤效果。在{{ duration }}秒里持续对每个敌方英雄造成的总伤害：{{ totaldamagecalc }}魔法伤害和{{ totaladdamagecalc }}物理伤害。",
      "cooldown": "75/60/45",
      "cost": "0",
      "costType": "无消耗",
      "range": "550",
      "maxrank": 3,
      "image": "KatarinaR.png",
      "key": "R"
    }
  ]
}