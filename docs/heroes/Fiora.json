  "passive": {
    "name": "决斗之舞",
    "description": "菲奥娜已在这名英雄身上发现了一处破绽。如果她命中了这处破绽，她就会回复生命值并获得移动速度。",
    "image": "Fiora_P.png"
  },
  "spells": [
    {
      "name": "破空斩",
      "description": "菲奥娜向一个方向冲刺，并刺击一个附近的敌人，造成物理伤害并施加攻击特效。",
      "tooltip": "菲奥娜向一个方向进行突刺并刺击相距最近的敌人、守卫或建筑物，造成{{ totaldamage }}物理伤害。这次打击会优先攻击破绽和将被此打击击杀的单位。如果菲奥娜命中了一个敌人，那么这个技能的冷却时间就会缩短{{ cdrefundpercent*100 }}%。",
      "cooldown": "13/11.25/9.5/7.75/6",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "FioraQ.png",
      "key": "Q"
    },
    {
      "name": "劳伦特心眼刀",
      "description": "菲奥娜在短时间内对所有即将到来的伤害和限制效果进行招架，然后朝着一个方向进行刺击。这个刺击会减速命中的第一个敌方英雄，如果菲奥娜用这个技能格挡掉一个禁锢类效果，那么刺击会造成晕眩效果而非减速效果。",
      "tooltip": "菲奥娜招架即将到来的所有伤害、限制效果和有害效果，持续{{ parryduration }}秒，然后刺击。刺击会对命中的第一个敌方英雄造成{{ stabdamage }}魔法伤害，并减速目标的{{ msslowpercent*-100 }}%移动速度和{{ attackslowpercent*-100 }}%攻击速度，持续{{ ccduration }}秒。如果菲奥娜招架掉一个定身效果，那么被刺击的敌人会被晕眩而非减速。",
      "cooldown": "24/22/20/18/16",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "FioraW.png",
      "key": "W"
    },
    {
      "name": "夺命连刺",
      "description": "菲奥娜的下两次攻击将获得攻击速度加成。第一次攻击会使目标减速，而第二次攻击必定会产生暴击。",
      "tooltip": "菲奥娜的下两次攻击获得{{ aspercent*100 }}%攻击速度。第一次攻击造成持续{{ slowduration }}秒的{{ slowpercent*-100 }}%减速。第二次攻击必定会产生暴击，造成{{ attacktwopercenttad*100 }}%伤害。",
      "cooldown": "11/10/9/8/7",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "425",
      "maxrank": 5,
      "image": "FioraE.png",
      "key": "E"
    },
    {
      "name": "无双挑战",
      "description": "菲奥娜显示出一个敌方英雄身上的所有四处破绽，并在目标附近时获得移动速度加成。如果菲奥娜命中了所有四处破绽，或者目标在死前至少被命中了一处破绽，那么菲奥娜和范围内的友军就会在接下来的几秒里持续获得治疗效果。",
      "tooltip": "被动：决斗之舞移动速度加成提升至{{ percentms*100 }}%。主动：菲奥娜标出一名英雄身上的全部四处破绽，最多可造成{{ spell.fiorapassive:rdamagetotal }}最大生命值的真实伤害并在目标附近时获得决斗之舞的移动速度加成。如果菲奥娜在{{ markduration }}秒内命中了全部四处破绽，或者在目标死前至少命中一处，那么菲奥娜就会为周围的友方英雄每秒回复{{ healpersecondcalc }}生命值，持续{{ healduration }}秒。",
      "cooldown": "110/90/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 3,
      "image": "FioraR.png",
      "key": "R"
    }
  ]
