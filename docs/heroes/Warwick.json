  "passive": {
    "name": "血之饥渴",
    "description": "沃里克的普攻造成额外魔法伤害。如果沃里克的生命值低于50%，那么他会获得等额的治疗效果。如果他的生命值低于25%，则治疗效果提升至三倍。",
    "image": "WarwickP.png"
  },
  "spells": [
    {
      "name": "野兽之口",
      "description": "沃里克向前猛扑并撕咬他的目标，造成基于目标最大生命值的伤害，并造成基于实际伤害值的治疗效果。",
      "tooltip": "秒放：沃里克向前猛扑并撕咬，造成{{ basebitedamage }}外加{{ targetpercenthpdamage }}%最大生命值的魔法伤害和{{ e3 }}%实际伤害值的治疗效果。蓄力：沃里克猛扑并用它的狼嘴紧咬目标，并跃到目标身后。在紧咬目标时，沃里克会跟随目标的所有移动。在释放他的蓄力后，他会造成等额伤害和治疗效果。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "80/85/90/95/100",
      "costType": " {{ abilityresourcename }}",
      "range": "365",
      "maxrank": 5,
      "image": "WarwickQ.png",
      "key": "Q"
    },
    {
      "name": "鲜血追猎",
      "description": "沃里克感知生命值在50%以下的敌人，在朝着这些敌人移动时会获得移动速度加成，并在攻击这些敌人时会获得攻速加成。当这些敌人的生命值在25%以下时，他会狂暴并让这些加成提升至三倍。",
      "tooltip": "被动：沃里克可以感知生命值低于50%的英雄，朝着其移动时获得{{ passivemsbonus }}%移动速度。对生命值低于50%的敌人施放技能和攻击可获得{{ passiveasbonus }}%攻击速度。这些加成在对抗低于25%生命值的敌人们时会提升200%。主动：沃里克可以暂时感知到所有敌人，并在对抗相距最近的那个英雄时获得这个技能的被动效果，持续8秒，无论该目标有多少生命值。如果没有感知到任何英雄，该技能的冷却时间缩短30%。",
      "cooldown": "80/70/60/50/40",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "4000",
      "maxrank": 5,
      "image": "WarwickW.png",
      "key": "W"
    },
    {
      "name": "远祖嗥叫",
      "description": "沃里克获得持续2.5秒的伤害减免效果。在效果结束时，或者重新激活技能时，沃里克会嗥叫，使附近的敌人因恐惧而逃跑1秒。",
      "tooltip": "沃里克获得持续2.5秒的{{ e1 }}%伤害减免。在它结束后，沃里克会发出嗥叫，恐惧附近的敌人{{ e3 }}秒。沃里克可以再次施放来提前结束这个技能。",
      "cooldown": "15/14/13/12/11",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "375",
      "maxrank": 5,
      "image": "WarwickE.png",
      "key": "E"
    },
    {
      "name": "无尽束缚",
      "description": "沃里克朝一个方向跳跃（跳跃距离可从他的移动速度加成中获益），将他所碰撞到的第一个敌方英雄压制1.5秒。",
      "tooltip": "沃里克跳跃一大段距离(随他的移动速度增长)，并压制碰撞到的第一个敌方英雄{{ rduration }}秒并且自身处在引导状态。在此期间他持续攻击该英雄3次，造成{{ damagecumulative }}魔法伤害。沃里克在引导期间会获得100%实际伤害值的治疗效果。",
      "cooldown": "110/90/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "WarwickR.png",
      "key": "R"
    }
  ]
}