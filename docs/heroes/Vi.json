  "passive": {
    "name": "爆裂护盾",
    "description": "蔚持续为护盾充能。护盾会在蔚的技能命中一名敌人后激活。",
    "image": "ViPassive.png"
  },
  "spells": [
    {
      "name": "强能冲拳",
      "description": "蔚对她的拳套进行充能，并且释放一记粉碎性的勾拳，同时带着她前冲。被她命中的敌人会被击退，同时会被施加一层爆弹重拳的效果。",
      "tooltip": "开始蓄力：蔚开始积蓄一次强力的冲拳，自身减速{{ selfslow }}%。释放：蔚向前冲刺，基于蓄力时间造成{{ totaldamage }}到{{ maxdamagetooltip }}物理伤害，并对命中的所有敌人施加爆弹重拳。蔚会在与一名敌方英雄碰撞时停下，并将其击退。",
      "cooldown": "12/10.5/9/7.5/6",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "250",
      "maxrank": 5,
      "image": "ViQ.png",
      "key": "Q"
    },
    {
      "name": "爆弹重拳",
      "description": "蔚的出拳会打破她对手的护甲，造成额外伤害并为她提供额外攻击速度。",
      "tooltip": "被动：对相同目标的每第三次攻击会造成额外{{ totaldamagetooltip }}最大生命值的物理伤害，移除目标{{ shredamount }}%护甲，并为蔚提供{{ attackspeed }}%攻击速度，持续{{ sharedbuffsduration }}秒。它还可缩短爆裂护盾{{ spell.vipassive:cdreductionon3hit }}秒冷却时间。",
      "cooldown": "0",
      "cost": "0",
      "costType": "被动",
      "range": "750",
      "maxrank": 5,
      "image": "ViW.png",
      "key": "W"
    },
    {
      "name": "透体之劲",
      "description": "蔚的下次攻击会爆裂，并透过她的目标，对目标身后的敌人造成伤害。",
      "tooltip": "蔚的下次攻击对目标和目标后方的敌人造成{{ totaldamagetooltip }}物理伤害。这个技能有2层充能({{ ammorechargetime }}秒充能时间)。",
      "cooldown": "1",
      "cost": "26/32/38/44/50",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "ViE.png",
      "key": "E"
    },
    {
      "name": "天霸横空烈轰",
      "description": "蔚撞向一名敌人，将途中的人击退到两边。当她接触到目标时，她会将目标击飞到空中，然后跳上去，将目标轰到地面上。",
      "tooltip": "蔚挑出一名敌方英雄，将其显形并不可阻挡地向其冲刺。在触碰到该英雄后，蔚会将其击飞{{ rstunduration }}秒，并造成{{ damage }}物理伤害。任何与蔚产生碰撞的敌人都会受到伤害、被震开并晕眩{{ secondarytargetstunduration }}秒。",
      "cooldown": "140/115/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 3,
      "image": "ViR.png",
      "key": "R"
    }
