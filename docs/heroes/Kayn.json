  "passive": {
    "name": "暗裔魔镰",
    "description": "凯隐使用的是一把上古神兵，并且一直都在与附在武器上的暗裔灵体拉亚斯特为了身体的控制权而战斗着。要么暗裔杀手将获胜，要么凯隐将统御拉亚斯特并变为影流刺客。暗裔杀手：治疗自身，数额相当于一部分对敌方英雄造成的技能伤害值。影流刺客：在与敌方英雄作战的最初几秒里，造成额外伤害。",
    "image": "Kayn_Passive_Primary.png"
  },
  "spells": [
    {
      "name": "巨镰横扫",
      "description": "凯隐向前冲刺并打击附近的敌人。冲刺和打击都会造成伤害。",
      "tooltip": "凯隐冲刺然后旋转他的镰刀，对他途经的敌人们造成{{ totaldamage }}物理伤害，然后对附近的敌人们再次造成等额伤害。暗裔杀手：转而造成{{ darkinflatdamage }}外加{{ darkinpercentdamage }}最大生命值的物理伤害。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "350",
      "maxrank": 5,
      "image": "KaynQ.png",
      "key": "Q"
    },
    {
      "name": "利刃纵贯",
      "description": "凯隐伤害并减速一条直线上的敌人。",
      "tooltip": "凯隐向上挥出他的镰刀，造成{{ totaldamage }}物理伤害和在{{ e5 }}秒里持续衰减的{{ e3 }}%减速。影流刺客：凯隐可在使用这个技能时移动并提升这个技能的距离。暗裔杀手：还会击飞命中的敌人{{ e2 }}秒。",
      "cooldown": "13/12/11/10/9",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "KaynW.png",
      "key": "W"
    },
    {
      "name": "掠影步",
      "description": "凯隐可以穿越地形。",
      "tooltip": "凯隐获得{{ e1 }}%移动速度，变为【幽灵】状态，并能在地形中移动，持续{{ e2 }}秒。当他第一次进入地形时，他会治疗自身{{ totalhealing }}生命值。被定身或是在地形外连续停留{{ e3 }}秒，就会提前结束这个技能。影流刺客：获得{{ e5 }}%移动速度，免疫减速并使冷却时间缩短至{{ assassincdreduction }}秒。",
      "cooldown": "21/19/17/15/13",
      "cost": "90",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "KaynE.png",
      "key": "E"
    },
    {
      "name": "裂舍影",
      "description": "凯隐隐藏在敌方身体内，在他破膛而出时造成巨量伤害。",
      "tooltip": "被动：被凯隐造成过伤害的英雄们会被标记3.15秒。凯隐侵入一名被标记的敌方英雄，变为不可被选取状态。在{{ infestduration }}秒后或再次施放后，凯隐会破体而出，对该敌方英雄造成{{ damage }}物理伤害。影流刺客：提升这个技能的距离，凯隐离开时的移动距离，并在离开时刷新暗裔魔镰的冷却时间。暗裔杀手：转而造成{{ slayerdamage }}最大生命值的物理伤害并回复{{ healvalue }}生命值({{ slayerhealpercent*100 }}%伤害数额)。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 3,
      "image": "KaynR.png",
      "key": "R"
    }
  ]
