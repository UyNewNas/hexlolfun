  "passive": {
    "name": "暗影之刃",
    "description": "每过数秒，魔腾的下次攻击就会对附近敌人造成额外物理伤害，并治疗自己。魔腾的普通攻击会减少该技能的冷却时间。",
    "image": "Nocturne_UmbraBlades.png"
  },
  "spells": [
    {
      "name": "梦魇之径",
      "description": "魔腾扔出一把暗影之刃，对敌人造成伤害并留下幽灵影径，并使受到伤害的敌方英雄也留下幽灵影径。在影径上时，魔腾无视任何碰撞体积，并且他的移动速度和攻击力也会得到提高。",
      "tooltip": "魔腾扔出一把暗影之刃，造成{{ totaldamage }}物理伤害并留下一条持续{{ trailduration }}秒的影径。被击中的敌方英雄们也会留下一条影径。在影径上移动时，魔腾处于幽灵状态并获得{{ movespeed }}%移动速度和{{ bonustrailad }}攻击力。",
      "cooldown": "8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "1125",
      "maxrank": 5,
      "image": "NocturneDuskbringer.png",
      "key": "Q"
    },
    {
      "name": "黑暗庇护",
      "description": "魔腾强化他的刀刃，被动地提升他的攻击速度。主动激活此技能，将使魔腾融入黑影中，同时产生一个能够抵挡掉敌方单个技能的魔法护盾。若抵挡成功，则被动的攻速加成效果将提升至两倍。",
      "tooltip": "被动：魔腾获得{{ activeas }}%攻击速度。主动：魔腾生成一个持续1.5秒的暗影屏障，来格挡下一个敌方技能。如果格挡掉一个技能，那么这个技能的被动效果提升至{{ activeas*2 }}%攻击速度，持续{{ doubleasduration }}秒。",
      "cooldown": "20/18/16/14/12",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "NocturneShroudofDarkness.png",
      "key": "W"
    },
    {
      "name": "无言恐惧",
      "description": "魔腾将梦魇植入目标的大脑之中，持续对目标造成伤害。并且如果在该技能持续时间结束后，目标仍未脱离该技能的范围，那么目标会被恐惧。",
      "tooltip": "被动：魔腾朝着被恐惧的敌人时会获得{{ tooltipfearms*100 }}%移动速度。主动：魔腾将一根梦魇灵链植入他的目标，在{{ leashduration }}秒里持续造成共{{ totaldamage }}魔法伤害。如果灵链一直未断裂，目标就会被恐惧{{ ccduration }}秒。",
      "cooldown": "15/14/13/12/11",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "425",
      "maxrank": 5,
      "image": "NocturneUnspeakableHorror.png",
      "key": "E"
    },
    {
      "name": "鬼影重重",
      "description": "魔腾减少所有敌方英雄的视野范围，并在此过程中移除敌方英雄的友军的视野。魔腾能够借机突进到附近的敌方英雄身边。",
      "tooltip": "魔腾使地图变暗，降低所有敌方英雄的视野半径并移除其友方视野，持续{{ paranoiaduration }}秒。魔腾能够在持续期间再次施放这个技能，来突进到一名敌方英雄的身边并造成{{ damage }}物理伤害。",
      "cooldown": "140/115/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "2500/3250/4000",
      "maxrank": 3,
      "image": "NocturneParanoia.png",
      "key": "R"
    }
  ]
