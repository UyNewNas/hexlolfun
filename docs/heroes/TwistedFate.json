  },
  "spells": [
    {
      "name": "万能牌",
      "description": "崔斯特扔出三张卡牌，卡牌会对沿途的每个敌方单位造成伤害。",
      "tooltip": "崔斯特掷出三张牌，各造成{{ totaldamage }}魔法伤害。",
      "cooldown": "6/5.75/5.5/5.25/5",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "10000",
      "maxrank": 5,
      "image": "WildCards.png",
      "key": "Q"
    },
    {
      "name": "选牌",
      "description": "崔斯特挑选魔法卡牌，用于下次攻击，并附加额外效果。",
      "tooltip": "崔斯特开始洗牌，允许他再次施放来从3张牌中锁定一张，并且强化他的下次攻击。蓝牌造成{{ bluedamage }}魔法伤害并回复{{ e6 }}法力。红牌对附近的敌人造成{{ reddamage }}魔法伤害和持续2.5秒的{{ e2 }}%减速。金牌造成{{ golddamage }}魔法伤害和{{ e3 }}秒晕眩。",
      "cooldown": "6",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "200",
      "maxrank": 5,
      "image": "PickACard.png",
      "key": "W"
    },
    {
      "name": "卡牌骗术",
      "description": "崔斯特每四次攻击附加一次额外伤害。另外，崔斯特的攻击速度得到被动提升。",
      "tooltip": "被动：崔斯特获得{{ attackspeedbonus }}%攻击速度并且每第4次攻击造成额外的{{ bonusdamage }}魔法伤害。",
      "cooldown": "0",
      "cost": "0",
      "costType": "被动",
      "range": "0",
      "maxrank": 5,
      "image": "CardmasterStack.png",
      "key": "E"
    },
    {
      "name": "命运",
      "description": "崔斯特为他的敌人算卜命运，短时间内显示所有敌方英雄的位置，并可使用传送，让他在引导1.5秒后传送至目标位置。",
      "tooltip": "崔斯特专注于他的卡牌，提供地图上所有敌方英雄的真实视野，持续{{ e1 }}秒，并允许他再次施放。再次施放：崔斯特传送到{{ e4 }}码以内的任何地方。",
      "cooldown": "170/140/110",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "5500",
      "maxrank": 3,
      "image": "Destiny.png",
