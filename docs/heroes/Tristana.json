  "passive": {
    "name": "瞄准",
    "description": "崔丝塔娜的射程随等级提升。",
    "image": "Tristana_Passive.png"
  },
  "spells": [
    {
      "name": "急速射击",
      "description": "崔丝塔娜急速射击，短时间内提升攻击速度。",
      "tooltip": "崔丝塔娜开始全自动射击，获得持续{{ buffduration }}秒的{{ attackspeedmod*100 }}%攻击速度。",
      "cooldown": "20/19/18/17/16",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "TristanaQ.png",
      "key": "Q"
    },
    {
      "name": "火箭跳跃",
      "description": "崔丝塔娜朝地面开火，跳跃至目标区域，落地造成伤害并减速附近敌人一小段时间。",
      "tooltip": "崔丝塔娜将自己推送出去，在着陆时造成{{ landingdamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowmod*-100 }}%减速。参与击杀后，或者满层爆炸火花爆炸后，会重置这个技能的冷却时间。",
      "cooldown": "22/20/18/16/14",
      "cost": "30/35/40/45/50",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "TristanaW.png",
      "key": "W"
    },
    {
      "name": "爆炸火花",
      "description": "当崔丝塔娜杀死一个单位，加农炮弹会炸裂伤害周围的敌人。可通过主动施放这个技能来将一颗炸弹放置在目标身上，炸弹会在短时间内或被崔丝塔娜攻击数次后爆炸，爆炸时对目标及其附近的敌人造成伤害。",
      "tooltip": "被动：崔丝塔娜的攻击在击杀敌人时会对周围敌人造成{{ passivedamage }}魔法伤害。主动：崔丝塔娜将一颗炸弹附着在一名敌人或防御塔上，来在{{ activeduration }}秒后对周围敌人造成{{ activedamage }}物理伤害。崔丝塔娜对带着炸弹的目标进行的每次攻击和技能都会使这个伤害提升{{ activeperstackamp*100 }}%(最多4层)。在{{ activemaxstacks }}层时，这个炸弹会立刻爆炸(最大值为{{ activemaxdamage }}物理伤害)。",
      "cooldown": "16/15.5/15/14.5/14",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "TristanaE.png",
      "key": "E"
    },
    {
      "name": "毁灭射击",
      "description": "崔丝塔娜装填巨型加农炮弹攻击目标单位，造成巨大伤害并击退目标。如果目标携带着【爆炸火花】的炸弹，那么该炸弹的爆炸半径翻倍。",
      "tooltip": "崔丝塔娜发射一颗大型加农炮弹，对目标造成{{ damagecalc }}魔法伤害，并对其与周围敌人们施加击退和{{ stunduration }}秒晕眩。",
      "cooldown": "100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 3,
      "image": "TristanaR.png",
      "key": "R"
    }
  ]
