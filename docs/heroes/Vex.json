  "passive": {
    "name": "终焉暮气",
    "description": "薇古丝周期性地获得强化，使她的下一个基础技能可以恐惧敌人并打断冲刺。当一名附近的敌人冲刺时，薇古丝会施加一个标记，该标记可被消耗来造成额外伤害，并缩短她强化状态的冷却时间。",
    "image": "Icons_Vex_Passive.png"
  },
  "spells": [
    {
      "name": "寒心波云",
      "description": "发射一个可在飞行途中提速的伤害型飞弹。",
      "tooltip": "薇古丝发射一道迷雾波，造成{{ qdamagecalc }}魔法伤害。在短暂的延迟后，迷雾波会变得更小更快。在命中敌人时会消耗其身上的暮气效果。",
      "cooldown": "8/7/6/5/4",
      "cost": "45/50/55/60/65",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 5,
      "image": "VexQ.png",
      "key": "Q"
    },
    {
      "name": "生人勿近",
      "description": "获得一个护盾并伤害附近的敌人们。",
      "tooltip": "薇古丝获得持续{{ shieldduration }}秒的{{ shieldcalc }}护盾值并且放射一道冲击波来造成{{ wdamagecalc }}魔法伤害。在命中敌人时会消耗其身上的暮气效果。",
      "cooldown": "16/15/14/13/12",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "475",
      "maxrank": 5,
      "image": "VexW.png",
      "key": "W"
    },
    {
      "name": "溟濛渐染",
      "description": "召唤一个伤害性的减速地带，来对敌人们施加【暮气】效果。",
      "tooltip": "薇古丝命令【黑影】飞向一个区域，在其飞行时提升其体型。在抵达后，它会造成{{ edamagecalc }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。用这个技能击杀一个敌人，会使终焉暮气的冷却时间缩短{{ gloomcdnonchamptooltip*100 }}%。对命中的敌人们施加暮气效果。",
      "cooldown": "13",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "VexE.png",
      "key": "E"
    },
    {
      "name": "愁煞",
      "description": "射出一个飞弹来标记一名敌方英雄。再次施放可冲刺至该英雄处并造成伤害。",
      "tooltip": "黑影激动地向前涌动，造成{{ spell.vexr:rdamagecalc }}魔法伤害并将命中的第一位敌方英雄标记4秒。再次施放：冲刺至被标记的英雄，在抵达时造成{{ spell.vexr:recastdamagecalc }}魔法伤害。如果被标记的英雄在受到此技能伤害后的{{ spell.vexr:takedownwindow }}秒内阵亡，那么这个技能的冷却时间会暂时重置。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "2000/2500/3000",
      "maxrank": 3,
      "image": "VexR.png",
      "key": "R"
    }
