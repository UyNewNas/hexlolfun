  "passive": {
    "name": "沙场豪情",
    "description": "瑟提的普通攻击会交替使用左重拳和右重拳。右重拳稍微强一些和快一些。瑟提还很讨厌失败，因此会基于他的已损失生命值而获得额外的生命回复。",
    "image": "Sett_P.png"
  },
  "spells": [
    {
      "name": "屈人之威",
      "description": "瑟提的下两次攻击将基于目标的最大生命值来造成额外伤害。瑟提也会在朝着敌方英雄移动时获得移动速度加成。",
      "tooltip": "瑟提手痒难耐，渴望打架，在朝着敌方英雄移动时获得{{ msamount*100 }}%移动速度，持续{{ msduration }}秒。此外，瑟提的下两次攻击造成额外的{{ basedamage }}外加{{ maxhealthdamagecalc }}最大生命值的物理伤害。",
      "cooldown": "9/8/7/6/5",
      "cost": "0",
      "costType": "无消耗",
      "range": "0",
      "maxrank": 5,
      "image": "SettQ.png",
      "key": "Q"
    },
    {
      "name": "蓄意轰拳",
      "description": "瑟提会被动地将他受到的伤害储存为豪意。在施放时，瑟提会释放所有已储存的豪意来提供一层护盾并且重击一个区域，在区域中心造成真实伤害并在区域边缘造成物理伤害。",
      "tooltip": "被动：瑟提将受到的{{ damagestored*100 }}%伤害储存为豪意，储量上限为{{ maxgrit }}。豪意在停止受到伤害的{{ adrenalinestoragewindow }}秒后会快速衰减。主动：瑟提将所有豪意迸发出来，获得{{ shieldconversion*100 }}%迸发豪意值的护盾值，护盾值会在{{ shieldmaxduration }}秒里持续衰减。瑟提随后会轰出一记重拳，对中央的所有敌人造成{{ damagecalc }}外加{{ damageconversion }}迸发豪意值的真实伤害(最大伤害为{{ f1 }})。不在中央的敌人会受到物理伤害作为替代。",
      "cooldown": "18/16.5/15/13.5/12",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "SettW.png",
      "key": "W"
    },
    {
      "name": "强手裂颅",
      "description": "瑟提将他两侧的所有敌人猛撞到一起，对他们造成伤害和晕眩效果。如果敌人仅位于他的一侧，那么他们只会被减速而不会被晕眩。",
      "tooltip": "瑟提将他两侧的敌人猛撞到一起，造成{{ damagecalc }}物理伤害并使他们减速{{ slowamount*100 }}%，持续{{ slowduration }}秒。如果瑟提在每侧都至少擒住了一名敌人，那么所有敌人还会被晕眩{{ stunduration }}秒。",
      "cooldown": "16/14.5/13/11.5/10",
      "cost": "0",
      "costType": "无消耗",
      "range": "490",
      "maxrank": 5,
      "image": "SettE.png",
      "key": "E"
    },
    {
      "name": "叹为观止",
      "description": "瑟提将一名敌方英雄带到空中，然后将其猛砸到地上，在该英雄着陆后对其附近的所有敌人造成伤害和减速效果。",
      "tooltip": "瑟提擒住一名敌方英雄，并在扛着该英雄前行时将其压制，然后将该英雄猛摔到地上，对着陆点附近的所有敌人造成{{ damagecalc }}外加{{ maxhealthdamage*100 }}%被擒英雄的额外生命值的物理伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。敌人离瑟提着陆的位置越远，受到的伤害越低。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "400",
      "maxrank": 3,
      "image": "SettR.png",
      "key": "R"
    }
  ]
}