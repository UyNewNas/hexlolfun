  "passive": {
    "name": "游击队军备",
    "description": "如果提莫在短时间内静止站立且不受任何伤害，就会进入无定期的隐形状态。如果提莫在草丛中，他就能在移动的同时进入并保持隐形状态。离开隐形状态后，提莫会获得“出奇制胜”的增益效果，提升攻击速度，持续3秒。",
    "image": "TeemoPassive.png"
  },
  "spells": [
    {
      "name": "致盲吹箭",
      "description": "用一团强力的毒液来侵蚀一名敌人的视野，对目标单位造成伤害并使目标致盲一段时间。",
      "tooltip": "提莫发射一根吹箭，对目标造成{{ blindduration }}秒致盲和{{ calculateddamage }}魔法伤害。",
      "cooldown": "7",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "680",
      "maxrank": 5,
      "image": "TeemoQ.png",
      "key": "Q"
    },
    {
      "name": "小莫快跑",
      "description": "提莫动如脱兔，提升移动速度，直到被敌方英雄或防御塔击中为止。提莫可以通过冲刺来获得额外移动速度，且短时间内不会因被击中而使加速效果中止。",
      "tooltip": "被动：提莫获得{{ passivemovespeedbonus*100 }}%移动速度，前提是在最近{{ passivecooldownondamagetaken }}秒内未受到来自敌方英雄或防御塔的伤害。主动：提莫急速奔跑，获得持续{{ activemovespeedbuffduration }}秒的{{ activemovespeedbonus*100 }}%移动速度，在被攻击时也不会移除。",
      "cooldown": "14",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "TeemoW.png",
      "key": "W"
    },
    {
      "name": "毒性射击",
      "description": "提莫每次攻击附带毒液伤害%i:OnHit% 攻击特效，造成持续性伤害，持续4秒。",
      "tooltip": "被动：提莫的攻击会施加剧毒%i:OnHit% 攻击特效，造成额外的{{ impactcalculateddamage }}魔法伤害外加在{{ poisonduration }}秒里持续造成共{{ totaldotdamage }}魔法伤害。",
      "cooldown": "0",
      "cost": "0",
      "costType": "被动",
      "range": "680",
      "maxrank": 5,
      "image": "TeemoE.png",
      "key": "E"
    },
    {
      "name": "种蘑菇",
      "description": "提莫投掷一个可爆炸的毒性陷阱，需要消耗提莫背包里的一个蘑菇。陷阱会在被敌方踩中时爆炸，释放出一团毒云，对附近的敌人造成减速效果和持续伤害。如果提莫把一个蘑菇扔到另一个蘑菇上，那么这个蘑菇会进行弹跳，获得额外的距离。",
      "tooltip": "提莫投掷一个蘑菇陷阱，它会在被敌方踩中时爆炸。陷阱造成持续{{ debuffduration }}秒的{{ slowamount }}%减速并在此期间持续造成共{{ totaldamage }}魔法伤害。敌人会被显形相同的时长 。陷阱持续{{ mushroomduration }}分钟并且处于潜行状态。一个蘑菇在被扔到另一个蘑菇上时，会先弹跳然后着陆到它的位置。这个技能有{{ maxammo }}层充能({{ ammorechargetime }}秒充能时间)。",
      "cooldown": "0.25",
      "cost": "75/55/35",
      "costType": " {{ abilityresourcename }}",
      "range": "600/750/900",
      "maxrank": 3,
      "image": "TeemoR.png",
      "key": "R"
    }
  ]
