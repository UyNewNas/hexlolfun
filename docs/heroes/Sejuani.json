  "passive": {
    "name": "北地之怒",
    "description": "在脱离战斗后，瑟庄妮会获得冰霜护甲，冰川护甲可提供护甲、魔法抗性和免疫减速。当瑟庄妮受到伤害后，冰霜护甲会存留一小段时间。瑟庄妮可以伤害一名被晕眩的敌人来击碎它，从而造成巨量魔法伤害。",
    "image": "Sejuani_passive.png"
  },
  "spells": [
    {
      "name": "极寒突袭",
      "description": "瑟庄妮向前冲锋，将敌人击飞至空中。冲锋会在命中一名敌方英雄后停止。",
      "tooltip": "瑟庄妮冲锋，对敌人造成{{ totaldamagetooltip }}魔法伤害并击飞敌人{{ e4 }}秒。冲锋会在命中一名敌方英雄后停止。",
      "cooldown": "18/16.5/15/13.5/12",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "SejuaniQ.png",
      "key": "Q"
    },
    {
      "name": "凛冬之怒",
      "description": "瑟庄妮两次挥舞她的链枷，造成伤害、减速敌人并施加霜冻层数。",
      "tooltip": "瑟庄妮挥击她的链枷，造成{{ firsthitdamagetooltip }}物理伤害并击退小兵和野怪。然后她会再次挥击，造成{{ secondhitdamagetooltip }}物理伤害并暂时减速目标。两段挥击都会施加永冻效果。",
      "cooldown": "9/8/7/6/5",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "SejuaniW.png",
      "key": "W"
    },
    {
      "name": "永冻领域",
      "description": "瑟庄妮冻结并晕眩一名叠满了霜冻层数的敌方英雄。",
      "tooltip": "被动：附近近战友方英雄的攻击会对英雄和野怪施加一层效果。主动：瑟庄妮对带有4层此效果的目标敌人造成{{ totaldamage }}魔法伤害并使其晕眩{{ e1 }}秒。",
      "cooldown": "1.5",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "560",
      "maxrank": 5,
      "image": "SejuaniE.png",
      "key": "E"
    },
    {
      "name": "极冰寒狱",
      "description": "瑟庄妮投出她的套索来冻结并击晕命中的第一名敌方英雄，并创造一次冰风暴来减速其它敌人。",
      "tooltip": "瑟庄妮扔出她的极冰套索，晕眩并显形命中的第一个敌方英雄{{ e2 }}秒并造成{{ minordamagetooltip }}魔法伤害。如果套索飞行了至少25%的最大距离，那么它会晕眩并显形{{ e6 }}秒。它还会生成一团冰风暴来使目标附近的敌人减速{{ e4 }}%，持续{{ e3 }}秒。所有受影响的敌人都会受到{{ totaldamagetooltip }}魔法伤害。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1300",
      "maxrank": 3,
      "image": "SejuaniR.png",
      "key": "R"
    }
  ]
}