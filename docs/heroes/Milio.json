  "spells": [
    {
      "name": "火爆飞踢",
      "description": "踢出一团火球，这个火球可击退一名敌人。火球在击中敌人时会弹至目标身后，对落地范围内的所有敌人造成伤害和减速效果。",
      "tooltip": "米利欧踢出一团火球，这个火球会击退命中的第一个敌人。如果它命中了敌人，则会弹至目标身后并爆炸，对周围的敌人们造成{{ damage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamountpercent }}减速。用火爆飞踢命中至少一个敌方英雄时，会返还其{{ refundratio*100 }}%法力消耗。",
      "cooldown": "10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 5,
      "image": "MilioQ.png",
      "key": "Q"
    },
    {
      "name": "依依不舍",
      "description": "创造一个强化地带，为地带中的友军们提供治疗效果并提升攻击距离。地带会跟随距离施法点最近的那名友方英雄。",
      "tooltip": "米利欧创造一团炉火来跟随友方英雄们，持续{{ zoneduration }}秒。炉火附近的友方英雄们会在持续期间获得{{ rangepercent }}攻击距离并且持续回复共{{ healingovertime }}生命值。炉火还会每{{ healfrequencyseconds }}秒施加热情洋溢！。再次施放：改变炉火跟随的友方英雄。",
      "cooldown": "29/27/25/23/21",
      "cost": "90/100/110/120/130",
