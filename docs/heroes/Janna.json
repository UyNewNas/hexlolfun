  "passive": {
    "name": "顺风而行",
    "description": "迦娜的友军在朝她移动时获得移动速度。迦娜的普攻和【和风守护】会附带一部分额外移动速度的额外魔法伤害。",
    "image": "JannaP.png"
  },
  "spells": [
    {
      "name": "飓风呼啸",
      "description": "迦娜改变气压和温度，在目标区域召唤小型风暴，风暴体积随时间增大。她可以再次施放该技能来释放风暴。风暴会朝向施放方向飞行，对沿途的所有单位造成伤害和击飞效果。",
      "tooltip": "迦娜召唤一道在{{ maxduration }}秒里持续聚集的飓风，随后沿路猛刮出去。飓风对目标造成{{ minimumdamage }} - {{ maxdamage }}魔法伤害和{{ baseknockup }} - {{ maxknockup }}秒击飞。移动距离、伤害和击飞时长都基于飓风聚集的时长。迦娜可以再次施放来提前将飓风刮出去。",
      "cooldown": "14",
      "cost": "90/95/100/105/110",
      "costType": " {{ abilityresourcename }}",
      "range": "1075",
      "maxrank": 5,
      "image": "HowlingGale.png",
      "key": "Q"
    },
    {
      "name": "和风守护",
      "description": "迦娜召唤出一个空气元素灵体，来被动地提升她的移动速度，并使她能够穿越单位。她也可以主动激活这个技能，来对一个敌人造成伤害和减速效果。",
      "tooltip": "被动：迦娜获得{{ totalms }}移动速度并处在幽灵状态。主动：迦娜的风灵打击一名敌人，对其造成持续{{ slowduration }}秒的{{ totalslow }}减速和{{ totaldamage }} + {{ spell.tailwindself:bonusdamage }}魔法伤害。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "4294967295",
      "maxrank": 5,
      "image": "SowTheWind.png",
      "key": "W"
    },
    {
      "name": "风暴之眼",
      "description": "迦娜制造出一阵防御性的气旋，来为目标友军或防御塔吸收即将到来的伤害，并提高目标的攻击力。",
      "tooltip": "迦娜为一个友军或防御塔提供持续{{ shieldduration }}秒的{{ totalshield }}护盾值。在护盾存在时，该友军目标获得{{ totalad }}攻击力。迦娜在每次用一个技能使一名敌方英雄的移动速度受损时，会使这个冷却时间缩短{{ ecdrefundforcc*100 }}%。",
      "cooldown": "16/15/14/13/12",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "EyeOfTheStorm.png",
      "key": "E"
    },
    {
      "name": "复苏季风",
      "description": "迦娜召唤魔法风暴围绕自己，将敌人击退。在风暴平息后，当技能仍处在激活状态时，和风将治疗附近的友军。",
      "tooltip": "迦娜召唤一阵魔法季风，击退附近的敌人们然后在{{ e3 }}秒里持续治疗附近的友军共{{ totalheal }}生命值。移动或使用技能都会提前结束这阵季风。",
      "cooldown": "130/115/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "725",
      "maxrank": 3,
      "image": "ReapTheWhirlwind.png",
      "key": "R"
    }
  ]
}