  "passive": {
    "name": "巨像重击",
    "description": "每过若干秒，加里奥的下次普攻就能在小范围内造成额外魔法伤害。",
    "image": "Galio_Passive.png"
  },
  "spells": [
    {
      "name": "战争罡风",
      "description": "加里奥发射两道罡风，罡风在汇聚后会形成一团大型龙卷风，造成持续伤害。",
      "tooltip": "加里奥发射两道罡风，每道造成{{ qmissiledamage }}魔法伤害。当罡风汇聚时，它们会合成一股龙卷风，在{{ superqduration }}秒内持续造成相当于各敌人{{ percentsuperqdamagett }}%最大生命值的魔法伤害。",
      "cooldown": "11/10/9/8/7",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 5,
      "image": "GalioQ.png",
      "key": "Q"
    },
    {
      "name": "杜朗护盾",
      "description": "加里奥在防御姿态下蓄力，同时移动速度减慢。在蓄力得以释放时，加里奥将嘲讽并伤害附近的敌人。",
      "tooltip": "被动：如果加里奥在{{ passiveshieldooctimer }}秒内没有受到伤害，那么他就会获得{{ totalpassiveshield }}魔法护盾。开始蓄力：加里奥使即将到来的魔法伤害降低{{ magicdamagereduction }}，使即将到来的物理伤害降低{{ physicaldamagereduction }}，并且自身减速{{ selfslowpercent }}%。释放：加里奥嘲讽附近的敌方英雄{{ ccdurationmin }}到{{ ccdurationmax }}秒，造成{{ mintotaldamage }}到{{ maxtotaldamage }}魔法伤害，并使伤害减免的持续时长刷新至{{ drlingerduration }}秒。嘲讽的持续时长、伤害和距离取决于他的蓄力时长。",
      "cooldown": "18/17/16/15/14",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "275",
      "maxrank": 5,
      "image": "GalioW.png",
      "key": "W"
    },
    {
      "name": "正义冲拳",
      "description": "加里奥将暂时后跳然后冲锋，击飞他遇到的第一个敌方英雄。",
      "tooltip": "加里奥挟着一股强劲向前猛冲，将命中的第一个敌方英雄击飞{{ knockupduration }}秒并造成{{ totaldamage }}魔法伤害。沿途的其它敌人将受到{{ pvedamage }}魔法伤害。加里奥的猛冲将在命中地形时停下。",
      "cooldown": "11/10/9/8/7",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "GalioE.png",
      "key": "E"
    },
    {
      "name": "英雄登场",
      "description": "加里奥将一名友军的当前位置作为他的着陆点，并为区域内的所有友军提供一个魔法护盾。在短暂的延迟后，加里奥会落到该位置上，然后击退附近的敌人。",
      "tooltip": "加里奥选定一个友方英雄的位置作为他的着陆位置，并为该区域的所有友方英雄提供杜朗护盾的被动护盾，护盾持续{{ temporarywshieldduration }}秒。然后加里奥会飞往他的着陆地带。当加里奥着陆时，他会造成{{ stundurationouter }}秒击飞和{{ totaldamage }}魔法伤害。",
      "cooldown": "180/160/140",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "4000/4750/5500",
      "maxrank": 3,
      "image": "GalioR.png",
      "key": "R"
    }
  ]
