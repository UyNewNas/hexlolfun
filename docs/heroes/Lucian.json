  "passive": {
    "name": "圣光银弹",
    "description": "每使用一个技能时，卢锡安的下次普通攻击都会连射2次。当卢锡安从另一位友军处获得治疗或护盾、或者有一名附近的敌方英雄被定身时，他的下2次普通攻击造成额外魔法伤害。",
    "image": "Lucian_Passive.png"
  },
  "spells": [
    {
      "name": "透体圣光",
      "description": "卢锡安射出一束穿透性的圣光穿过他的目标。",
      "tooltip": "卢锡安发射一束透体圣光，造成{{ totaldamage }}物理伤害。",
      "cooldown": "9/8/7/6/5",
      "cost": "48/56/64/72/80",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 5,
      "image": "LucianQ.png",
      "key": "Q"
    },
    {
      "name": "热诚烈弹",
      "description": "卢锡安发射一个会呈星形爆炸的飞弹，标记并暂时显形敌人。在卢锡安攻击被标记的敌人时，会获得移动速度加成。",
      "tooltip": "卢锡安发射一颗子弹，子弹会在到达射程终点或命中第一个敌人时爆炸，造成{{ totaldamage }}魔法伤害，暂时显形敌人们并将其标记6秒。当卢锡安或一名友方英雄对被标记的敌人造成伤害时，卢锡安会获得持续1秒的{{ e2 }}移动速度。友方英雄在触发这个效果时，将也会为卢锡安提供警惕效果。",
      "cooldown": "14/13/12/11/10",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "LucianW.png",
      "key": "W"
    },
    {
      "name": "冷酷追击",
      "description": "卢锡安冲刺一小段距离。【圣光银弹】的攻击会减少【冷酷追击】的冷却时间。",
      "tooltip": "卢锡安进行冲刺。当卢锡安用圣光银弹命中一名敌人时，这个技能的冷却时间会缩短{{ e1 }}秒(对英雄时缩短{{ e2 }}秒)。",
      "cooldown": "16/15.5/15/14.5/14",
      "cost": "32/24/16/8/0",
      "costType": " {{ abilityresourcename }}",
      "range": "445",
      "maxrank": 5,
      "image": "LucianE.png",
      "key": "E"
    },
    {
      "name": "圣枪洗礼",
      "description": "卢锡安的武器释放出大量的子弹。",
      "tooltip": "卢锡安朝一个方向快速发射{{ totalnumshots }}颗子弹，持续{{ duration }}秒或直到他再次施放。每颗子弹对命中的第一个敌人造成{{ damageperbullet }}物理伤害。在发射时，卢锡安可以使用冷酷追击。总伤害：{{ totaldamage }}物理伤害",
      "cooldown": "110/100/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1400",
      "maxrank": 3,
      "image": "LucianR.png",
      "key": "R"
    }
  ]
