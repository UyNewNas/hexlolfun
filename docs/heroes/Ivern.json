  "passive": {
    "name": "森林之友",
    "description": "艾翁无法攻击非史诗野怪，也无法被非史诗野怪攻击。艾翁可以在野怪营地创造神奇的小植被，小植被可以持续成长。当小植被完全成长后，艾翁就可以送走野怪来获得金币和经验。",
    "image": "IvernP.png"
  },
  "spells": [
    {
      "name": "根深敌固",
      "description": "艾翁召唤出一束荆棘，对命中的敌方单位造成伤害和禁锢效果。艾翁的友军可以突进到禁锢目标附近。",
      "tooltip": "艾翁召唤一束荆棘，造成{{ totaldamage }}魔法伤害并禁锢命中的第一个敌人{{ rootduration }}秒。友军在攻击禁锢的敌人时会冲刺到攻击距离处。再次施放：艾翁直接冲刺到这个被禁锢的敌人身边。命中非史诗级野怪会使根深敌固的冷却时间缩减50%。",
      "cooldown": "14/13/12/11/10",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1125",
      "maxrank": 5,
      "image": "IvernQ.png",
      "key": "Q"
    },
    {
      "name": "揠苗助攻",
      "description": "在草丛中，艾翁和他附近友军们的攻击将造成额外魔法伤害。艾翁可以激活这个技能来创造一块草丛。",
      "tooltip": "被动：在草丛中时或离开草丛后的{{ buffduration }}秒内，艾翁的攻击造成额外的{{ totaldamage }}魔法伤害。附近的友军们将获得持续{{ allybuffduration }}秒的此效果，其攻击会因此造成额外的{{ totalallydamage }}魔法伤害。主动：艾翁生成一片草丛，从而将该区域显形{{ revealduration }}秒。草丛会存留至艾翁的队伍失去它其中的视野，或至多至{{ maxbrushduration }}秒。",
      "cooldown": "0.5",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "1150",
      "maxrank": 5,
      "image": "IvernW.png",
      "key": "W"
    },
    {
      "name": "种豆得瓜",
      "description": "艾翁在一个友军身上放置一个护盾，护盾会在短暂延迟后爆炸，减速并伤害敌人。护盾值会在没有命中敌人时刷新。",
      "tooltip": "艾翁为一名友方英雄或小菊提供{{ totalshield }}护盾值。{{ shieldduration }}秒后，护盾会爆裂，对敌人们造成{{ totaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。如果在护盾存留时引爆种豆得瓜且没有命中任何敌方英雄，那么该友军将获得持续{{ shieldduration }}秒的{{ totalshield }}护盾值。",
      "cooldown": "11/10/9/8/7",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "IvernE.png",
      "key": "E"
    },
    {
      "name": "小菊！",
      "description": "艾翁召唤他的护卫好友小菊来与他并肩战斗。再次施放即可指挥小菊进行攻击或移动。",
      "tooltip": "艾翁召唤出他的护卫好友小菊跃入纷争，持续{{ daisyduration }}秒。小菊，猛击！：小菊对相同英雄或史诗级野怪的每第3次连续的攻击将发出一道冲击波，对命中的所有敌人造成 {{ totalshockwavedamage }}魔法伤害和{{ shockwaveccduration }}秒击飞。这个效果每{{ shockwavecd }}秒仅触发一次。再次施放：指示小菊进行攻击或移动。",
      "cooldown": "140/130/120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "IvernR.png",
      "key": "R"
    }
  ]
}