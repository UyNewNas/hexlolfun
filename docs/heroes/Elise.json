  "passive": {
    "name": "蜘蛛女皇",
    "description": "人类形态：每当伊莉丝的技能命中一名敌人时，就会有一只小蜘蛛准备就绪。蜘蛛形态：普攻造成额外魔法伤害并回复自身生命值。",
    "image": "ElisePassive.png"
  },
  "spells": [
    {
      "name": "神经毒素 / 剧毒之蜇",
      "description": "人类形态：根据目标的当前生命值来造成伤害。蜘蛛形态：戳刺目标，并根据目标已损失的生命值来造成伤害。",
      "tooltip": "人类形态：伊莉丝注入神经毒素，造成{{ basedamage }}外加 {{ humanpercenthealth }}当前生命值的魔法伤害。",
      "cooldown": "6",
      "cost": "80/85/90/95/100",
      "costType": " {{ abilityresourcename }}",
      "range": "615",
      "maxrank": 5,
      "image": "EliseHumanQ.png",
      "key": "Q"
    },
    {
      "name": "自爆蜘蛛 / 掠行狂暴",
      "description": "人类形态：召唤一个注满毒液的小蜘蛛，并在靠近目标时爆炸。蜘蛛形态：伊莉丝和她的小蜘蛛们获得攻击速度加成。",
      "tooltip": "人类形态：伊莉丝召唤一个爆炸蜘蛛朝着一个位置移动，并在它接近一名敌人或3秒后爆炸。这个蜘蛛造成{{ spell.elisehumanw:totaldamage }}魔法伤害。",
      "cooldown": "12",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "EliseHumanW.png",
      "key": "W"
    },
    {
      "name": "结茧 / 盘丝",
      "description": "人类形态：将命中的第一个敌人晕眩，如敌方未处于潜行状态则将其暴露在己方视野中。蜘蛛形态：伊莉丝和她的小蜘蛛们拉升至半空中，随后降落到目标敌人身上。在降落到目标敌方处时，伊莉丝的来自蜘蛛形态的额外伤害和治疗效果都会提升。",
      "tooltip": "人类形态：伊莉丝发射一颗蜘蛛茧，晕眩并使命中的第一个敌人显形{{ totalstunduration }}秒。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "1075",
      "maxrank": 5,
      "image": "EliseHumanE.png",
      "key": "E"
    },
    {
      "name": "蜘蛛形态",
      "description": "变成一只凶恶的蜘蛛，减少攻击距离，但获得移动速度加成、一套全新技能并且会有一群小蜘蛛来攻击她的敌人。",
      "tooltip": "人类形态：伊莉丝变形为一只令人生畏的蜘蛛，变成近战，获得一套蜘蛛形态技能的使用权并且还可以召唤出所有休眠中的小蜘蛛。",
      "cooldown": "3",
