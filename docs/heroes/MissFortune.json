  "passive": {
    "name": "厄运的眷顾",
    "description": "在对一个新目标进行普攻时，厄运小姐会造成额外物理伤害。",
    "image": "MissFortune_W.png"
  },
  "spells": [
    {
      "name": "一箭双雕",
      "description": "厄运小姐向敌人发射子弹，伤害他们以及他们后面的目标。两次攻击都可以施加【厄运的眷顾】。",
      "tooltip": "厄运小姐发射一次弹跳射击，对一个敌人及其身后的另一个敌人造成{{ totaldamagetooltip }}物理伤害。第二段射击可以暴击以造成{{ totaldamagecrit }}物理伤害。如果第一段射击击杀了目标，则第二段射击必定暴击。",
      "cooldown": "7/6/5/4/3",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "MissFortuneRicochetShot.png",
      "key": "Q"
    },
    {
      "name": "大步流星",
      "description": "厄运小姐在不被攻击时会被动获得移动速度加成。可以主动施放这个技能来获得短时间的攻击速度加成。在【大步流星】尚未冷却完毕时，【厄运的眷顾】可减少【大步流星】的剩余持续时间。",
      "tooltip": "被动：如果{{ passivebasemsooc }}秒内没有受到伤害，厄运小姐就会获得{{ passivebasems }}移动速度。再过{{ passivemaxmsextraooc }}秒后，这个加成会提升至{{ passivemaxms }}。主动：获得被动效果的全额移动速度加成并提供{{ activeas*100 }}%攻击速度，持续{{ activeduration }} 秒。厄运的眷顾会使这个技能的冷却时间缩短{{ lovetaprefund }}秒。",
      "cooldown": "12",
      "cost": "45",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "MissFortuneViciousStrikes.png",
      "key": "W"
    },
    {
      "name": "枪林弹雨",
      "description": "厄运小姐发射一阵弹雨来获得目标区域的视野，对敌人造成几波伤害，并减缓他们的移动速度。",
      "tooltip": "厄运小姐发射一阵弹雨，来显形一个区域，造成{{ totalslowamount }}减速和每秒{{ totaldamagepersecond }}魔法伤害，持续{{ baseduration }}秒(总共{{ totaldamage }}魔法伤害)。",
      "cooldown": "18/17/16/15/14",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "MissFortuneScattershot.png",
      "key": "E"
    },
    {
      "name": "弹幕时间",
      "description": "厄运小姐向她面前的锥形范围内引导一阵子弹风暴，对敌人造成大量伤害。这个技能的每波子弹都可以暴击。",
      "tooltip": "厄运小姐向前方锥形地带引导一阵弹幕，{{ basechannelduration }}秒内持续发射共{{ basewaves }}波子弹，每波弹幕造成{{ physicaldamageperwave }}物理伤害(总共{{ totalphysicaldamage }}物理伤害)。每一波均可触发暴击，造成%i:scaleCrit%{{ critdamageperwave }}物理伤害。",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "MissFortuneBulletTime.png",
      "key": "R"
    }
  ]
}