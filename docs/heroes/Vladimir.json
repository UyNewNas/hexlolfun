  "passive": {
    "name": "血色契约",
    "description": "每30生命值加成给予弗拉基米尔1法术强度，每1法术强度给予弗拉基米尔1.6生命值（不会自我循环叠加）。",
    "image": "VladimirP.png"
  },
  "spells": [
    {
      "name": "鲜血转换",
      "description": "弗拉基米尔从目标敌人身上偷取生命值。当弗拉基米尔的资源槽攒满后，鲜血转换将暂时获得增益，提升伤害和治疗效果。",
      "tooltip": "弗拉基米尔汲取目标的生命力，造成{{ basedamagetooltip }}魔法伤害并回复{{ basehealtooltip }}生命值。在使用2次这个技能后，弗拉基米尔会获得{{ movementspeedonq2 }}%移动速度，持续0.5秒，并强化这个技能的下一次使用，持续{{ e8 }}秒。这个技能的强化版会造成{{ empowereddamagetooltip }}魔法伤害并回复额外的{{ empoweredhealtooltip }}加上{{ empoweredhealpercenttooltip }}已损失生命值。",
      "cooldown": "9/7.9/6.8/5.7/4.6",
      "cost": "0",
      "costType": "无消耗",
      "range": "600",
      "maxrank": 5,
      "image": "VladimirQ.png",
      "key": "Q"
    },
    {
      "name": "血红之池",
      "description": "弗拉基米尔潜入血泊之中，变得不可被选取，持续2秒。血泊上的敌人被减速，同时弗拉基米尔会从他们身上吸取生命。",
      "tooltip": "弗拉基米尔化成一滩持续2秒的血池，获得{{ hasteboost*100 }}%持续衰减的移动速度，持续{{ hasteduration }}秒，并进入无法被选取和幽灵状态，同时使血池中的敌人减速{{ movespeedmod*-100 }}%。弗拉基米尔在期间会持续造成{{ totaldamage }}魔法伤害，并且每命中一个敌人就会为弗拉基米尔回复{{ totalheal }}生命值。",
      "cooldown": "28/25/22/19/16",
      "cost": "0",
      "costType": "%当前生命值",
      "range": "350",
      "maxrank": 5,
      "image": "VladimirSanguinePool.png",
      "key": "W"
    },
    {
      "name": "血之潮汐",
      "description": "弗拉基米尔消耗他的生命值来持续灌注一个蓄血库，蓄血库在释放时会对他身边的敌人造成伤害，但会被敌方单位所阻挡。",
      "tooltip": "开始蓄力：弗拉基米尔积攒一个蓄血库，至多消耗{{ chargehealthtooltip }}生命值。在攒满后，弗拉基米尔会被减速20%。释放：弗拉基米尔对附近的敌人释放一股血弹激流，基于蓄力时间造成{{ mindamagetooltip }}至{{ maxdamagetooltip }}魔法伤害。如果这个技能蓄力了至少1秒，那么它还会对目标造成持续0.5秒的{{ slowpercent }}%减速。",
      "cooldown": "13/11/9/7/5",
      "cost": "0",
      "costType": "%最大生命值({{ chargehealthtooltip }})",
      "range": "600",
      "maxrank": 5,
      "image": "VladimirE.png",
      "key": "E"
    },
    {
      "name": "血之瘟疫",
      "description": "弗拉基米尔令一片区域感染上剧毒瘟疫，增加受感染敌人所受的伤害。在几秒后，血之瘟疫会对被感染的敌人造成魔法伤害，并根据命中的敌方英雄数来治疗弗拉基米尔。",
      "tooltip": "弗拉基米尔生成一个剧毒瘟疫，使他的目标们所受伤害(所有来源)提高{{ e2 }}%，持续{{ e4 }}秒。在它消散后，弗拉基米尔对所有被感染的目标造成{{ damage }}魔法伤害。如果弗拉基米尔命中了一名敌方英雄，那么就会治疗自身{{ damage }}生命值，此后每命中一名敌方英雄会治疗自身额外的{{ secondaryhealingtooltip }}生命值。",
      "cooldown": "120",
      "cost": "0",
      "costType": "无消耗",
      "range": "625",
      "maxrank": 3,
      "image": "VladimirHemoplague.png",
      "key": "R"
    }
  ]
}