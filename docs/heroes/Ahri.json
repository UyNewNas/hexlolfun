  "passive": {
    "name": "摄魂夺魄",
    "description": "在击杀9个小兵或野怪后，阿狸会治疗自身。在参与击杀一名敌方英雄后，阿狸会以一个更高的治疗效果来治疗自身。",
    "image": "Ahri_SoulEater2.png"
  },
  "spells": [
    {
      "name": "欺诈宝珠",
      "description": "阿狸放出并收回她的宝珠，在放出时会沿途对敌人造成魔法伤害，在收回时则会沿途对敌人造成真实伤害。",
      "tooltip": "阿狸投出然后收回她的宝珠，在放出时会沿途对敌人造成{{ totaldamage }}魔法伤害，在收回时则会沿途对敌人造成{{ totaldamage }}真实伤害。",
      "cooldown": "7",
      "cost": "55/65/75/85/95",
      "costType": " {{ abilityresourcename }}",
      "range": "970",
      "maxrank": 5,
      "image": "AhriQ.png",
      "key": "Q"
    },
    {
      "name": "妖异狐火",
      "description": "阿狸获得短暂的爆发性移动速度加成，并放出三团狐火，锁定附近的敌人进行攻击。",
      "tooltip": "阿狸释放出3团狐火来追踪附近的敌人们并造成{{ singlefiredamage }}魔法伤害，第一团之后的狐火降低至{{ multifiredamage }}伤害。她还会获得在{{ movementspeedduration }}秒里持续衰减的{{ movementspeed*100 }}%移动速度。",
      "cooldown": "9/8/7/6/5",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "AhriW.png",
      "key": "W"
    },
    {
      "name": "魅惑妖术",
      "description": "阿狸献出红唇热吻，对命中的第一个敌人造成伤害并将目标魅惑，并且立刻终止目标的移动技能并使目标无恶意地走向她。",
      "tooltip": "阿狸献出红唇热吻，魅惑命中的首个敌人{{ charmduration }}秒并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "12",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "975",
      "maxrank": 5,
      "image": "AhriE.png",
      "key": "E"
    },
    {
      "name": "灵魄突袭",
      "description": "阿狸向前猛冲，并放出元气弹，对周围的数个敌人造成伤害。灵魄突袭在进入冷却阶段以前最多可被施放三次，并在参与击杀敌方英雄后获得额外的再次施放次数。",
      "tooltip": "阿狸灵活地突进，并对附近的敌人们发射{{ rmaxtargetspercast }}颗灵魄弹，优先选择英雄。这些灵魄弹每颗造成{{ rcalculateddamage }}魔法伤害。灵魄突袭可以在{{ rrecastwindow }}秒内再次施放至多2次。在此期间，用摄魂夺魄吞噬一名英雄的魂魄时，会使再次施放的窗口期至多延长至{{ pdurationextension }}秒并为灵魄突袭提供一次额外的再次施放(至多可储存至{{ rmaxcasts }}次)。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "450",
      "maxrank": 3,
      "image": "AhriR.png",
      "key": "R"
    }
  ]
}