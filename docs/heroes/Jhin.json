  "passive": {
    "name": "低语",
    "description": "烬的手枪，“低语”，是一台精密的设备，用来造成出色的伤害。它会以一个固定的频率发射子弹，并且只能装四颗子弹。烬会将黑暗魔法注入最后一颗子弹，来让它产生暴击并造成额外斩杀伤害。当“低语”暴击时，它会为烬提供一个爆发性的移动速度加成。",
    "image": "Jhin_P.png"
  },
  "spells": [
    {
      "name": "曼舞手雷",
      "description": "烬朝敌人扔出一颗迷人的手雷。它最多可以命中四个目标，并在每次击杀单位后获得伤害提升。",
      "tooltip": "烬扔出一颗手雷，手雷会造成{{ totaldamage }}物理伤害，然后弹跳到附近的一个还未被此技能命中的目标上。手雷最多可命中{{ tooltipmaxtargetshit }}个目标。手雷每击杀一个单位，它的后续弹跳伤害就会提升{{ percentamponkill*100 }}%。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "550",
      "maxrank": 5,
      "image": "JhinQ.png",
      "key": "Q"
    },
    {
      "name": "致命华彩",
      "description": "烬挥舞他的长枪，进行一次射程极远的射击。它可穿透小兵和野怪，但会在命中第一个敌方英雄后停下。如果目标最近踩到了烬的陷阱、承受过烬的伤害或被烬的队友给命中过，那么还会受到禁锢效果。",
      "tooltip": "烬进行一次远程射击，对命中的第一个英雄和沿途的其它敌人造成{{ totaldamage }}物理伤害。如果被【W致命华彩】命中的敌方英雄在前{{ spottingduration }}秒受到过来自烬的友方英雄的伤害，那么这个英雄还会被禁锢{{ rootduration }}秒，并为烬提供低语的移动速度加成。",
      "cooldown": "12",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "3000",
      "maxrank": 5,
      "image": "JhinW.png",
      "key": "W"
    },
    {
      "name": "万众倾倒",
      "description": "烬放置一个隐形的莲花陷阱，陷阱会在敌人经过时绽放。它会减速附近的敌人，然后爆炸为一阵飘零的花瓣并对敌人造成伤害。绚葬之华 - 当烬击杀掉一名敌方英雄时，一个莲花陷阱将在该英雄的尸体附近爆炸。",
      "tooltip": "被动：被烬击杀的英雄，将在其所在位置生成并引爆一个莲花陷阱。主动：烬放置一个持续{{ trapduration }}分钟的隐形莲花陷阱，陷阱会在被敌人踩中时生成一个区域，使区域内的敌人减速{{ trapslowamount*100 }}%。在{{ trapdetonationtime }}秒后，陷阱会爆炸，造成{{ totaldamage }}魔法伤害。这个技能有2层充能({{ ammorechargeratetooltip }}秒刷新时间)。",
      "cooldown": "2",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "JhinE.png",
      "key": "E"
    },
    {
      "name": "完美谢幕",
      "description": "烬开始引导，将“低语”切换成一个肩扛式重炮。它能够进行四次超级射击，超级射击的射程极远，可穿透小兵和野怪，但会在命中第一个敌方英雄后停下。“低语”会让命中的敌方单位怯场，也就是对它们造成减速效果和斩杀伤害。第四次射击是经过精心调制的，所以威力特别大，并且必定会造成暴击。",
      "tooltip": "烬架好武器，固定在原地，并获得4颗超级子弹。每颗超级子弹会在命中第一个敌方英雄时对其造成{{ damagecalc }}到{{ maxincreasecalc }}物理伤害（伤害会基于目标的已损失生命值而提升）并使其减速{{ slowpercent*100 }}%，持续{{ slowduration }}秒。第四颗子弹会暴击，造成{{ fourthshotmultiplier*100 }}%伤害。",
      "cooldown": "120/105/90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "JhinR.png",
      "key": "R"
    }
  ]
}