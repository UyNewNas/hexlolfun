  "passive": {
    "name": "黑暗起兮",
    "description": "莫德凯撒在对英雄或野怪打出3次攻击或技能之后获得一个强力的伤害光环和移动速度。",
    "image": "MordekaiserPassive.png"
  },
  "spells": [
    {
      "name": "破灭之锤",
      "description": "莫德凯撒用他的权杖猛砸地面，来对被击中的每个敌人造成伤害。在只命中单个敌人时，伤害会提升。",
      "tooltip": "莫德凯撒用夜陨猛砸地面，造成{{ qdamage }}魔法伤害，如果这个技能只命中了一个敌人，则伤害提升至{{ empowereddamagetooltip }}。",
      "cooldown": "8/7/6/5/4",
      "cost": "0",
      "costType": "无消耗",
      "range": "675",
      "maxrank": 5,
      "image": "MordekaiserQ.png",
      "key": "Q"
    },
    {
      "name": "不坏之身",
      "description": "莫德凯撒将他所造成和承受的伤害储存起来，以创造一个护盾。他可以消耗这个护盾来治疗自身。",
      "tooltip": "被动：莫德凯撒将他造成的{{ damageconversion*100 }}%伤害和他受到的{{ damagetakenconversion*100 }}%伤害储存起来。主动：莫德凯撒获得相当于已储存伤害值的护盾。他可以再次施放这个技能来回复相当于{{ healingpercent*100 }}%剩余护盾值的生命值。最小护盾值：{{ minhealthtooltip }}最大护盾值：{{ maxhealthtooltip }}",
      "cooldown": "12/11/10/9/8",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "MordekaiserW.png",
      "key": "W"
    },
    {
      "name": "断魂一扼",
      "description": "莫德凯撒拉拽一个区域内的所有敌人",
      "tooltip": "主动：将敌人朝他的方向拖拽，造成{{ totaldamage }}魔法伤害。",
      "cooldown": "18/16/14/12/10",
      "cost": "0",
      "costType": "无消耗",
      "range": "700",
      "maxrank": 5,
      "image": "MordekaiserE.png",
      "key": "E"
    },
    {
      "name": "轮回绝境",
      "description": "莫德凯撒将自身和他的目标拖拽到一个异次元空间，并偷取目标的一部分属性。如果他击杀了目标，那么会将这些属性保持到目标复活。",
      "tooltip": "莫德凯撒将自身和一个敌方英雄放逐至死者领域{{ spiritrealmduration }}秒，并在期间内偷取该英雄{{ statstealpercentscalar*100 }}%的核心属性。如果莫德凯撒在死者领域击杀了该敌人，那么他会吞噬目标的灵魂，保留他所偷取的属性，直到目标复活为止。",
      "cooldown": "140/120/100",
      "cost": "0",
      "costType": "无消耗",
      "range": "650",
      "maxrank": 3,
      "image": "MordekaiserR.png",
      "key": "R"
    }
  ]
}