  "passive": {
    "name": "海克斯科技军备",
    "description": "库奇普通攻击的一部分伤害会转化为真实伤害。",
    "image": "Corki_RapidReload.png"
  },
  "spells": [
    {
      "name": "磷光炸弹",
      "description": "库奇向目标区域发射一枚闪光弹，对范围内的敌人造成魔法伤害。这个技能还会暂时让目标区域附近的非隐形的单位和英雄现形。",
      "tooltip": "库奇抛射一颗炸弹，造成{{ totaldamage }}魔法伤害。该区域及命中的敌方英雄会被显形{{ revealduration }}秒。",
      "cooldown": "9/8.5/8/7.5/7",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 5,
      "image": "PhosphorusBomb.png",
      "key": "Q"
    },
    {
      "name": "瓦尔基里俯冲",
      "description": "库奇飞行一小段距离，同时投下炸弹。炸弹会制造出一条毁灭与死亡的路径，对留在路径中的敌人造成伤害。",
      "tooltip": "库奇飞越并烧焦一条路径，使其灼烧{{ trailduration }}秒。火焰中的敌人们在此期间至多受到{{ maximumdamage }}魔法伤害。",
      "cooldown": "20/18/16/14/12",
      "cost": "80/85/90/95/100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "CarpetBomb.png",
      "key": "W"
    },
    {
      "name": "格林机枪",
      "description": "库奇使用格林机枪扫射他面前锥形范围内的敌人，造成伤害并降低敌人护甲和魔法抗性。",
      "tooltip": "库奇朝他的前方发射加特林机枪，在{{ sprayduration }}秒里持续造成共{{ totaldamage }}物理伤害并至多击碎{{ shredmax*-1 }}护甲和魔法抗性。",
      "cooldown": "12",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "GGun.png",
      "key": "E"
    },
    {
      "name": "火箭轰击",
      "description": "库奇朝着他的目标地点发射一枚导弹。导弹会在命中第一个敌人后爆炸，并对目标周围单位造成伤害。库奇每隔一段时间就会挂载一枚导弹，最多挂载7枚。每发射2枚导弹后，下一次就会发射超级导弹，造成额外伤害。",
      "tooltip": "库奇发射一颗导弹，导弹会在命中第一个敌人时爆炸，对周围的敌人们造成{{ rsmallmissiledamage }}物理伤害。每第三颗导弹会转而造成{{ rbigmissiledamage }}物理伤害。这个技能至多有{{ maxammotooltip }}层充能。每次对英雄的普攻在命中时会使充能时间缩短{{ attackrefund }}秒。",
      "cooldown": "2",
      "cost": "35",
      "costType": " {{ abilityresourcename }}",
      "range": "1225",
      "maxrank": 3,
      "image": "MissileBarrage.png",
      "key": "R"
    }
  ]
}