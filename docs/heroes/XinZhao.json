  "passive": {
    "name": "果决",
    "description": "每第三次攻击造成额外伤害并治疗赵信自身。",
    "image": "XinZhaoReworkP.png"
  },
  "spells": [
    {
      "name": "三重爪击",
      "description": "赵信的下3次普攻将造成额外伤害并且第三次攻击将击飞目标。",
      "tooltip": "赵信的下3次普攻造成额外的{{ bonusdamage }}物理伤害并使他的其它技能的冷却时间缩短1秒。第3次普攻还会击飞目标{{ e2 }}秒。",
      "cooldown": "7/6.5/6/5.5/5",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "375",
      "maxrank": 5,
      "image": "XinZhaoQ.png",
      "key": "Q"
    },
    {
      "name": "风斩电刺",
      "description": "赵信用他的长枪斩击他的前方，之后将长枪向前刺击，并使被击中的敌人减速并对其施加被挑战印记。",
      "tooltip": "赵信进行斩击，造成{{ slashdamage }}物理伤害，随后进行刺击，造成{{ thrustdamage }}物理伤害。被这次刺击命中的敌人们会受到持续{{ totalslowduration }}秒的{{ e6 }}%减速。被这次刺击命中的英雄和大型野怪会被施加持续{{ markduration }}秒的被挑战标记并且如果不在潜行状态还会被显形。",
      "cooldown": "12/11/10/9/8",
      "cost": "60/55/50/45/40",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "XinZhaoW.png",
      "key": "W"
    },
    {
      "name": "无畏冲锋",
      "description": "赵信对一名敌人发起冲锋，获得攻击速度并对范围内的所有敌人造成伤害，并使他们暂时减速。以被挑战的敌人为目标时，这个技能的施放距离会获得提升。",
      "tooltip": "赵信对一名敌人发起冲锋，对附近的敌人们造成{{ chargedamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount }}%减速。赵信自身获得{{ f1 }}% (%i:scaleAS%%i:scaleAP%)攻击速度，持续{{ asduration }}秒。以被挑战的敌人为目标时，这个技能的施放距离会获得提升。",
      "cooldown": "11",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "XinZhaoE.png",
      "key": "E"
    },
    {
      "name": "新月护卫",
      "description": "赵信被动地挑战一名近期被他造成过伤害的敌人。在主动施放时，赵信对附近的敌人们造成基于其当前生命值的伤害，并击退未被挑战的目标们，且自身变得不会受到来自圆环之外的敌人所造成的伤害。",
      "tooltip": "被动：赵信会给他用攻击或无畏冲锋造成过伤害的最后一个英雄施加持续{{ markduration }}秒的被挑战标记。主动：赵信环绕自身释放一次横扫，造成{{ totaldamage }}外加{{ percentcurrenthealthdamage*100 }}%当前生命值的物理伤害并击退所有未被挑战的敌人们。 随后，赵信会免疫来自横扫范围外侧敌人的伤害，持续{{ missiledefensebaseduration }}秒。",
      "cooldown": "120/110/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 3,
      "image": "XinZhaoR.png",
      "key": "R"
    }
  ]
