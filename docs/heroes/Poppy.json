  "passive": {
    "name": "钢铁大使",
    "description": "波比扔出她的圆盾，圆盾会在命中目标后弹起。波比可以捡起圆盾来获得一个短暂的护盾效果。",
    "image": "Poppy_Passive.png"
  },
  "spells": [
    {
      "name": "圣锤猛击",
      "description": "波比挥舞她的铁锤，造成伤害并创造一个区域，这个区域会减速敌人并在一段时间后爆炸。",
      "tooltip": "波比猛砸地面，造成{{ basedamage }}外加{{ healthdamagepercent }}%最大生命值的物理伤害并使该地面变得不稳定。 不稳定区域会使敌人减速{{ slow_ }}%并在{{ delaybetweentwohits }}秒后喷发，再次造成{{ basedamage }}外加{{ healthdamagepercent }}%最大生命值的物理伤害。",
      "cooldown": "8/7/6/5/4",
      "cost": "35/40/45/50/55",
      "costType": " {{ abilityresourcename }}",
      "range": "430",
      "maxrank": 5,
      "image": "PoppyQ.png",
      "key": "Q"
    },
    {
      "name": "坚定风采",
      "description": "波比被动获得护甲和魔法抗性。这个加成会在她生命值较低时得到提升。波比可以主动施放此技能来获得移动速度加成并中断附近敌人的突进。如果中断了一次突进，那么该敌人还会被减速和缚地。",
      "tooltip": "被动：波比获得{{ bonusarmor }}护甲和{{ bonusmr }}魔法抗性。在波比低于{{ passiveempoweredhealthpercent*100 }}%生命值时，这个加成会翻倍。主动：波比获得{{ haste }}%移动速度并投射出一个环绕自身的领域，持续{{ duration }}秒，该领域可中断敌人的冲刺。被领域中断的敌人们会受到持续{{ groundingduration }}秒的缚地和{{ slowamount*-100 }}%减速，以及{{ interruptdamage }}魔法伤害。",
      "cooldown": "20/18/16/14/12",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "PoppyW.png",
      "key": "W"
    },
    {
      "name": "英勇冲锋",
      "description": "波比冲向目标并把目标推后。如果目标被推到墙上，就会受到晕眩效果。",
      "tooltip": "波比擒抱一名敌人，造成{{ tackledamage }}物理伤害并将该敌人带向前方。如果波比将目标擒抱到地形上，那么该敌人会被晕眩{{ stunduration }}秒并受到额外的{{ tackledamage }}物理伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "475",
      "maxrank": 5,
      "image": "PoppyE.png",
      "key": "E"
    },
    {
      "name": "持卫的裁决",
      "description": "波比引导一次能够把敌人击飞到远方的锤击。",
      "tooltip": "开始施放：波比开始为她的战锤蓄力，至多{{ channelmaxduration }}秒，自身减速{{ selfslow }}%。释放：波比猛砸地面，生成一道冲击波，来对命中的第一个敌方英雄及其身边的敌人们造成{{ damage }}物理伤害，将他们朝着他们的水晶枢纽处击退，并使他们在飞行时处在不可被选取状态。冲击波距离和击退距离受益于蓄力时长。未蓄力的挥锤造成{{ halfdamage }}物理伤害和持续{{ knockupdurationsnap }}秒的击飞。",
      "cooldown": "140/120/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 3,
      "image": "PoppyR.png",
      "key": "R"
    }
  ]
