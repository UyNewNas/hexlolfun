  "passive": {
    "name": "千珏之印",
    "description": "千珏可以标记敌人进行狩猎。成功完成一次狩猎，将永久强化千珏的基础技能。每完成4次狩猎，还会提升千珏的普攻距离。",
    "image": "Kindred_Passive.png"
  },
  "spells": [
    {
      "name": "乱箭之舞",
      "description": "千珏进行翻滚并朝附近的敌人射出最多三支箭矢。",
      "tooltip": "千珏进行翻滚，对至多3名敌人发射一根箭矢，造成{{ totaldamage }}物理伤害并提供持续{{ e8 }}秒的{{ totalqattackspeed }}攻击速度。在狼灵狂热之中时，这个技能的冷却时间会缩短至{{ e4 }}秒。",
      "cooldown": "9",
      "cost": "35",
      "costType": " {{ abilityresourcename }}",
      "range": "340",
      "maxrank": 5,
      "image": "KindredQ.png",
      "key": "Q"
    },
    {
      "name": "狼灵狂热",
      "description": "狼灵狂化并攻击在他附近的敌人。羊灵通过攻击和移动来被动地积攒层数。当层数攒满时，羊灵的下次攻击将治愈生命值。",
      "tooltip": "被动：千珏会在移动和攻击时获得层数。在100层时，千珏的下一次攻击会回复至多{{ attackheal }}生命值(基于它们的已损失生命值)。主动：千珏划出一块领地，命令狼灵去撕咬被羊灵攻击过的最后一名敌人。狼灵的撕咬造成{{ basewolfdamage }}外加{{ percentwolfdamage }}当前生命值的魔法伤害。",
      "cooldown": "18/17/16/15/14",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "560",
      "maxrank": 5,
      "image": "KindredW.png",
      "key": "W"
    },
    {
      "name": "横生惧意",
      "description": "羊灵进行一发谨慎的定位射击，来使目标减速。如果羊灵又进行了两次攻击，那么她的第三次攻击会指挥狼灵扑向目标，对目标造成巨量伤害。",
      "tooltip": "千珏弱化一名敌人，对其造成持续{{ slowduration }}秒的{{ totalslow }}%减速。千珏在{{ totalduration }}秒内对目标进行的第三次攻击会引导狼灵扑击该敌人，造成额外{{ basebitedamage }}外加{{ percentbitedamage }}已损失生命值的物理伤害。",
      "cooldown": "14/12.5/11/9.5/8",
      "cost": "0",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 5,
      "image": "KindredEWrapper.png",
      "key": "E"
    },
    {
      "name": "羊灵生息",
      "description": "羊灵让一块区域内的所有生灵都免受死亡。效果结束之前，谁都不会死去。效果结束时，所有单位都会获得治疗。",
      "tooltip": "千珏赐福于地面{{ e2 }}秒，使其中的友方、敌方或中立单位不会阵亡。在降至10%生命值时，仍留在该区域内的单位就不会受到伤害或治疗效果了。当赐福结束时，其中的所有单位都会治疗{{ e1 }}生命值。",
      "cooldown": "160/140/120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 3,
      "image": "KindredR.png",
      "key": "R"
    }
  ]
