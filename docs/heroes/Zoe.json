  "passive": {
    "name": "烟火四射！",
    "description": "佐伊在施放一次技能后的下次普攻会造成额外魔法伤害。",
    "image": "Zoe_P.png"
  },
  "spells": [
    {
      "name": "飞星乱入！",
      "description": "佐伊发射一个可在飞行途中由她重新导向的飞弹。飞弹在直线上飞行的路程越远，造成的伤害就会越高。",
      "tooltip": "佐伊发射一颗飞星，基于它的飞行距离来对命中的第一个敌人造成不断提升的伤害 -- {{ totaldamagetooltip }}到{{ maxdamagetooltip }}魔法伤害。佐伊可以再次施放这个技能来将这个飞弹重新导向到佐伊附近的一个新位置。",
      "cooldown": "8.5/8/7.5/7/6.5",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "ZoeQ.png",
      "key": "Q"
    },
    {
      "name": "窃法巧手",
      "description": "佐伊可以拾取敌方在施放召唤师技能和主动型装备时产生的法术碎片，从而让她自己能够施放一次性的相应技能或效果。在她施放一次召唤师技能的同时，她会获得3颗飞弹来射向距她最近的目标。",
      "tooltip": "被动：敌人在使用【召唤师技能】或【主动型装备】时会掉落一个技能碎片。特定小兵也会在被佐伊或一名附近的友方英雄击杀后掉落一个技能碎片。佐伊可以拾取这些碎片来使用一次相应技能。被动：当佐伊施放这个技能或任一召唤师技能时，她会获得{{ movementspeed*100 }}%移动速度，持续{{ msduration }}秒，并对她近期刚攻击过的目标投出3个飞弹。每颗飞弹造成{{ missiledamagetooltip }}魔法伤害。主动：施放一次来自佐伊已拾取的技能碎片的技能。",
      "cooldown": "0.25",
      "cost": "0",
      "costType": "无消耗",
      "range": "3000/4500/6000/3000/3000",
      "maxrank": 5,
      "image": "ZoeW.png",
      "key": "W"
    },
    {
      "name": "催眠气泡",
      "description": "困倦使目标进入困倦状态，然后陷入昏睡。在昏睡状态下，目标的魔抗会被降低。打醒目标的第一个伤害来源会造成双倍伤害，但有封顶值。",
      "tooltip": "佐伊踢出一个气泡，可造成{{ totaldamagetooltip }}魔法伤害，并会在未命中任何单位时如陷阱一般停留。在飞越墙体后，气泡的距离会得到延长。如果气泡或陷阱命中了一个敌方英雄，那么她会刷新此技能{{ cooldownrefresh*100 }}%冷却时间。在一段延迟后，被气泡命中的目标会陷入昏睡状态并降低{{ percentpen*100 }}%魔法抗性，持续2秒。攻击和技能在命中目标时都会将其惊醒并造成双倍伤害，最多造成{{ breakdamagetooltip }}真实伤害。",
      "cooldown": "18/17/16/15/14",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "ZoeE.png",
      "key": "E"
    },
    {
      "name": "折返跃迁",
      "description": "闪烁到附近的一个位置1秒。然后闪烁回去。",
      "tooltip": "佐伊传送到附近的一个位置1秒。然后，佐伊会传送回原来的位置。在此期间，佐伊可以攻击和使用技能，但无法移动。",
      "cooldown": "11/8/5",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "575",
      "maxrank": 3,
      "image": "ZoeR.png",
      "key": "R"
    }
  ]
