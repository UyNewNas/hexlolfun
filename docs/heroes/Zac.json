  "passive": {
    "name": "细胞分裂",
    "description": "扎克每用技能命中一次敌人，自己的一小块粘液就会飞溅出去。扎克可以重新吸收这些粘液，来为自己回复生命值。在承受致命伤害时，扎克会分裂成四块细胞组织，并试图重新结合。如果在短时间后，仍然有细胞组织存活，那么他就会重生，重生时的生命值取决于存活的细胞组织数量。细胞组织会继承一部分扎克的最大生命值、护甲和魔法抗性。这个技能的冷却时间为5分钟。",
    "image": "ZacPassive.png"
  },
  "spells": [
    {
      "name": "延伸打击",
      "description": "扎克延伸他的双臂，捕获一个敌人。攻击一个不同的敌人将使他把两个目标投向彼此。",
      "tooltip": "扎克伸展他的手臂，将其吸附到命中的第一个敌人身上以造成{{ totaldamage }}魔法伤害并暂时将该敌人减速。扎克的下次攻击会提升距离并且造成相同的伤害和减速。如果扎克用这次攻击命中了一个不同的敌人，那么他会将这两个敌人朝着彼此击飞。如果这两个敌人产生碰撞，那么他们及他们附近的敌人都会受到{{ totaldamage }}魔法伤害并被暂时减速。",
      "cooldown": "14/12.5/11/9.5/8",
      "cost": "0",
      "costType": "%当前生命值({{ healthcosttooltip }})",
      "range": "800",
      "maxrank": 5,
      "image": "ZacQ.png",
      "key": "Q"
    },
    {
      "name": "不稳定物质",
      "description": "扎克朝着附近的敌人进行喷溅，造成相当于目标一部分最大生命值的魔法伤害。",
      "tooltip": "扎克的躯体进行喷溅，对附近的敌人造成{{ basedamage }}+{{ displaypercentdamage }}最大生命值的魔法伤害。吸收粘液可使【不稳定物质】的冷却时间缩短1秒。",
      "cooldown": "5",
      "cost": "0",
      "costType": "%当前生命值({{ tooltiphealthcost }})",
      "range": "350",
      "maxrank": 5,
      "image": "ZacW.png",
      "key": "W"
    },
    {
      "name": "橡筋弹弓",
      "description": "扎克将手臂附在地上然后收缩，并将自己射向前方。",
      "tooltip": "开始蓄力：扎克将自身绷紧，在{{ channeltime }}秒里积攒一次冲刺。释放：扎克将自身发射出去，并击飞着陆点位置的敌人们至多{{ maxstun }}秒(基于蓄力时间)并对他们造成{{ damage }}魔法伤害。扎克每命中一名敌方英雄就会生成一团额外的粘液。",
      "cooldown": "22/19/16/13/10",
      "cost": "0",
      "costType": "%当前生命值({{ healthcosttooltip }})",
      "range": "300",
      "maxrank": 5,
      "image": "ZacE.png",
      "key": "E"
    },
    {
      "name": "动感弹球",
      "description": "扎克弹跳4次，对命中的敌人造成击飞和减速效果。",
      "tooltip": "扎克弹跳{{ bounces }}次。弹跳在首次命中敌人时会将其击退并造成{{ damageperbounce }}魔法伤害。后续弹跳会造成{{ damagepersubsequentbounce }}魔法伤害和持续{{ slowduration }}秒的{{ slowamount*100 }}%减速。扎克在此期间持续获得至多{{ endingms*100 }}%移动速度并且可以在弹跳时施放不稳定物质。",
