  "passive": {
    "name": "死亡毒液",
    "description": "图奇的攻击会使目标感染死亡毒液%i:OnHit% 攻击特效，每秒造成真实伤害。",
    "image": "Twitch_Passive.png"
  },
  "spells": [
    {
      "name": "埋伏",
      "description": "图奇进入伪装状态，持续一段短暂的时间并且移动速度得到提升。当离开伪装状态后，图奇会暂时获得攻击速度加成。当一名身上带有【死亡毒液】的敌方英雄死亡时，此技能的冷却时间会重置。",
      "tooltip": "图奇伪装并获得{{ movespeedmod }}%移动速度，持续{{ stealthduration }}秒。当附近有一名无法看见他的敌方英雄时，移动速度提升至{{ hiddenspeed }}%。在离开伪装后，图奇获得{{ attackspeedmod*100 }}%攻击速度，持续{{ attackspeedduration }}秒。当一名带有毒液的敌方英雄阵亡时，这个技能的冷却时间就会刷新。",
      "cooldown": "16",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "TwitchHideInShadows.png",
      "key": "Q"
    },
    {
      "name": "剧毒之桶",
      "description": "图奇扔出一个毒性之桶来引爆一个区域，对区域内的敌人造成减速效果，并对他们施加死亡毒液效果。",
      "tooltip": "图奇扔出一个毒性之桶来添加一层死亡毒液给所有被桶砸中的敌人，并留下一团毒雾，存留{{ duration }}秒。一直呆在毒雾中的敌人会被减速{{ totalslowamount }}%并且会每秒受到额外的一层死亡毒液。",
      "cooldown": "13/12/11/10/9",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "TwitchVenomCask.png",
      "key": "W"
    },
    {
      "name": "毒性爆发",
      "description": "图奇引爆他那卑劣的毒素，对已中毒的敌人进行更为深远的蹂躏。",
      "tooltip": "对附近感染了死亡毒液的所有敌人造成{{ basedamage }}物理伤害，此外，每层死亡毒液额外造成{{ physicaldamageperstack }}物理伤害和{{ magicdamageperstack }}魔法伤害。最大伤害：{{ maxphysicaldamage }}物理伤害和{{ maxmagicdamage }}魔法伤害。",
      "cooldown": "12/11/10/9/8",
      "cost": "50/60/70/80/90",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 5,
      "image": "TwitchExpunge.png",
      "key": "E"
    },
    {
      "name": "火力全开",
      "description": "图奇让十字弩火力全开，快速地朝他面前射出强力且射程极远的穿刺箭头，穿透沿途的所有敌人。",
      "tooltip": "图奇解开他的十字弩的封印，获得{{ bonusrange }}攻击距离和{{ bonusad }}攻击力，并使他的攻击变为穿刺弩箭，持续{{ duration }}秒。这些弩箭会攻击它们沿途的所有敌人，但对每个后续目标造成的伤害减少{{ falloffdamage*100 }}%，最低降至{{ minimumfalloffdamage*100 }}%伤害。",
      "cooldown": "90",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 3,
      "image": "TwitchFullAutomatic.png",
      "key": "R"
    }
  ]
}