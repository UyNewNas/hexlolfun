  "passive": {
    "name": "欢乐时光",
    "description": "古拉加斯可周期性地使用一个技能来治疗自身。",
    "image": "GragasPassiveHeal.png"
  },
  "spells": [
    {
      "name": "滚动酒桶",
      "description": "古拉加斯将酒桶滚到目标地点，酒桶可以被主动引爆或在到达目标地点4秒后自行爆炸。爆炸的威力会随时间持续提升。被酒桶炸到的敌人，移动速度会被降低。",
      "tooltip": "古拉加斯滚动出一个酒桶，该酒桶会在{{ e4 }}秒后爆炸， 造成{{ mindamage }}魔法伤害到{{ maxdamage }}魔法伤害和持续{{ e3 }}秒的{{ e2 }}到{{ effect2amount*1.5 }}%减速。伤害和减速会基于该酒桶在爆炸前的时长来提升。古拉加斯可以再次施放这个技能来提前引爆该酒桶。",
      "cooldown": "10/9/8/7/6",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "GragasQ.png",
      "key": "Q"
    },
    {
      "name": "醉酒狂暴",
      "description": "古拉加斯品尝他的最新佳酿，持续1秒。在喝完之后，他会变得喧闹且好斗，下次普通攻击会对附近的所有目标造成更多伤害，并且自身所受的伤害会降低。",
      "tooltip": "古拉加斯品尝他的最新佳酿，使即将到来的伤害降低{{ damagereduction }}，持续{{ defenseduration }}秒，此外，他的下次攻击获得强化，对目标及目标身边的敌人们造成额外的{{ totaldamage }}外加{{ maxhppercentdamage }}%最大生命值的魔法伤害。",
      "cooldown": "5",
      "cost": "30",
      "costType": " {{ abilityresourcename }}",
      "range": "20",
      "maxrank": 5,
      "image": "GragasW.png",
      "key": "W"
    },
    {
      "name": "肉弹冲击",
      "description": "古拉加斯向目标区域冲锋，在撞上第一个敌人后，对附近的所有敌方单位造成伤害和晕眩效果。",
      "tooltip": "古拉加斯向前冲锋，撞击命中的第一名敌人，使附近的敌人击飞{{ stunduration }}秒并对其造成{{ totaldamage }}魔法伤害。当古拉加斯撞到一个敌人时，这个技能的冷却时间会缩短{{ cooldownrefund*100 }}%。",
      "cooldown": "14/13.5/13/12.5/12",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "GragasE.png",
      "key": "E"
    },
    {
      "name": "爆破酒桶",
      "description": "古拉加斯向目标区域投掷他的酒桶，对爆炸范围内的所有敌人造成伤害和击退效果。",
      "tooltip": "古拉加斯猛抛他的酒桶，造成{{ damagedone }}魔法伤害并将敌人们从爆炸中心击退。",
