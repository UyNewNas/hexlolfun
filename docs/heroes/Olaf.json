  "passive": {
    "name": "狂战之怒",
    "description": "奥拉夫基于已损失生命值获得攻击速度和生命偷取。",
    "image": "Olaf_Passive.png"
  },
  "spells": [
    {
      "name": "逆流投掷",
      "description": "奥拉夫将战斧投至目标区域，对所有被战斧穿过的敌人造成伤害并削减他们的护甲和移动速度。如果奥拉夫捡起斧头，那么该技能冷却时间就会重置。",
      "tooltip": "奥拉夫扔出一把斧头，造成{{ totaldamage }}物理伤害和至多持续{{ maxslowduration }}秒(基于斧头移动距离)的{{ slowamount*100 }}%减速。被斧头命中的英雄还会损失{{ shredamount*100 }}%护甲，持续{{ debuffduration }}秒。如果奥拉夫拾起了斧头，那么这个技能的冷却时间会缩短至{{ tooltipcdrefund }}秒，或在度过{{ tooltipcdrefund }}秒之后完全返还。",
      "cooldown": "9",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "OlafAxeThrowCast.png",
      "key": "Q"
    },
    {
      "name": "挺过去",
      "description": "奥拉夫的攻击速度得到提升，并获得一层护盾。",
      "tooltip": "奥拉夫获得持续{{ duration }}秒的{{ attackspeed*100 }}%攻击速度，以及持续{{ shieldduration }}秒的{{ baseshield }}外加{{ shieldpercmissinghp*100 }}%已损失生命值的护盾值(最大值为{{ maxshieldcalc }}护盾值，在低于{{ thresholdformax*100 }}%时提供)。",
      "cooldown": "16/15/14/13/12",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "OlafFrenziedStrikes.png",
      "key": "W"
    },
    {
      "name": "鲁莽挥击",
      "description": "奥拉夫以破釜沉舟之势发动进攻，对目标造成真实伤害（不受护甲与魔抗减免），同时，自身也会根据敌方所受的伤害而受到真实伤害的反噬。",
      "tooltip": "奥拉夫狂野地挥舞他的双斧，造成{{ totaldamage }}真实伤害。如果该敌人阵亡，那么会返还此技能的消耗。攻击会使这个技能的冷却时间缩短1秒，在攻击野怪时，缩短值提升至2秒。",
      "cooldown": "11/10/9/8/7",
      "cost": "0",
      "costType": "生命值",
      "range": "325",
      "maxrank": 5,
      "image": "OlafRecklessStrike.png",
      "key": "E"
    },
    {
      "name": "诸神黄昏",
      "description": "奥拉夫被动获得护甲和魔法抗性提升。他可以激活这个技能来变得免疫控制效果，并且会在他保持攻击时一直持续。",
      "tooltip": "被动：奥拉夫获得{{ resists }}护甲和{{ resists }}魔法抗性。主动：奥拉夫净化掉他身上的所有定身和限制效果并且在接下来的{{ duration }}秒内免疫这些效果。在激活时，奥拉夫获得{{ ad }}攻击力。用一次攻击或鲁莽挥击命中一名英雄时，会使持续时间延长{{ durationextension }}秒。此外，奥拉夫会在朝着敌方英雄时获得{{ haste*100 }}%移动速度，持续{{ hasteduration }}秒。",
      "cooldown": "100/90/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 3,
      "image": "OlafRagnarok.png",
      "key": "R"
    }
  ]
}