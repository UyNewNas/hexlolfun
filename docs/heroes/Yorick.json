  "passive": {
    "name": "牧魂人",
    "description": "受诅咒的部落：约里克可以召唤雾行者来蜂拥并攻击附近的敌人。",
    "image": "Yorick_P.png"
  },
  "spells": [
    {
      "name": "临终仪式",
      "description": "约里克的下次攻击造成额外伤害并治疗自身。如果目标是一个英雄或大型野怪或如果目标死亡，则会留下一个坟墓。",
      "tooltip": "你的下一次普通攻击造成额外的{{ bonusdamage }}物理伤害并回复{{ qheal }}外加他的{{ missinghealthratio }}%已损失生命值，对抗非英雄单位时会削减{{ healreduction }}%。如果这个攻击命中了一个英雄或大型野怪或击杀了目标，就会留下一座坟墓。当附近有3个或以上的坟墓时，如果这个技能已被使用，那么约里克就能再次施放来从附近的所有坟墓中唤起雾行者。",
      "cooldown": "6/5.5/5/4.5/4",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "0",
      "maxrank": 5,
      "image": "YorickQ.png",
      "key": "Q"
    },
    {
      "name": "暗灵缠身",
      "description": "约里克在目标区域召唤一圈可破坏的暗灵之墙来阻挡敌方移动。",
      "tooltip": "约里克召唤一道灵墙来阻挡敌人的道路，但不影响友军。灵墙拥有{{ wallhealthtooltip }}生命值，并且会在{{ circleduration }}秒后消失。",
      "cooldown": "20/18/16/14/12",
      "cost": "70",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "YorickW.png",
      "key": "W"
    },
    {
      "name": "哀伤之雾",
      "description": "约里克扔出一小团黑雾，对敌人造成护甲削减、伤害、减速效果并标记敌人。召唤物在朝着被标记的目标移动时会获得移动速度。",
      "tooltip": "约里克扔出一小团黑雾，来造成{{ calc_healthdamage }}最大生命值的魔法伤害，以及持续{{ slowduration }}秒的{{ calc_slow }}减速，并标记英雄和野怪{{ markduration }}秒。被标记的敌人们会不断唤醒附近的坟墓(但数量上限不会超过{{ spell.yorickpassive:yorickpassiveghoulmax }})，并受到{{ armorshred*100 }}%护甲削减。约里克和他的召唤单位们在朝着标记移动时会获得{{ hasteamount*100 }}%移动速度。雾行者将在被标记的敌人远离它们时跳跃一次。",
      "cooldown": "12/11/10/9/8",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "YorickE.png",
      "key": "E"
    },
    {
      "name": "海屿悼词",
      "description": "约里克召唤迷雾室女，来让约里克的攻击对室女锁定的目标造成额外伤害。室女也会自动从死亡的敌人身上唤起雾行者。",
      "tooltip": "约里克召唤拥有{{ yorickbigghoulhealth }}生命值和{{ yorickbigghouldamage }}魔法攻击伤害的迷雾室女外加{{ rghoulnumbers }}个雾行者。室女会自动从附近阵亡的敌人身上唤起雾行者并且通过她的攻击标记敌方英雄。当约里克对室女的目标造成伤害时，他将造成{{ rmarkdamagepercent }}%最大生命值的魔法伤害。10秒后，约里克可以再次施放这个技能来放走室女，派她去相距最近的一条战线。",
      "cooldown": "160/130/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "YorickR.png",
      "key": "R"
    }
  ]
}