  "passive": {
    "name": "一触即发",
    "description": "每过一段时间，吉格斯的下次普通攻击就会造成额外的魔法伤害。这个冷却时间会在吉格斯每用一次技能时得到减少。",
    "image": "ZiggsPassiveReady.png"
  },
  "spells": [
    {
      "name": "弹跳炸弹",
      "description": "吉格斯扔出一个会弹跳的炸弹，对敌人造成魔法伤害。",
      "tooltip": "吉格斯扔出一个会弹跳的炸弹，对敌人造成{{ totaldamage }}魔法伤害。",
      "cooldown": "6/5.5/5/4.5/4",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "ZiggsQ.png",
      "key": "Q"
    },
    {
      "name": "定点爆破",
      "description": "吉格斯扔出一个炸药包，会在一段延迟后爆炸，或者在再次施放该技能后爆炸。爆炸会对敌人造成魔法伤害，并将他们击退。吉格斯也会被击退，但不会受到伤害。吉格斯可以用这个技能来爆破敌方摇摇欲坠的防御塔。",
      "tooltip": "吉格斯扔出一个炸药包，会在{{ bombduration }}秒后或者在再次施放该技能后爆炸。爆炸会对敌人造成{{ totaldamage }}魔法伤害，并将他们击退。吉格斯也会被震开，但不会受到伤害。【定点爆破】会自动摧毁生命值低于{{ turretdestroypercent*100 }}%的防御塔。",
      "cooldown": "20/18/16/14/12",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "ZiggsW.png",
      "key": "W"
    },
    {
      "name": "海克斯爆破雷区",
      "description": "吉格斯布下敌人一踩就炸的感应雷区，对踩中地雷的敌人造成魔法伤害和减速效果。对相同目标的后续爆炸将造成较少伤害。",
      "tooltip": "吉格斯布下敌人一踩就炸的感应雷区，对踩中地雷的敌人造成{{ totaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ slow*-100 }}%减速。地雷持续{{ mineduration }}秒。",
      "cooldown": "16",
      "cost": "70/80/90/100/110",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "ZiggsE.png",
      "key": "E"
    },
    {
      "name": "科学的地狱火炮",
      "description": "吉格斯部署他的尖端发明，科学的地狱火炮，将它推送一段极远的距离。在主要爆炸区域里的敌人会比在其它爆炸区域里的敌人受到更多的伤害。",
      "tooltip": "吉格斯扔出他的终极造物，在爆炸范围的中心区域造成{{ empowereddamage }}魔法伤害，或在边缘区域造成{{ blastdamage }}魔法伤害。",
      "cooldown": "120/95/70",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "5000",
      "maxrank": 3,
      "image": "ZiggsR.png",
      "key": "R"
    }
