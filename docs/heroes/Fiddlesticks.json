  "passive": {
    "name": "巫骇草人",
    "description": "费德提克的饰品会被替换为【草间人】。",
    "image": "FiddlesticksP.png"
  },
  "spells": [
    {
      "name": "恐惧",
      "description": "费德提克在非战斗状态且未被敌人看见时，如果用技能对敌人造成了伤害，或者对一名敌人使用了【Q恐惧】的主动效果，都会使目标因害怕而逃跑一段时间。",
      "tooltip": "被动：在非战斗状态且未被敌人看见，或冒充成一个草间人时，如果用一个技能对敌人造成了伤害，那么会使该敌人恐惧{{ fearduration }}秒。主动：恐惧一个目标{{ fearduration }}秒并造成{{ totalpercenthealthdamage }}当前生命值的魔法伤害。如果目标近期被费德提克恐惧过，那么则会转而造成{{ totalpercenthealthdamagefeared }}当前生命值的魔法伤害。",
      "cooldown": "15/14.5/14/13.5/13",
      "cost": "65",
      "costType": " {{ abilityresourcename }}",
      "range": "575",
      "maxrank": 5,
      "image": "FiddleSticksQ.png",
      "key": "Q"
    },
    {
      "name": "五骨丰登",
      "description": "费德提克从附近敌人们身上吸取生命值，在持续结束时造成额外的处决伤害。",
      "tooltip": "费德提克引导并吸取附近敌人们的灵魂，每秒造成{{ draindamagecalc }}魔法伤害，持续2秒，外加在结束时造成{{ percentfortooltip }}%已损失生命值的伤害。费德提克回复相当于{{ vamppercentage }}%伤害值的生命值。如果费德提克在未被打断地结束引导，那么剩余冷却时间缩短60%。",
      "cooldown": "10/9.5/9/8.5/8",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "FiddleSticksW.png",
      "key": "W"
    },
    {
      "name": "夜割",
      "description": "费德提克用它的镰刀斩击一个区域，使命中的所有敌人减速，并使斩击区域中心的敌人沉默。",
      "tooltip": "费德提克释放黑暗魔法，造成{{ damage }}魔法伤害并使敌人减速{{ slowamount*-100 }}%，持续{{ silenceduration }}秒。处于区域正中的敌人还会受到沉默效果。",
      "cooldown": "10/9/8/7/6",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "FiddleSticksE.png",
      "key": "E"
    },
    {
      "name": "群鸦风暴",
      "description": "一群杀人鸦盘旋于费德提克身边，每秒对范围内的所有敌方单位造成伤害。",
      "tooltip": "费德提克引导{{ channeltime }}秒，随后传送并释放杀人鸦群，在{{ duration }}秒里持续造成共{{ totaldamage }}魔法伤害。",
      "cooldown": "140/110/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 3,
      "image": "FiddleSticksR.png",
      "key": "R"
    }
  ]
