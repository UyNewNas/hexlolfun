  "passive": {
    "name": "镜花水月",
    "description": "当乐芙兰跌至40%最大生命值以下时，她会隐形1秒并创造一个幻像（不能造成伤害），幻像最多可持续8秒。",
    "image": "LeblancP.png"
  },
  "spells": [
    {
      "name": "恶意魔印",
      "description": "乐芙兰朝目标投射一个魔印，造成魔法伤害并标记目标3.5秒。用一个技能对被标记的目标造成伤害时，会引爆魔印，造成附加伤害。如果这两部分伤害中有任一部分击杀了目标，那么乐芙兰就会返还此技能的法力消耗和此技能的一部分剩余冷却时间。",
      "tooltip": "乐芙兰对一个敌人投出一个魔印，造成{{ damage }}魔法伤害并将其标记{{ markduration }}秒。用一个技能对被标记的目标造成伤害时，会引爆魔印，从而造成{{ markdamage }}魔法伤害。如果这两部分伤害中有任一部分击杀了目标，那么乐芙兰就会返还此技能的{{ manarefund*100 }}%法力消耗和此技能的{{ cooldownrefund*100 }}%剩余冷却时间。初始魔印对小兵造成额外的{{ bonusminiondamage }}伤害。",
      "cooldown": "6",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "LeblancQ.png",
      "key": "Q"
    },
    {
      "name": "魔影迷踪",
      "description": "乐芙兰位移至目标位置，并对目标位置附近的敌人造成伤害。在接下来的4秒里，她可以激活此技能来回到她的初始位置。",
      "tooltip": "乐芙兰冲刺然后对附近的敌人们造成{{ totaldamage }}魔法伤害。在冲刺后的{{ snapbacktimeallowed }}秒里，乐芙兰可以再次施放。再次施放：乐芙兰回到她的初始位置。",
      "cooldown": "15/13.75/12.5/11.25/10",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "LeblancW.png",
      "key": "W"
    },
    {
      "name": "幻影锁链",
      "description": "乐芙兰抛出一条锁链来束缚命中的第一个敌人。如果目标持续被束缚1.5秒，那么目标就会受到额外的魔法伤害并且被禁锢。",
      "tooltip": "乐芙兰抛出一个锁链来束缚命中的第一个敌人，造成{{ initialdamage }}魔法伤害并提供目标的真实视野。如果目标持续被束缚{{ tetherduration }}秒，则乐芙兰会将其禁锢{{ rootduration }}秒，并造成额外的{{ delayeddamage }}魔法伤害。",
      "cooldown": "14/13.25/12.5/11.75/11",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "LeblancE.png",
      "key": "E"
    },
    {
      "name": "故技重施",
      "description": "乐芙兰可以施放她一个技能的故技重施版。",
      "tooltip": "乐芙兰故技重施，将她放过的上一个技能再施放一次。故技重施版技能的伤害会获得提升。故技重施版恶意魔印在施加印记时造成{{ rq1damage }}魔法伤害，并在消耗印记时造成{{ rq2damage }}魔法伤害 。故技重施版魔影迷踪造成{{ rwdamage }}魔法伤害。故技重施版幻影锁链在链到目标时造成{{ re1damage }}魔法伤害并在禁锢时造成{{ re2damage }}魔法伤害。",
      "cooldown": "45/35/25",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 3,
      "image": "LeblancR.png",
      "key": "R"
    }
  ]
