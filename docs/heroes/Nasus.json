  "passive": {
    "name": "吞噬灵魂",
    "description": "内瑟斯吸取敌人的生命能量，从而获得生命偷取加成。",
    "image": "Nasus_Passive.png"
  },
  "spells": [
    {
      "name": "汲魂痛击",
      "description": "内瑟斯对敌人施放汲魂痛击造成伤害，如果敌人死于汲魂痛击，则永久增加下次汲魂痛击的伤害。",
      "tooltip": "内瑟斯的下次攻击造成{{ totaldamage }}物理伤害。用这个攻击击杀一名敌人后，会使其伤害永久提升{{ basicstacks }}，击杀英雄、大型小兵和大型野怪的伤害提升为{{ bigstacks }}。",
      "cooldown": "7.5/6.5/5.5/4.5/3.5",
      "cost": "20",
      "costType": " {{ abilityresourcename }}",
      "range": "255",
      "maxrank": 5,
      "image": "NasusQ.png",
      "key": "Q"
    },
    {
      "name": "枯萎",
      "description": "内瑟斯使一名敌方英雄衰老，持续减少其移动速度和攻击速度。",
      "tooltip": "内瑟斯使一名英雄衰老，使其减速{{ slowbase }}%，并在{{ duration }}秒内持续提升至{{ maxslowtooltiponly }}%。目标的攻击速度也会降低，相当于该减速幅度的{{ attackspeedslowmult*100 }}%。",
      "cooldown": "15/14/13/12/11",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "NasusW.png",
      "key": "W"
    },
    {
      "name": "灵魂烈焰",
      "description": "内瑟斯在目标区域施放灵魂烈焰，伤害并削弱敌人。",
      "tooltip": "内瑟斯引发一团灵魂烈焰，造成{{ initialdamage }}魔法伤害。区域内的敌人们会失去{{ e2 }}%护甲并在{{ e3 }}秒里持续受到共{{ totaldotdamage }}魔法伤害。",
      "cooldown": "12",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "NasusE.png",
      "key": "E"
    },
    {
      "name": "死神降临",
      "description": "内瑟斯释放一个具有强大魔力的沙漠风暴来侵袭身边的敌人。当风暴肆虐期间，他会获得额外生命值、额外攻击距离，伤害附近的敌人，汲魂痛击会拥有较短冷却时间，并获得额外的护甲和魔法抗性。",
      "tooltip": "沙漠风暴赐予内瑟斯力量，使他在15秒的持续时间内获得{{ bonushealth }}最大生命值，以及{{ initialresistgain }}护甲与魔法抗性。在风暴肆虐时，他每秒对周围目标造成{{ damagecalc }}最大生命值的魔法伤害，并且汲魂痛击的冷却时间缩短{{ qcdr*100 }}%。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 3,
      "image": "NasusR.png",
      "key": "R"
    }
  ]
}