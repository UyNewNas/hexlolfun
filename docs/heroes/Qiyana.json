  "passive": {
    "name": "凌人贵气",
    "description": "奇亚娜对每名敌人发起的第一次普攻或技能会造成额外伤害。",
    "image": "Qiyana_Passive.png"
  },
  "spells": [
    {
      "name": "元素之怒 / 以绪塔尔之锋",
      "description": "奇亚娜挥舞她的武器，造成伤害和基于她元素的额外效果。",
      "tooltip": "如果奇亚娜并未拥有一个附魔，那么她会进行斩击，对小范围内的敌人们造成{{ vanilladamage }}物理伤害。如果她已有一个附魔，那么这个技能会获得额外距离并基于附魔类型获得一个额外效果：寒冰附魔：暂时禁锢，然后是持续{{ slowduration }}秒的{{ slowpotency*-100 }}%减速。岩石附魔：对低于{{ critthreshold*100 }}%生命值的敌人们造成额外的{{ tremordamage }}物理伤害。荒野附魔：留下一条小径，来使奇亚娜隐形并提供{{ haste*100 }}%移动速度。",
      "cooldown": "7",
      "cost": "35",
      "costType": " {{ abilityresourcename }}",
      "range": "525",
      "maxrank": 5,
      "image": "QiyanaQ.png",
      "key": "Q"
    },
    {
      "name": "方圆塑令",
      "description": "奇亚娜突进到一个位置并用一种元素为她的武器附魔。当武器有附魔时，她的攻击和技能会造成额外伤害。",
      "tooltip": "被动：当奇亚娜的武器已被附魔时，她会获得{{ attackspeed*100 }}%攻击速度并且她的攻击造成额外的{{ onhitdamage }}魔法伤害。她还会在相应地形类型附近获得非战斗状态下的{{ passivems*100 }}%移动速度。主动：奇亚娜突进向一个附近的草丛、地形或河流，然后用该地形类型来附魔她的武器。这会刷新元素之怒 / 以绪塔尔之锋的冷却时间。",
      "cooldown": "7",
      "cost": "25/30/35/40/45",
      "costType": " {{ abilityresourcename }}",
      "range": "1100",
      "maxrank": 5,
      "image": "QiyanaW.png",
      "key": "W"
    },
    {
      "name": "天纵之勇",
      "description": "奇亚娜突进至一名敌人处，并对其造成伤害。",
      "tooltip": "奇亚娜冲刺并经过一名敌人，并对其造成{{ damage }}物理伤害。",
      "cooldown": "11/10/9/8/7",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "QiyanaE.png",
      "key": "E"
    },
    {
      "name": "惊才绝景",
      "description": "奇亚娜发出一道冲击波来引爆沿途命中的任何元素，对元素附近的敌人造成伤害和晕眩效果。",
      "tooltip": "奇亚娜放出一道冲击波来击退敌人们并在它命中墙体时爆炸。爆炸会沿着地形的完整边缘行进，晕眩0.5到{{ stunduration }}秒并造成{{ damage }}外加{{ missinghealthdamagerock }}最大生命值的物理伤害。 晕眩时长会随着爆炸的移动距离而缩短。冲击波途经的任何河流与草丛也会在短暂延迟后爆炸，造成等值的伤害和晕眩。",
      "cooldown": "120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 3,
      "image": "QiyanaR.png",
      "key": "R"
    }
  ]
}