  "passive": {
    "name": "法力澎湃",
    "description": "泽拉斯的普通攻击会周期性地恢复法力值。每当泽拉斯击杀了一个单位时，这个冷却时间就会缩短。",
    "image": "Xerath_Passive1.png"
  },
  "spells": [
    {
      "name": "奥能脉冲",
      "description": "泽拉斯聚集能量，随后发射出一道射程很远的能量光束，对所有命中的目标造成魔法伤害。",
      "tooltip": "开始蓄力：泽拉斯开始积蓄一次奥术光束，自身逐步减速，至多可达50%。释放：泽拉斯发射光束，造成{{ tooltiptotaldamage }}魔法伤害。距离随蓄力时间提升。",
      "cooldown": "9/8/7/6/5",
      "cost": "80/90/100/110/120",
      "costType": " {{ abilityresourcename }}",
      "range": "750",
      "maxrank": 5,
      "image": "XerathArcanopulseChargeUp.png",
      "key": "Q"
    },
    {
      "name": "毁灭之眼",
      "description": "在目标区域降下奥术能量的弹幕，对一个区域内的所有敌人造成减速效果和魔法伤害。区域中心的目标会受到额外伤害和一个更强大的减速效果。",
      "tooltip": "泽拉斯引爆目标区域的奥术能量，造成{{ totaldamage }}魔法伤害并使敌人减速{{ slowamount*100 }}%，持续{{ slowduration }}秒。区域中心的敌人会受到{{ sweetspottotaldamage }}魔法伤害，并被减速{{ sweetspotslowamount*100 }}%，减速效果会在{{ slowduration }}秒里持续衰减。",
      "cooldown": "14/13/12/11/10",
      "cost": "80/90/100/110/120",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 5,
      "image": "XerathArcaneBarrage2.png",
      "key": "W"
    },
    {
      "name": "冲击法球",
      "description": "对单个敌人造成魔法伤害和晕眩效果。",
      "tooltip": "泽拉斯发射一颗原生魔法之球，基于飞行距离使命中第一个的敌人晕眩至多{{ maxstunduration }}秒，并造成{{ tooltiptotaldamage }}魔法伤害。",
      "cooldown": "13/12.5/12/11.5/11",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "1050",
      "maxrank": 5,
      "image": "XerathMageSpear.png",
      "key": "E"
    },
    {
      "name": "奥术仪式",
      "description": "泽拉斯将自己固定在一处魔力之源上，并获得数次远程施法的机会。",
      "tooltip": "泽拉斯飞升至他的真正形态并引导{{ duration }}秒。在此期间，他可以再次施放此技能至多{{ numberofshots }}次。再次施放：泽拉斯施放一道魔法炮击，造成{{ tooltiptotaldamage }}魔法伤害。每次命中英雄时，炮击都会造成额外的{{ rampdamagecalc }}魔法伤害。",
      "cooldown": "130/115/100",
