  "passive": {
    "name": "嗜火",
    "description": "在施放4个技能后，安妮的下一次伤害类技能就会对目标造成短暂的晕眩效果。安妮在游戏开始时和重生时，会带着满层的【嗜火】。",
    "image": "Annie_Passive.png"
  },
  "spells": [
    {
      "name": "碎裂之火",
      "description": "安妮向目标投出注入了法力值的火球，对目标造成魔法伤害。如果目标死于碎裂之火，则碎裂之火消耗的法力值会返还给安妮，且碎裂之火的冷却时间减半。",
      "tooltip": "安妮投出一团火球，造成{{ totaldamage }}魔法伤害。如果目标阵亡，那么安妮会返还法力值并缩短50%冷却时间。",
      "cooldown": "4",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "625",
      "maxrank": 5,
      "image": "AnnieQ.png",
      "key": "Q"
    },
    {
      "name": "焚烧",
      "description": "安妮向锥形区域施放一道烈焰，对区域内的所有敌人造成伤害。",
      "tooltip": "安妮投射出一阵火焰波，造成{{ totaldamage }}魔法伤害。",
      "cooldown": "7",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "AnnieW.png",
      "key": "W"
    },
    {
      "name": "熔岩护盾",
      "description": "为安妮或一名友军提供一层护盾、一个爆发性的移动速度加成并且对任何用攻击或技能袭击她的敌人造成伤害。",
      "tooltip": "安妮为一名友方英雄提供持续{{ shieldduration }}秒的{{ shieldblocktotal }}护盾值，以及在{{ movementspeedduration }}秒里持续衰减的{{ movespeedcalc }}移动速度。当护盾处于激活状态时，敌人用攻击或技能对护盾造成伤害时会受到{{ damagereturn }}魔法伤害，每个护盾受到一次伤害。提伯斯在被召唤出来时总会获得熔岩护盾的效果。",
      "cooldown": "10",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "AnnieE.png",
      "key": "E"
    },
    {
      "name": "提伯斯之怒",
      "description": "安妮召唤地狱火泰迪：提伯斯为其作战，对目标区域造成伤害，提伯斯也会攻击和烧伤站在它周围的敌人。",
      "tooltip": "被动：安妮获得{{ rpercentpenbuff*100 }}%法术穿透。安妮召唤提伯斯，造成{{ initialburstdamage }}魔法伤害。在接下来的{{ tibberslifetime }}秒里，提伯斯会灼烧附近的敌人，每秒造成{{ tibbersauradamage }}魔法伤害。提伯斯在以下情况下会变得暴怒：在被召唤出来时、在安妮晕眩一名敌方英雄时、以及在安妮阵亡时。在暴怒状态下，提伯斯获得275%攻击速度和在3秒里持续衰减的100%移动速度。再次施放：手动给提伯斯下达指令。",
      "cooldown": "130/115/100",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 3,
      "image": "AnnieR.png",
      "key": "R"
    }
  ]
}