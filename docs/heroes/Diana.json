  "passive": {
    "name": "月银之刃",
    "description": "每第三次攻击就会溅射周围的敌人，造成额外的魔法伤害。在施放一个技能后，黛安娜获得持续5秒的攻击速度。",
    "image": "Diana_Passive_LunarBlade.png"
  },
  "spells": [
    {
      "name": "新月打击",
      "description": "释放一道月能光束，对弧形范围内的敌人造成伤害。会对命中的敌人施加月光效果，如果中了月光效果的敌人不在潜行状态下，就会暴露在己方视野中3秒。",
      "tooltip": "黛安娜释放一道月能圆弧，造成{{ totaldamage }}魔法伤害并用月光标记{{ moonlightduration }}秒。月光会显形那些不在潜行状态的敌人们。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "50",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "DianaQ.png",
      "key": "Q"
    },
    {
      "name": "苍白之瀑",
      "description": "黛安娜召出三颗护体法球，在命中敌人后爆炸，对一个区域内的敌人造成范围伤害。她也会获得一层吸收伤害的护盾。护盾的生命值会在她的第三颗法球爆炸后得到提升。",
      "tooltip": "黛安娜生成3颗持续{{ shieldduration }}秒的护体法球，可在接触时爆炸，每颗造成{{ totaldamage }}魔法伤害，至多达到{{ totalmaxdamage }}伤害。黛安娜也会获得相同持续时间的{{ shieldvalue }}护盾值。当最后一颗法球爆炸后，她会获得额外的{{ shieldvalue }}护盾值并刷新持续时间。",
      "cooldown": "15/13.5/12/10.5/9",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "DianaOrbs.png",
      "key": "W"
    },
    {
      "name": "月神冲刺",
      "description": "成为复仇之月的活化身，冲向一名敌人并造成魔法伤害。【月神冲刺】在冲达一名被施加了【月光】效果的敌人时，会没有冷却时间。所有其它的敌人都将移除掉身上的【月光】效果，无论他们是否是【月神冲刺】的目标。",
      "tooltip": "黛安娜成为复仇之月的活化身，冲向一名敌人并造成{{ totaldamage }}魔法伤害。如果目标被施加了月光，那么这个技能的冷却时间会被刷新。",
      "cooldown": "22/20/18/16/14",
      "cost": "40/45/50/55/60",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 5,
      "image": "DianaTeleport.png",
      "key": "E"
    },
    {
      "name": "月之降临",
      "description": "黛安娜将附近所有敌人显形并拉拽到身边，然后使他们减速。如果黛安娜将1个或以上的敌方英雄拉拽到身边，那么月光会在短暂延迟后倾注在她身上，在她附近的一个区域内造成魔法伤害，每拉拽一个额外目标就会使这个伤害提升。",
      "tooltip": "黛安娜拽入、减速{{ slowtooltip }}%、并显形附近的敌人 {{ slowduration }}秒。如果黛安娜命中了至少一名敌方英雄，那么她就会召唤月亮，造成{{ rexplosiondamage }}魔法伤害外加{{ rmultihitamplification }}x第一个之外的被拖拽英雄数，至多达到{{ maxdamage }}伤害。",
      "cooldown": "100/90/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "475",
      "maxrank": 3,
      "image": "DianaR.png",
      "key": "R"
    }
  ]
}