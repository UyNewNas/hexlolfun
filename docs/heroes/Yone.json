  "passive": {
    "name": "狩人之道",
    "description": "永恩每第二次攻击造成魔法伤害。此外，他的暴击几率提升。",
    "image": "YonePassive.png"
  },
  "spells": [
    {
      "name": "错玉切",
      "description": "向前出剑，呈直线造成伤害。在命中时，错玉切会获得一层旋风烈斩效果，持续数秒。在2层时，错玉切会使永恩向前冲刺并带着一阵能够击飞敌人的旋风。",
      "tooltip": "永恩向前出剑，造成{{ qdamage }}物理伤害。在命中时，提供一层持续{{ buffduration }}秒的可叠加效果。在积攒2层效果后，这个技能会使永恩向前冲刺，并带着一阵能够击飞敌人{{ q3knockupduration }}秒的的旋风，造成{{ qdamage }}物理伤害。",
      "cooldown": "4",
      "cost": "0",
      "costType": "无消耗",
      "range": "450",
      "maxrank": 5,
      "image": "YoneQ.png",
      "key": "Q"
    },
    {
      "name": "凛神斩",
      "description": "向前顺劈，对锥形范围内的所有敌人造成伤害。为永恩提供一个护盾，护盾生命值会基于被顺劈到的敌方英雄的数量而得到提升。凛神斩的冷却时间和施放时间可通过攻击速度来缩短。",
      "tooltip": "永恩向前顺劈，造成{{ basedamage*0.5 }}+目标{{ maxhealthdamage*50 }}%最大生命值的物理伤害和{{ basedamage*0.5 }}+目标{{ maxhealthdamage*50 }}%最大生命值的魔法伤害。如果永恩命中了敌方单位，那么他会获得{{ wshield }}护盾，持续{{ shieldduration }}秒。每命中一名敌方英雄，护盾生命值都会提升。",
      "cooldown": "14",
      "cost": "0",
      "costType": "无消耗",
      "range": "700",
      "maxrank": 5,
      "image": "YoneW.png",
      "key": "W"
    },
    {
      "name": "破障之锋",
      "description": "永恩的灵体离开他的身体，并获得移动速度。当这个技能结束时，永恩的灵体会被强制返回他的身体，并且他会再次造成伤害，伤害值相当于一部分他在灵体形态中造成的伤害。",
      "tooltip": "永恩进入灵体形态{{ returntimer }}秒，期间会将他的身体留在原地，并获得不断提升的{{ startingms*100 }}%到{{ movementspeed*100 }}%移动速度。当灵体形态结束时，永恩会返回他的身体，并再次造成伤害，伤害值相当于他在此期间对英雄造成伤害的{{ deathmarkpercent*100 }}%。你可以在灵体形态期间再次施放这个技能。再次施放：提前结束灵体形态。",
      "cooldown": "22/19/16/13/10",
      "cost": "0",
      "costType": "无消耗",
      "range": "25000",
      "maxrank": 5,
      "image": "YoneE.png",
      "key": "E"
    },
    {
      "name": "封尘绝念斩",
      "description": "永恩沿直线进行斩击，闪烁至最后一名敌方英雄身后，并将命中的所有敌人拉向他。",
      "tooltip": "永恩对一条路径上的所有敌人进行打击，造成{{ tooltipdamage }}物理伤害和{{ tooltipdamage }}魔法伤害，传送至命中的最后一名敌方英雄身后，并将命中的所有敌人击飞向永恩。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "1000",
      "maxrank": 3,
      "image": "YoneR.png",
      "key": "R"
    }
  ]
}