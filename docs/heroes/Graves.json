  "passive": {
    "name": "新命运",
    "description": "格雷福斯的散弹枪拥有一些独特性能。他的弹药打光后就必须重新装弹。每次攻击会发射4颗弹丸，弹丸无法穿透单位。会击退被多颗弹丸命中的非英雄单位。",
    "image": "GravesTrueGrit.png"
  },
  "spells": [
    {
      "name": "穷途末路",
      "description": "格雷福斯发射一颗爆破性的榴弹，会在1秒后引爆，或是在碰到地形后立刻爆炸。",
      "tooltip": "格雷福斯发射一个火药卷，造成{{ totaldamage }}物理伤害。在1秒或与地形碰撞之后，它会爆炸，对沿途和爆炸附近的敌人们再次造成{{ totaldetonationdamage }}物理伤害。",
      "cooldown": "13/11.25/9.5/7.75/6",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "GravesQLineSpell.png",
      "key": "Q"
    },
    {
      "name": "烟幕弹",
      "description": "格雷福斯朝目标区域掷出一颗烟幕弹。如果敌人处在烟幕之中，则其视野会被降低。被烟幕弹的初始冲击所命中的敌人会受到魔法伤害并且移动速度会被短暂降低。",
      "tooltip": "格雷福斯生成一团黑色烟幕，持续4秒，使其中的敌人减速{{ e2 }}%并无法看到区域之外。初始冲击造成{{ impactdamage }}魔法伤害。",
      "cooldown": "26/24/22/20/18",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "950",
      "maxrank": 5,
      "image": "GravesSmokeGrenade.png",
      "key": "W"
    },
    {
      "name": "快速拔枪",
      "description": "格雷福斯向前冲刺，获得一层持续数秒的护甲和魔法抗性加成。如果格雷福斯朝着一名敌方英雄冲刺，则会获得两层纯爷们效果。格雷福斯的每次未被闪避的普通攻击，都会减少这个技能的冷却时间并刷新该防御属性加成。",
      "tooltip": "格雷福斯冲刺并装填一颗子弹进他的霰弹枪中。他还会获得一层持续{{ buffduration }}秒的效果(最多{{ maxstacks }}层)或是在朝着敌人突进时获得2层效果。每层效果为他提供{{ armorperstack }}护甲和{{ mrgrant }}魔法抗性。层数会在对非小兵单位造成伤害时刷新。格雷福斯的攻击每有一颗弹丸命中敌人，就会使这个技能缩短{{ cooldownperhit }}秒冷却时间。",
      "cooldown": "16/15/14/13/12",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "425",
      "maxrank": 5,
      "image": "GravesMove.png",
      "key": "E"
    },
    {
      "name": "终极爆弹",
      "description": "格雷福斯射出一枚爆破弹，对它所命中的第一个敌人造成大量伤害。在命中一名英雄或者达到它的最大射程之后，爆弹会爆炸，并对锥形范围内的敌人造成伤害。",
      "tooltip": "格雷福斯射出一枚爆破弹，并因后坐力而向后位移。爆破弹对命中的第一敌人造成{{ damage }}物理伤害。在命中一名敌方英雄，或者达到最大射程之后，终极爆弹将会向外爆裂，造成{{ falloffdamage }}物理伤害。",
      "cooldown": "100/80/60",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1000",
      "maxrank": 3,
      "image": "GravesChargeShot.png",
      "key": "R"
    }
  ]
}