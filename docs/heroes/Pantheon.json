  "passive": {
    "name": "矢志不退",
    "description": "在数次技能或攻击后，潘森的下一个技能会得到强化。",
    "image": "Pantheon_Passive.png"
  },
  "spells": [
    {
      "name": "贯星长枪",
      "description": "潘森朝着选定方向刺出或投掷他的长枪。",
      "tooltip": "秒放：潘森刺出他的长枪，对命中的敌人们造成{{ tapdamagecalc }}物理伤害。返还这个技能{{ tapcooldownrefund*100 }}%的冷却时间。蓄力：潘森挥出他的长枪，对命中的首个敌人造成{{ holddamagecalc }}物理伤害并对后续目标造成的伤害减少{{ damagefalloff*100 }}%。这个技能在对抗低于{{ crithealththreshold*100 }}%生命值的敌人时会获得强化，造成{{ executedamagecalcmodified }}物理伤害作为替代。矢志不退加成：造成额外的{{ empowereddamagecalc }}物理伤害。",
      "cooldown": "11/10.25/9.5/8.75/8",
      "cost": "25",
      "costType": " {{ abilityresourcename }}",
      "range": "575",
      "maxrank": 5,
      "image": "PantheonQ.png",
      "key": "Q"
    },
    {
      "name": "斗盾跃击",
      "description": "潘森跃向一个目标，对其造成伤害和晕眩。",
      "tooltip": "潘森跃向他的目标，晕眩{{ stunduration }}秒并造成{{ maxhealthdamagecalc }}最大生命值物理伤害。矢志不退加成：潘森的下一次攻击会打击{{ empowerednumhits }}次，总共造成{{ empowereddamagemultcalcmodified }}物理伤害。",
      "cooldown": "13/12/11/10/9",
      "cost": "55",
      "costType": " {{ abilityresourcename }}",
      "range": "600",
      "maxrank": 5,
      "image": "PantheonW.png",
      "key": "W"
    },
    {
      "name": "神佑枪阵",
      "description": "潘森架起他的圣盾，变得免疫来自前方的伤害，并快速地用他的长枪戳刺。",
      "tooltip": "潘森架起他的圣盾并与选定方向上的敌人交战{{ shieldduration }}秒，变得免疫来自所选方向的伤害(防御塔除外)并在持续期间造成{{ damagecalc }}物理伤害。在引导之后，潘森会用他的圣盾进行猛击，造成{{ shielddamagecalc }}物理伤害。矢志不退加成：当潘森猛击他的圣盾时，获得持续{{ resistsduration }}秒的{{ resistscalc }}护甲和{{ resistscalc }}魔法抗性，以及持续{{ speedduration }}秒的{{ speedamount*100 }}%移动速度。",
      "cooldown": "22/21/20/19/18",
      "cost": "80",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "PantheonE.png",
      "key": "E"
    },
    {
      "name": "大荒星陨",
      "description": "潘森屏气凝神然后跃至空中， 随后如流星一般落到选定的位置上。",
      "tooltip": "被动：潘森获得{{ armorpenetration*100 }}%护甲穿透。主动：潘森聚集他的力量以跃至空中。他会从天上掷出他的长枪，在小范围内造成{{ spell.pantheonq:holddamagecalc }}物理伤害和持续{{ spearslowduration }}秒的{{ spearslow*100 }}%减速。潘森随后会如陨石一般落向目标区域。对一条直线上的敌人最多造成{{ damagecalc }}魔法伤害(最多降低至{{ edgedamagereduction*100 }}%伤害，极小值出现于区域的边缘)。这个技能会立刻使矢志不退准备就绪。",
      "cooldown": "180/165/150",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "5500",
      "maxrank": 3,
      "image": "PantheonR.png",
      "key": "R"
    }
  ]
