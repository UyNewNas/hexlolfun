  "passive": {
    "name": "星光漫射",
    "description": "萨勒芬妮施放的每第三个技能将进行双重施放。此外，施放技能时，附近的友军会为她的下一次普通攻击提供额外魔法伤害和攻击距离。",
    "image": "Seraphine_Passive.png"
  },
  "spells": [
    {
      "name": "清籁穿云",
      "description": "萨勒芬妮在一个区域内造成伤害。",
      "tooltip": "萨勒芬妮放出一道清澈的音符，造成{{ explosiondamage }}魔法伤害，对英雄和野怪的伤害会基于目标的已损失生命值而提升，最多可对{{ executethreshold*100 }}%生命值以下的目标造成{{ totalempowereddamage }}伤害。",
      "cooldown": "8/7.5/7/6.5/6",
      "cost": "60/70/80/90/100",
      "costType": " {{ abilityresourcename }}",
      "range": "900",
      "maxrank": 5,
      "image": "SeraphineQ.png",
      "key": "Q"
    },
    {
      "name": "聚和心声",
      "description": "萨勒芬妮为附近的友军提供护盾和急速。如果她身上已有护盾，那么还会治疗附近的友军。",
      "tooltip": "萨勒芬妮用歌曲激励她附近的友方英雄，为他们提供{{ hastevalueallies }}移动速度，为她自身提供不断衰减的{{ wmsbonustotal }}移动速度，并为自身和友方都提供{{ shieldvalueseraphine }}护盾值，持续{{ shieldduration }}秒。如果萨勒芬妮身上已有护盾，那么她会号召友军加入她，在{{ whealsplitdelay }}秒延迟后，为他们回复{{ wmissinghpheal }}%已损失生命值。",
      "cooldown": "22",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "800",
      "maxrank": 5,
      "image": "SeraphineW.png",
      "key": "W"
    },
    {
      "name": "增幅节拍",
      "description": "萨勒芬妮对一条直线上的敌人们造成伤害和移动受损效果。",
      "tooltip": "萨勒芬妮释放出一道强力音波，对一条直线上的敌人造成{{ finaldamage }}魔法伤害和持续{{ slowduration }}秒的{{ slowvalue }}%减速效果。对已被减速的敌人们造成禁锢效果，对已被定身的敌人们造成晕眩效果。",
      "cooldown": "11/10.5/10/9.5/9",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1300",
      "maxrank": 5,
      "image": "SeraphineE.png",
      "key": "E"
    },
    {
      "name": "炫音返场",
      "description": "萨勒芬妮对命中的敌人们造成伤害和魅惑效果，会在每次命中友方英雄或敌方英雄时刷新距离。",
      "tooltip": "萨勒芬妮登台演出，投射出一股令人着迷的力量，来造成{{ rchannelduration }}秒魅惑效果和{{ r1totaldamage }}魔法伤害。任何被命中的英雄(包括友方英雄)都会成为表演的一部分，延长这个技能的距离。友方英雄会获得满层的音符。",
      "cooldown": "160/140/120",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "25000",
      "maxrank": 3,
      "image": "SeraphineR.png",
      "key": "R"
    }
  ]
}