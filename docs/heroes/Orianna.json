  "passive": {
    "name": "发条协奏",
    "description": "奥莉安娜的攻击会造成额外魔法伤害。这个伤害可在奥莉安娜对相同目标进行更多次攻击后提升。",
    "image": "OriannaPassive.png"
  },
  "spells": [
    {
      "name": "指令：攻击",
      "description": "奥莉安娜指挥她的魔偶，朝目标区域发射，对沿途目标造成魔法伤害（对后续目标伤害递减）。指令结束后魔偶会停在目标区域。",
      "tooltip": "奥莉安娜指挥她的魔偶移动至一个区域，对附近敌人和它途经的敌人造成{{ totaldamagetooltip }}魔法伤害。对第一个敌人之后的所有敌人造成的伤害就减少{{ reduceddamagepercent }}%。",
      "cooldown": "7/6/5/4/3",
      "cost": "35",
      "costType": " {{ abilityresourcename }}",
      "range": "815",
      "maxrank": 5,
      "image": "OrianaIzunaCommand.png",
      "key": "Q"
    },
    {
      "name": "指令：杂音",
      "description": "奥莉安娜指挥她的魔偶，释放能量脉冲，造成魔法伤害，并产生一个加速友军、减速敌军的能量场。",
      "tooltip": "奥莉安娜指挥她的魔偶释放一股电脉冲，对周围敌军造成{{ totaldamage }}魔法伤害。此电脉冲会留下持续{{ fieldduration }}秒的能量场，使敌人减速{{ slowamount*100 }}%，并为友军提供{{ hasteamount*100 }}%移动速度，在{{ slowandhasteduration }}秒里持续衰减。",
      "cooldown": "7",
      "cost": "60/65/70/75/80",
      "costType": " {{ abilityresourcename }}",
      "range": "225",
      "maxrank": 5,
      "image": "OrianaDissonanceCommand.png",
      "key": "W"
    },
    {
      "name": "指令：防卫",
      "description": "奥莉安娜指挥她的魔偶，依附于友军英雄身上，保护他们并对经过的敌人造成魔法伤害。此外，魔偶还会对依附的友军增加额外护甲和魔法抗性。",
      "tooltip": "被动：魔偶为附身的友军英雄增加{{ defensebonus }}护甲和{{ defensebonus }}魔法抗性。主动：奥莉安娜指挥她的魔偶附身在一名友方英雄身上，为其提供{{ totalshieldtooltip }}护盾值，持续{{ shieldduration }}秒。魔偶途经的敌方单位都会受到{{ totaldamagetooltip }}魔法伤害。",
      "cooldown": "9",
      "cost": "60",
      "costType": " {{ abilityresourcename }}",
      "range": "1095",
      "maxrank": 5,
      "image": "OrianaRedactCommand.png",
      "key": "E"
    },
    {
      "name": "指令：冲击波",
      "description": "奥莉安娜指挥她的魔偶，释放一股冲击波，对周围敌军造成魔法伤害并在短暂延迟后将他们拉向魔偶。",
      "tooltip": "奥莉安娜指挥她的魔偶，在短暂的延迟后释放一股冲击波，对周围敌军造成{{ totaldamage }}魔法伤害并将他们朝魔偶的方向击飞。",
      "cooldown": "110/95/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "410",
      "maxrank": 3,
      "image": "OrianaDetonateCommand.png",
      "key": "R"
    }
  ]
}