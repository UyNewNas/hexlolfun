  "passive": {
    "name": "优雅蛇行",
    "description": "卡西奥佩娅身上的所有移动速度加成效率变得更多。",
    "image": "Cassiopeia_Passive.png"
  },
  "spells": [
    {
      "name": "瘟毒爆炸",
      "description": "在短暂的延迟后，卡西奥佩娅用毒素引爆一片区域，并且如果命中了一名敌方英雄，就会获得移动速度加成。",
      "tooltip": "卡西奥佩娅引爆毒性气体，使敌人中毒并且在{{ poisonduration }}秒内造成{{ tooltiptotaldamage }}魔法伤害。命中一名英雄会为卡西奥佩娅提供在{{ champhitmsduration }}秒里持续衰减的{{ champhitmsbonus }}%移动速度。",
      "cooldown": "3.5",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "850",
      "maxrank": 5,
      "image": "CassiopeiaQ.png",
      "key": "Q"
    },
    {
      "name": "剧毒迷雾",
      "description": "卡西奥佩娅释放出若干团毒云，对经过毒云的敌人造成减速效果、缚地效果和轻量伤害。被缚地的敌人无法使用位移技能。",
      "tooltip": "卡西奥佩娅吐出毒液，留下一团持续{{ cloudduration }}秒的毒云。对毒云内的敌人们造成每秒{{ damagepersecond }}魔法伤害、中毒、缚地、以及{{ slowpercent }}%减速。",
      "cooldown": "24/22/20/18/16",
      "cost": "70/75/80/85/90",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "CassiopeiaW.png",
      "key": "W"
    },
    {
      "name": "双生毒牙",
      "description": "卡西奥佩娅释放一次攻击，可对中毒的目标造成额外伤害并且基于实际伤害值为她提供治疗效果。如果目标死于这次攻击，卡西奥佩娅会回复法力值。",
      "tooltip": "卡西奥佩娅发射致命的毒牙，造成{{ basicdamage }}魔法伤害。如果敌人已经中毒，那么还会受到额外的{{ bonuspoisoneddamage }}魔法伤害并且卡西奥佩娅回复{{ healcalc }}生命值，对抗小兵和小型野怪降低至{{ healcalcminion }}生命值。如果这个技能击杀了目标，那么卡西奥佩娅回复{{ cost }}法力值。",
      "cooldown": "0.75",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "700",
      "maxrank": 5,
      "image": "CassiopeiaE.png",
      "key": "E"
    },
    {
      "name": "石化凝视",
      "description": "卡西奥佩娅从眼中放出一团魔法能量，对她前方的任何面对她的敌人造成晕眩效果并对其它背对她的敌人造成减速效果。",
      "tooltip": "卡西奥佩娅释放一道震慑敌人的凝视，造成{{ rdamage }}魔法伤害并将面朝她的敌人们晕眩{{ rccduration }}秒。作为替代，未面朝她的敌人们会被减速{{ rslowpercent }}%，在相同时长内持续衰减。",
      "cooldown": "120/100/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "825",
      "maxrank": 3,
      "image": "CassiopeiaR.png",
      "key": "R"
    }
  ]
