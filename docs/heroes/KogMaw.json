  "passive": {
    "name": "来自艾卡西亚的惊喜",
    "description": "在死后4秒，克格莫会爆炸，对周围的敌人造成真实伤害。",
    "image": "KogMaw_IcathianSurprise.png"
  },
  "spells": [
    {
      "name": "腐蚀唾液",
      "description": "克格莫发射一团腐蚀性物质，对目标造成魔法伤害，并暂时腐蚀目标的护甲和魔法抗性。克格莫还会获得额外攻速。",
      "tooltip": "被动：克格莫获得{{ attackspeed*100 }}%攻击速度。主动：克格莫抛射出一团腐蚀性的唾沫，对命中的第一个敌人造成{{ totaldamage }}魔法伤害，以及持续{{ shredduration }}秒的{{ shredamount }}%护甲和魔法抗性击碎。",
      "cooldown": "7",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "1175",
      "maxrank": 5,
      "image": "KogMawQ.png",
      "key": "Q"
    },
    {
      "name": "生化弹幕",
      "description": "克格莫的攻击获得额外距离，并且能够对目标造成额外的魔法伤害，伤害值基于目标的最大生命值%i:OnHit% 攻击特效。",
      "tooltip": "克格莫获得{{ range }}攻击距离，并且他的攻击附带额外的{{ totalhealthdamage }}最大生命值的魔法伤害%i:OnHit% 攻击特效，持续{{ duration }}秒。",
      "cooldown": "17",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "530",
      "maxrank": 5,
      "image": "KogMawBioArcaneBarrage.png",
      "key": "W"
    },
    {
      "name": "虚空淤泥",
      "description": "克格莫抛射出一团特殊的分泌物，对经过或停留在分泌物上的敌人造成伤害和减速效果。",
      "tooltip": "克格莫呕出胆汁，造成{{ totaldamage }}魔法伤害并留下一条持续{{ trailduration }}秒的软泥路径。软泥中的敌人们会被减速{{ slowamount }}%。",
      "cooldown": "12",
      "cost": "40/55/70/85/100",
      "costType": " {{ abilityresourcename }}",
      "range": "1200",
      "maxrank": 5,
      "image": "KogMawVoidOoze.png",
      "key": "E"
    },
    {
      "name": "活体大炮",
      "description": "克格莫发射一枚射程极远的活体炮弹，让被命中的敌人暴露在己方视野中，并对目标造成魔法伤害（对低血量目标的伤害会显著提升）。 在短时间内连续使用活体大炮，将消耗额外的法力值。",
      "tooltip": "克格莫朝一个区域发射一团酸液，造成{{ basedamagecalc }}外加{{ tooltipmissinghealthdamageamp }}%每1%已损失生命值的魔法伤害并使命中的敌人显形2秒。低于40%生命值的敌人们会转而受到{{ maxdamagecalc }}魔法伤害。{{ manacostduration }}秒内的后续发射会消耗额外的{{ basecost }}法力(最大值：{{ manacostcap }}法力)。",
      "cooldown": "2/1.5/1",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "1300/1550/1800",
      "maxrank": 3,
      "image": "KogMawLivingArtillery.png",
      "key": "R"
    }
  ]
}