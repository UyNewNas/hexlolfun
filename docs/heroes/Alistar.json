  "passive": {
    "name": "凯旋怒吼",
    "description": "阿利斯塔在对敌方英雄造成晕眩或强制位移时，或附近有敌人阵亡时，会积攒他的怒吼层数。在层数攒满后，他会治疗他自己和所有附近的友方英雄。",
    "image": "Alistar_E.png"
  },
  "spells": [
    {
      "name": "大地粉碎",
      "description": "阿利斯塔锤击地面，对附近的敌人造成魔法伤害并使他们浮空。",
      "tooltip": "阿利斯塔使大地破裂，击飞敌人{{ knockupduration }}秒并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "365",
      "maxrank": 5,
      "image": "Pulverize.png",
      "key": "Q"
    },
    {
      "name": "野蛮冲撞",
      "description": "阿利斯塔冲撞目标，对其造成伤害并击退目标。",
      "tooltip": "阿利斯塔顶向一名敌人，将其击退并造成{{ totaldamage }}魔法伤害。",
      "cooldown": "14/13/12/11/10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "650",
      "maxrank": 5,
      "image": "Headbutt.png",
      "key": "W"
    },
    {
      "name": "践踏",
      "description": "阿利斯塔践踏附近的敌方单位，无视单位的碰撞体积并在他伤害到一名敌方英雄时获得一层充能。在满层充能时，阿利斯塔的下次对敌方英雄发起的普攻将造成额外魔法伤害和晕眩效果。",
      "tooltip": "阿利斯塔践踏地面，变为幽灵状态并在{{ duration }}秒里持续对附近的敌人造成{{ totaldamage }}魔法伤害。每段践踏在至少伤害到一名敌方英雄时会为阿利斯塔提供一层效果。在{{ maxstacks }}层效果时，阿利斯塔的下一个对英雄打出的攻击会晕眩目标{{ stunduration }}秒并造成额外的{{ attackbonusdamage }}魔法伤害。",
      "cooldown": "12/11.5/11/10.5/10",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "350",
      "maxrank": 5,
      "image": "AlistarE.png",
      "key": "E"
    },
    {
      "name": "坚定意志",
      "description": "阿利斯塔发出野性的咆哮，移除身上所有控制效果，并且持续时间内所受的物理和魔法伤害将减少。",
      "tooltip": "阿利斯塔立刻净化掉所有限制效果并获得{{ rdamagereduction }}%伤害减免，持续{{ rduration }}秒。",
