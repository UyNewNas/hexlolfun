  "passive": {
    "name": "坚韧",
    "description": "如果盖伦近期没有受到伤害或者被敌方技能命中，那么他会每秒回复若干百分比的总生命值。",
    "image": "Garen_Passive.png"
  },
  "spells": [
    {
      "name": "致命打击",
      "description": "盖伦的移动速度获得爆发性提升，同时移除身上的所有减速效果。他的下次攻击将打击敌人的要害部位，造成额外伤害并将目标沉默。",
      "tooltip": "盖伦移除身上的所有减速效果并获得{{ movementspeedamount*100 }}%移动速度，持续{{ movementspeedduration }}秒。他的下次攻击会使目标沉默{{ silenceduration }}秒并造成{{ totaldamage }}物理伤害。",
      "cooldown": "8",
      "cost": "0",
      "costType": "无消耗",
      "range": "300",
      "maxrank": 5,
      "image": "GarenQ.png",
      "key": "Q"
    },
    {
      "name": "勇气",
      "description": "盖伦被动地通过击杀敌人来提升护甲和魔法抗性。他也可以激活这个技能来暂时获得一层护盾和韧性，并在接下来的较长持续时间里获得较弱的伤害减免效果。",
      "tooltip": "被动：盖伦获得{{ resistsfortooltip }}额外护甲和{{ resistsfortooltip }}额外魔法抗性。击杀单位时会永久提供{{ resistgainonkilltooltip }}双抗，至多至最大值{{ resistmax }}。主动：盖伦加固他的勇气{{ drduration }}秒，使即将到来的伤害降低{{ drpercent*100 }}%。他还会获得持续{{ upfrontduration }}秒的{{ totalshield }}护盾值和{{ upfronttenacity*100 }}%韧性。",
      "cooldown": "22/19.5/17/14.5/12",
      "cost": "0",
      "costType": "无消耗",
      "range": "0",
      "maxrank": 5,
      "image": "GarenW.png",
      "key": "W"
    },
    {
      "name": "审判",
      "description": "盖伦快速地旋转身体挥舞大剑，并对邻近敌人造成物理伤害。",
      "tooltip": "盖伦快速地旋舞大剑，持续{{ duration }}秒，每旋转一圈造成{{ totaldamage }}物理伤害，共旋转{{ f1 }}圈。相距最近的敌人受到{{ nearestenemybonus*100 }}%提升伤害。被{{ stackstoshred }}圈旋转命中的敌方英雄会损失{{ shredamount*100 }}%护甲，持续{{ shredduration }}秒。再次施放：盖伦提前结束这个技能。",
      "cooldown": "9/8.25/7.5/6.75/6",
      "cost": "0",
      "costType": "无消耗",
      "range": "325",
      "maxrank": 5,
      "image": "GarenE.png",
      "key": "E"
    },
    {
      "name": "德玛西亚正义",
      "description": "盖伦召唤德玛西亚之力，试图处决一名敌方英雄。",
      "tooltip": "盖伦召唤德玛西亚之力来击杀他的敌人，造成{{ basedamage }}外加{{ executedamage*100 }}%已损失生命值的真实伤害。",
      "cooldown": "120/100/80",
      "cost": "0",
      "costType": "无消耗",
      "range": "400",
      "maxrank": 3,
      "image": "GarenR.png",
      "key": "R"
    }
  ]
