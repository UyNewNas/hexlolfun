  "passive": {
    "name": "背刺",
    "description": "在目标的背后时，萨科的普攻和【E双面毒刃】会造成额外伤害。",
    "image": "Jester_CarefulStrikes.png"
  },
  "spells": [
    {
      "name": "欺诈魔术",
      "description": "萨科进入隐形状态并传送到目标位置。他在隐形状态下的第一次普攻将获得增强，造成额外伤害并在目标背后攻击时必定会暴击。",
      "tooltip": "萨科传送并变为隐形，持续{{ stealthduration }}秒。使用惊吓魔盒或幻像不会打破隐形。萨科在隐形时的下次攻击造成额外的{{ totaldamage }}物理伤害。如果从背后进行打击，那么这个攻击会暴击，造成{{ qcritdamagemod }}伤害。",
      "cooldown": "13/12.5/12/11.5/11",
      "cost": "40",
      "costType": " {{ abilityresourcename }}",
      "range": "400",
      "maxrank": 5,
      "image": "Deceive.png",
      "key": "Q"
    },
    {
      "name": "惊吓魔盒",
      "description": "萨科丢出一个隐形且会动的惊吓魔盒。在触发时，盒子会恐惧附近的敌人，然后对其进行攻击。",
      "tooltip": "萨科生成一个会在{{ e5 }}秒后潜行的陷阱，持续{{ trapduration }}秒。它会在有敌人靠近或显形时触发，恐惧附近的敌方英雄们{{ fearduration }}秒，或小兵和野怪{{ minionfearduration }}秒。一旦激活，陷阱就会在5秒里持续攻击所有附近的敌人们，造成{{ aoedamage }}魔法伤害，如果只攻击一个敌人则为{{ stdamage }}伤害。惊吓魔盒的攻击对野怪造成额外的{{ monsterbonusdamage }}伤害。",
      "cooldown": "15",
      "cost": "70/65/60/55/50",
      "costType": " {{ abilityresourcename }}",
      "range": "500",
      "maxrank": 5,
      "image": "JackInTheBox.png",
      "key": "W"
    },
    {
      "name": "双面毒刃",
      "description": "萨科的毒刃在命中时会被动地使目标中毒，减少目标的移动速度。他可以将毒刃扔向目标，造成伤害和中毒效果。扔出的毒刃会对生命值低于30%的目标造成额外伤害。",
      "tooltip": "被动：当这个技能未进入冷却阶段时，萨科的攻击会对目标造成持续{{ slowdurationpassive }}秒的{{ slowamount*-100 }}%减速。主动：萨科扔出一把毒刃，造成{{ totaldamage }}魔法伤害和持续{{ slowdurationactive }}秒的{{ slowamount*-100 }}%减速。如果目标低于{{ executehealththreshold*100 }}%生命值，毒刃会转而造成{{ totalexecutedamage }}伤害。",
      "cooldown": "8",
      "cost": "75",
      "costType": " {{ abilityresourcename }}",
      "range": "625",
      "maxrank": 5,
      "image": "TwoShivPoison.png",
      "key": "E"
    },
    {
      "name": "幻像",
      "description": "萨科在身边制造一个自己的幻像，幻像能够攻击周围的敌人（对防御塔造成较少伤害）。在死亡时爆炸，它会爆炸，生成三个小型惊吓魔盒并对附近的敌人造成伤害。",
      "tooltip": "萨科暂时消失，然后重新出现并制造一个持续{{ clonelifetime }}秒的幻像，幻像会在死亡时爆炸，对附近的敌人造成{{ explosiontotaldamage }}魔法伤害并生成三个立即触发的小型惊吓魔盒。幻像造成萨科{{ cloneaadamagepercent*100 }}%的伤害并承受{{ cloneincomingdamagepercent*100 }}%额外伤害。小型惊吓魔盒造成{{ aoedamage }}魔法伤害，如果只攻击一个敌人则为{{ stdamage }}魔法伤害，并让敌人恐惧{{ boxfearduration }}秒。",
      "cooldown": "100/90/80",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "200",
      "maxrank": 3,
      "image": "HallucinateFull.png",
      "key": "R"
    }
  ]
}