  "passive": {
    "name": "复仇之欲",
    "description": "每完成一次击杀或助攻，韦鲁斯就会暂时获得攻击速度、攻击力和法术强度。如果敌人是个英雄，则这个加成的幅度会更大。",
    "image": "VarusPassive.png"
  },
  "spells": [
    {
      "name": "穿刺之箭",
      "description": "韦鲁斯开始蓄力，随后进行一次远距离的强力射击，蓄力时间越长，伤害越高。",
      "tooltip": "开始蓄力：韦鲁斯为一次强力射击深深挽弓，自我减速{{ movespeedmod*-100 }}%。在{{ maxchannelduration }}秒后，如果未将箭射出去，则韦鲁斯会取消这个技能并返还其{{ manarefund*100 }}%法力消耗。释放：韦鲁斯将箭射出，造成{{ totaldamagemintooltip }}物理伤害，每命中一个敌人就会降低{{ falloffpercent*100 }}%(最低降至{{ mindamagepercent*100 }}%)。伤害和枯萎的引爆效果会基于蓄力时间至多提升至{{ maxchargeamp*100 }}%(最大值为{{ totaldamagemax }}) 。",
      "cooldown": "16/15/14/13/12",
      "cost": "50/55/60/65/70",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "VarusQ.png",
      "key": "Q"
    },
    {
      "name": "枯萎箭袋",
      "description": "被动：韦鲁斯的普通攻击会造成额外的伤害，并附加枯萎效果。韦鲁斯的其它技能会引爆枯萎效果，造成基于目标最大生命值的魔法伤害。主动：韦鲁斯增强他的下一个【穿刺之箭】。",
      "tooltip": "被动：韦鲁斯的攻击造成额外的{{ onhitdamage }}魔法伤害并施加一层持续{{ debuffduration }}秒的枯萎(最多至{{ maxstacks }}层)。韦鲁斯的其它技能会引爆枯萎层数来造成每层{{ percenthpperstack }}最大生命值伤害(最大值为{{ maxpercenthpperstack }}最大生命值伤害)。引爆英雄和史诗级野怪身上的枯萎时也会使他基础技能的冷却时间缩短，数额为每层{{ cdrperblightstack*100 }}%基础冷却时间。主动：韦鲁斯的下一个穿刺之箭会造成额外的{{ qempowerpercenthp }}已损失生命值的魔法伤害，并且基于蓄力时间不断提升，至多可达{{ maxqempowerpercenthp }}已损失生命值伤害。",
      "cooldown": "40",
      "cost": "0",
      "costType": "无消耗",
      "range": "750",
      "maxrank": 5,
      "image": "VarusW.png",
      "key": "W"
    },
    {
      "name": "恶灵箭雨",
      "description": "韦鲁斯射出一阵箭雨，造成物理伤害并污染地面。被污染的地面将会减慢敌人的移动速度，并降低他们的自我治疗效果和回复效果。",
      "tooltip": "韦鲁斯射出一阵箭雨，造成{{ totaldamage }}物理伤害，并污染地面{{ groundduration }}秒，减速敌人{{ slowpercent*-100 }}%并施加{{ grievousamount*100 }}%重伤。",
      "cooldown": "18/16/14/12/10",
      "cost": "90",
      "costType": " {{ abilityresourcename }}",
      "range": "925",
      "maxrank": 5,
      "image": "VarusE.png",
      "key": "E"
    },
    {
      "name": "腐败锁链",
      "description": "韦鲁斯投掷出一个腐败藤蔓，来禁锢命中的第一个敌方英雄，随后向附近没有被感染的英雄蔓延，并在碰到后将他们也禁锢。",
      "tooltip": "韦鲁斯猛射出一根腐败藤蔓，禁锢命中的第一个敌方英雄{{ rootduration }}秒并造成{{ totaldamage }}魔法伤害。被禁锢的敌人们会在此期间持续获得{{ passivestacks }}层枯萎。随后腐败藤蔓会从它的目标处向附近未被感染的英雄蔓延。如果它接触到了未被感染的英雄，就会使其承受相同的伤害和禁锢。",
      "cooldown": "100/80/60",
      "cost": "100",
      "costType": " {{ abilityresourcename }}",
      "range": "1300",
      "maxrank": 3,
      "image": "VarusR.png",
      "key": "R"
    }
  ]
}